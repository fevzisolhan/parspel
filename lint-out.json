     border: \"none\",\r\n                color: \"#64748b\",\r\n                cursor: \"pointer\",\r\n                fontSize: \"1.1rem\",\r\n              }}\r\n            >\r\n              ├ó┼ôΓÇó\r\n            </button>\r\n          </div>\r\n          <ApiSettings\r\n            onClose={() => {\r\n              invalidateKeyCache();\r\n              setShowSettings(false);\r\n            }}\r\n          />\r\n        </div>\r\n      )}\r\n\r\n      {/* Quick prompts ├óΓé¼ΓÇ¥ bo┼ƒ ekranda b├╝y├╝k grid */}\r\n      {messages.length === 0 && !showSettings && (\r\n        <div style={{ marginBottom: 14 }}>\r\n          <div\r\n            style={{\r\n              flex: 1,\r\n              display: \"flex\",\r\n              flexDirection: \"column\",\r\n              alignItems: \"center\",\r\n              justifyContent: \"center\",\r\n              textAlign: \"center\",\r\n              padding: \"20px 0 16px\",\r\n            }}\r\n          >\r\n            <div style={{ fontSize: \"3rem\", marginBottom: 10, opacity: 0.5 }}>\r\n              ─ƒ┼╕┬ñΓÇô\r\n            </div>\r\n            <h3\r\n              style={{\r\n                color: \"#475569\",\r\n                fontWeight: 700,\r\n                marginBottom: 6,\r\n                fontSize: \"0.95rem\",\r\n              }}\r\n            >\r\n              ─░┼ƒletmenizle ilgili her ┼ƒeyi sorabilirsiniz\r\n            </h3>\r\n            <p\r\n              style={{\r\n                color: \"#334155\",\r\n                fontSize: \"0.8rem\",\r\n                maxWidth: 360,\r\n                lineHeight: 1.6,\r\n              }}\r\n            >\r\n              {hasKeys\r\n                ? \"Ger├ºek verilerinizi analiz ederek yan─▒t verir.\"\r\n                : \"ΓÜá∩╕Å Ayarlar'dan API anahtarini girin. Internetsiz de temel sorulara yanit verir.\"}\r\n            </p>\r\n          </div>\r\n          <div\r\n            style={{\r\n              display: \"grid\",\r\n             