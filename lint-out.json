uleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":77,"column":24,"messageId":"unexpectedAny","endLine":77,"endColumn":27,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2748,2751],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2748,2751],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useRef, useCallback, useEffect } from 'react';\r\n\r\n// Android WebView'da Web Speech API ├ºal─▒┼ƒmaz.\r\n// Capacitor + Android i├ºin SpeechRecognition plugin kullan─▒l─▒r.\r\n// Fallback: getUserMedia ile mikrofon izni al─▒n─▒r.\r\n\r\nfunction isAndroid(): boolean {\r\n  return /android/i.test(navigator.userAgent);\r\n}\r\n\r\nfunction isCapacitor(): boolean {\r\n  return !!(window as any).Capacitor?.isNativePlatform?.();\r\n}\r\n\r\n// ΓöÇΓöÇ Sesli Tan─▒ma (Speech-to-Text) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport function useSpeechRecognition(onResult: (text: string) => void) {\r\n  const [listening, setListening] = useState(false);\r\n  const [supported, setSupported] = useState(false);\r\n  const [error, setError] = useState('');\r\n  const recRef = useRef<any>(null);\r\n\r\n  useEffect(() => {\r\n    // Android native'de Web Speech API ├ºal─▒┼ƒmaz ama kontrol edelim\r\n    const SpeechRecognition =\r\n      (window as any).SpeechRecognition ||\r\n      (window as any).webkitSpeechRecognition ||\r\n      (window as any).mozSpeechRecognition;\r\n    // Android'de desteklenmiyor olarak i┼ƒaretle (WebView k─▒s─▒t─▒)\r\n    const androidNative = isCapacitor() && isAndroid();\r\n    setSupported(!!SpeechRecognition && !androidNative);\r\n  }, []);\r\n\r\n  const start = useCallback(async () => {\r\n    // Android native'de desteklenmiyor\r\n    if (isCapacitor() && isAndroid()) {\r\n      setError('Sesli giri┼ƒ Android uygulamas─▒nda desteklenmiyor. Web taray─▒c─▒s─▒ndan kullan─▒n.');\r\n      setTimeout(() => setError(''), 4000);\r\n      return;\r\n    }\r\n\r\n    const SpeechRecognition =\r\n      (window as any).SpeechRecognition ||\r\n      (window as any).webkitSpeechRecognition;\r\n\r\n    if (!SpeechRecognition) {\r\n      setError('Bu cihaz sesli giri┼ƒi desteklemiyor');\r\n      setTimeout(() => setError(''), 3000);\r\n      return;\r\n    }\r\n\r\n    // Mikrofon izni iste\r\n    if (navigator.mediaDevices?.getUserMedia) {\r\n      try {\r\n        await navigator.mediaDevices.getUserMedia({ audio: true });\r\n      } catch {\r\n        setError('Mikrofon izni gerekli ΓÇö Ayarlar > Uygulama ─░zinleri');\r\n        setTimeout(() => setError(''), 4000);\r\n        return;\r\n      }\r\n    }\r\n\r\n    const rec = new SpeechRecognition();\r\n    rec.lang = 'tr-TR';\r\n    rec.continuous = false;\r\n    rec.interimResults = false;\r\n    rec.maxAlternatives = 1;\r\n\r\n    rec.onstart = () => { setListening(true); setError(''); };\r\n    rec.onend = () => setListening(false);\r\n    rec.onerror = (e: any) => {\r\n      setListening(false);\r\n      if (e.error === 'no-speech') setError('Ses alg─▒lanamad─▒, tekrar deneyin');\r\n      else if (e.error === 'not-allowed') setError('Mikrofon izni gerekli');\r\n      else setError('Ses tan─▒ma hatas─▒: ' + e.error);\r\n      setTimeout(() => setError(''), 3000);\r\n    };\r\n    rec.onresult = (e: any) => {\r\n      const text = e.results[0][0].transcript;\r\n      if (text.trim()) onResult(text.trim());\r\n    };\r\n\r\n    recRef.current = rec;\r\n    try { rec.start(); } catch { setError('Ses tan─▒ma ba┼ƒlat─▒lamad─▒'); }\r\n  }, [onResult]);\r\n\r\n  const stop = useCallback(() => {\r\n    recRef.current?.stop();\r\n    setListening(false);\r\n  }, []);\r\n\r\n  return { listening, supported, error, start, stop };\r\n}\r\n\r\n// ΓöÇΓöÇ Sesli Okuma (Text-to-Speech) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport function useSpeechSynthesis() {\r\n  const [speaking, setSpeaking] = useState(false);\r\n  const utterRef = useRef<SpeechSynthesisUtterance | null>(null);\r\n\r\n  // Android WebView'da speechSynthesis var ama T├╝rk├ºe ses olmayabilir\r\n  const supported = 'speechSynthesis' in window;\r\n\r\n  const speak = useCallback((text: string) => {\r\n    if (!supported) return;\r\n\r\n    // ├ûnceki konu┼ƒmay─▒ durdur\r\n    window.speechSynthesis.cancel();\r\n\r\n    // Markdown temizle\r\n    const clean = text\r\n      .replace(/\\*\\*(.*?)\\*\\*/g, '$1')\r\n      .replace(/\\*(.*?)\\*/g, '$1')\r\n      .replace(/#{1,6}\\s/g, '')\r\n      .replace(/`{1,3}[^`]*`{1,3}/g, '')\r\n      .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1')\r\n      .replace(/[-ΓÇó]\\s/g, '')\r\n      // Say─▒lar─▒ T├╝rk├ºe okunabilir hale getir\r\n      .replace(/Γé║(\\d+)/g, '$1 lira')\r\n      .replace(/(\\d+)%/g, 'y├╝zde $1')\r\n      .slice(0, 500);\r\n\r\n    const utter = new SpeechSynthesisUtterance(clean);\r\n    utter.lang = 'tr-TR';\r\n    // Daha do─ƒal ses i├ºin ayarlar\r\n    utter.rate = 0.95;   // biraz yava┼ƒ = daha net\r\n    utter.pitch = 1.05;  // hafif y├╝ksek = daha canl─▒\r\n    utter.volume = 1;\r\n\r\n    // En iyi T├╝rk├ºe sesi se├º\r\n    const trySpeak = () => {\r\n      const voices = window.speechSynthesis.getVoices();\r\n      // ├ûncelik s─▒ras─▒: Google TR > Microsoft TR > herhangi TR\r\n      const trVoice =\r\n        voices.find(v => v.lang === 'tr-TR' && v.name.includes('Google')) ||\r\n        voices.find(v => v.lang === 'tr-TR' && v.name.includes('Microsoft')) ||\r\n        voices.find(v => v.lang === 'tr-TR') ||\r\n        voices.find(v => v.lang.startsWith('tr'));\r\n      if (trVoice) utter.voice = trVoice;\r\n      utter.onstart = () => setSpeaking(true);\r\n      utter.onend = () => setSpeaking(false);\r\n      utter.onerror = () => setSpeaking(false);\r\n      utterRef.current = utter;\r\n      window.speechSynthesis.speak(utter);\r\n    };\r\n\r\n    if (window.speechSynthesis.getVoices().length > 0) {\r\n      trySpeak();\r\n    } else {\r\n      window.speechSynthesis.onvoiceschanged = () => {\r\n        window.speechSynthesis.onvoiceschanged = null;\r\n        trySpeak();\r\n      };\r\n      setTimeout(trySpeak, 500);\r\n    }\r\n  }, [supported]);\r\n\r\n  const stop = useCallback(() => {\r\n    window.speechSynthesis.cancel();\r\n    setSpeaking(false);\r\n  }, []);\r\n\r\n  return { speaking, supported, speak, stop };\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\hooks\\useUIPrefs.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\anomalyEngine.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\appConfig.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\auditEngine.test.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'vi' is defined but never used. Allowed unused vars must match /^_/u.","line":8,"column":44,"messageId":"unusedVar","endLine":8,"endColumn":46,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"vi"},"fix":{"range":[174,178],"text":""},"desc":"Remove unused variable \"vi\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'makeCari' is defined but never used. Allowed unused vars must match /^_/u.","line":73,"column":10,"messageId":"unusedVar","endLine":73,"endColumn":18}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Audit Engine ΓÇö Birim ve Property Testleri\r\n *\r\n * Feature: rule-engine-audit\r\n * Test framework: Vitest + fast-check\r\n */\r\n\r\nimport { describe, it, expect, beforeEach, vi } from 'vitest';\r\nimport * as fc from 'fast-check';\r\nimport {\r\n  computeDiff,\r\n  createAuditEntry,\r\n  trimAuditLog,\r\n  runFullAudit,\r\n  getSessionId,\r\n} from './auditEngine';\r\nimport type { DB, AuditEntry, KasaEntry, Cari, RuleViolation } from '@/types';\r\n\r\n// ΓöÇΓöÇΓöÇ Test Yard─▒mc─▒lar─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction makeDB(overrides: Partial<DB> = {}): DB {\r\n  const now = new Date().toISOString();\r\n  return {\r\n    _version: 1,\r\n    products: [],\r\n    sales: [],\r\n    suppliers: [],\r\n    orders: [],\r\n    cari: [],\r\n    kasa: [],\r\n    kasalar: [{ id: 'nakit', name: 'Nakit', icon: '≡ƒÆ╡' }],\r\n    bankTransactions: [],\r\n    matchRules: [],\r\n    monitorRules: [],\r\n    monitorLog: [],\r\n    stockMovements: [],\r\n    peletSuppliers: [],\r\n    peletOrders: [],\r\n    boruSuppliers: [],\r\n    boruOrders: [],\r\n    invoices: [],\r\n    budgets: [],\r\n    returns: [],\r\n    _activityLog: [],\r\n    _auditLog: [],\r\n    company: { id: 'c1', createdAt: now },\r\n    settings: {},\r\n    pelletSettings: { gramaj: 14, kgFiyat: 6.5, cuvalKg: 15, critDays: 3 },\r\n    ortakEmanetler: [],\r\n    installments: [],\r\n    partners: [],\r\n    productCategories: [],\r\n    notes: [],\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nfunction makeKasaEntry(overrides: Partial<KasaEntry> = {}): KasaEntry {\r\n  const now = new Date().toISOString();\r\n  return {\r\n    id: 'k1',\r\n    type: 'gelir',\r\n    category: 'satis',\r\n    amount: 500,\r\n    kasa: 'nakit',\r\n    deleted: false,\r\n    createdAt: now,\r\n    updatedAt: now,\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nfunction makeCari(overrides: Partial<Cari> = {}): Cari {\r\n  const now = new Date().toISOString();\r\n  return {\r\n    id: 'cari1',\r\n    name: 'Test M├╝┼ƒteri',\r\n    type: 'musteri',\r\n    balance: 0,\r\n    deleted: false,\r\n    createdAt: now,\r\n    updatedAt: now,\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nfunction makeAuditEntry(overrides: Partial<AuditEntry> = {}): AuditEntry {\r\n  return {\r\n    id: `ae_${Math.random().toString(36).slice(2)}`,\r\n    action: 'save',\r\n    entity: 'DB',\r\n    sessionId: 'test-session',\r\n    status: 'applied',\r\n    time: new Date().toISOString(),\r\n    ...overrides,\r\n  };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ computeDiff Testleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('computeDiff', () => {\r\n  it('de─ƒi┼ƒen alanlar diff\\'te yer al─▒r', () => {\r\n    const prev = makeDB({ products: [] });\r\n    const next = makeDB({ products: [{ id: 'p1', name: '├£r├╝n', category: 'soba', cost: 100, price: 150, stock: 10, minStock: 2, deleted: false, createdAt: new Date().toISOString(), updatedAt: new Date().toISOString() }] });\r\n    const { prevValue, nextValue } = computeDiff(prev, next);\r\n    expect(prevValue).toHaveProperty('products');\r\n    expect(nextValue).toHaveProperty('products');\r\n  });\r\n\r\n  it('de─ƒi┼ƒmeyen alanlar diff\\'te yer almaz', () => {\r\n    const db = makeDB({ _version: 5 });\r\n    const { prevValue, nextValue } = computeDiff(db, db);\r\n    expect(Object.keys(prevValue)).toHaveLength(0);\r\n    expect(Object.keys(nextValue)).toHaveLength(0);\r\n  });\r\n\r\n  it('_auditLog diff\\'e dahil edilmez (sonsuz d├╢ng├╝ ├╢nlemi)', () => {\r\n    const prev = makeDB({ _auditLog: [] });\r\n    const next = makeDB({ _auditLog: [makeAuditEntry()] });\r\n    const { prevValue, nextValue } = computeDiff(prev, next);\r\n    expect(prevValue).not.toHaveProperty('_auditLog');\r\n    expect(nextValue).not.toHaveProperty('_auditLog');\r\n  });\r\n\r\n  it('hata durumunda bo┼ƒ diff d├╢ner', () => {\r\n    // null ge├ºilse bile exception f─▒rlatmamal─▒\r\n    expect(() => computeDiff(null as unknown as DB, makeDB())).not.toThrow();\r\n  });\r\n});\r\n\r\n// ΓöÇΓöÇΓöÇ createAuditEntry Testleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('createAuditEntry', () => {\r\n  it('applied durumu i├ºin do─ƒru status ├╝retir', () => {\r\n    const db = makeDB();\r\n    const entry = createAuditEntry({ action: 'save', entity: 'DB', prevDB: db, nextDB: db, status: 'applied' });\r\n    expect(entry.status).toBe('applied');\r\n    expect(entry.violations).toBeUndefined();\r\n  });\r\n\r\n  it('blocked durumu i├ºin violations i├ºerir', () => {\r\n    const db = makeDB();\r\n    const violations: RuleViolation[] = [{ ruleId: 'negative_stock', ruleName: 'Negatif Stok', message: 'Stok negatif', severity: 'block' }];\r\n    const entry = createAuditEntry({ action: 'save', entity: 'DB', prevDB: db, nextDB: db, status: 'blocked', violations });\r\n    expect(entry.status).toBe('blocked');\r\n    expect(entry.violations).toHaveLength(1);\r\n    expect(entry.violations![0].ruleId).toBe('negative_stock');\r\n  });\r\n\r\n  it('warned durumu i├ºin do─ƒru status ├╝retir', () => {\r\n    const db = makeDB();\r\n    const violations: RuleViolation[] = [{ ruleId: 'duplicate_transaction', ruleName: 'M├╝kerrer', message: 'M├╝kerrer i┼ƒlem', severity: 'warn' }];\r\n    const entry = createAuditEntry({ action: 'save', entity: 'DB', prevDB: db, nextDB: db, status: 'warned', violations });\r\n    expect(entry.status).toBe('warned');\r\n  });\r\n\r\n  it('gerekli alanlar─▒ i├ºerir (id, time, sessionId)', () => {\r\n    const db = makeDB();\r\n    const entry = createAuditEntry({ action: 'test', entity: 'DB', prevDB: db, nextDB: db, status: 'applied' });\r\n    expect(typeof entry.id).toBe('string');\r\n    expect(entry.id.length).toBeGreaterThan(0);\r\n    expect(typeof entry.time).toBe('string');\r\n    expect(typeof entry.sessionId).toBe('string');\r\n  });\r\n\r\n  it('bo┼ƒ violations dizisi ΓåÆ violations undefined olur', () => {\r\n    const db = makeDB();\r\n    const entry = createAuditEntry({ action: 'save', entity: 'DB', prevDB: db, nextDB: db, status: 'applied', violations: [] });\r\n    expect(entry.violations).toBeUndefined();\r\n  });\r\n});\r\n\r\n// ΓöÇΓöÇΓöÇ trimAuditLog Testleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('trimAuditLog', () => {\r\n  it('500 kay─▒t s─▒n─▒r─▒n─▒ a┼ƒmaz', () => {\r\n    const entries = Array.from({ length: 600 }, (_, i) => makeAuditEntry({ id: `ae_${i}` }));\r\n    const trimmed = trimAuditLog(entries);\r\n    expect(trimmed.length).toBeLessThanOrEqual(500);\r\n  });\r\n\r\n  it('500\\'den az kay─▒t ΓåÆ de─ƒi┼ƒmeden d├╢ner', () => {\r\n    const entries = Array.from({ length: 100 }, (_, i) => makeAuditEntry({ id: `ae_${i}` }));\r\n    const trimmed = trimAuditLog(entries);\r\n    expect(trimmed).toHaveLength(100);\r\n  });\r\n\r\n  it('500 kay─▒t a┼ƒ─▒ld─▒─ƒ─▒nda en eski kay─▒tlar silinir (ilk kay─▒tlar korunur)', () => {\r\n    const entries = Array.from({ length: 600 }, (_, i) => makeAuditEntry({ id: `ae_${i}` }));\r\n    const trimmed = trimAuditLog(entries);\r\n    // ─░lk 500 kay─▒t korunmal─▒ (en yeni = ba┼ƒta)\r\n    expect(trimmed[0].id).toBe('ae_0');\r\n    expect(trimmed[499].id).toBe('ae_499');\r\n  });\r\n\r\n  it('tam 500 kay─▒t ΓåÆ de─ƒi┼ƒmeden d├╢ner', () => {\r\n    const entries = Array.from({ length: 500 }, (_, i) => makeAuditEntry({ id: `ae_${i}` }));\r\n    const trimmed = trimAuditLog(entries);\r\n    expect(trimmed).toHaveLength(500);\r\n  });\r\n});\r\n\r\n// ΓöÇΓöÇΓöÇ getSessionId Testleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('getSessionId', () => {\r\n  beforeEach(() => {\r\n    sessionStorage.clear();\r\n  });\r\n\r\n  it('string d├╢ner', () => {\r\n    const id = getSessionId();\r\n    expect(typeof id).toBe('string');\r\n    expect(id.length).toBeGreaterThan(0);\r\n  });\r\n\r\n  it('ayn─▒ oturumda ayn─▒ ID d├╢ner', () => {\r\n    const id1 = getSessionId();\r\n    const id2 = getSessionId();\r\n    expect(id1).toBe(id2);\r\n  });\r\n\r\n  it('sessionStorage temizlenince yeni ID ├╝retir', () => {\r\n    const id1 = getSessionId();\r\n    sessionStorage.clear();\r\n    const id2 = getSessionId();\r\n    expect(id1).not.toBe(id2);\r\n  });\r\n});\r\n\r\n// ΓöÇΓöÇΓöÇ runFullAudit Testleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('runFullAudit', () => {\r\n  it('bo┼ƒ DB ΓåÆ s─▒f─▒r istatistik d├╢ner', () => {\r\n    const db = makeDB();\r\n    const report = runFullAudit(db);\r\n    expect(report.totalEntries).toBe(0);\r\n    expect(report.appliedCount).toBe(0);\r\n    expect(report.blockedCount).toBe(0);\r\n    expect(report.warnedCount).toBe(0);\r\n    expect(report.balanceDrifts).toHaveLength(0);\r\n    expect(report.anomalies).toHaveLength(0);\r\n  });\r\n\r\n  it('_auditLog istatistiklerini do─ƒru hesaplar', () => {\r\n    const db = makeDB({\r\n      _auditLog: [\r\n        makeAuditEntry({ status: 'applied' }),\r\n        makeAuditEntry({ status: 'applied' }),\r\n        makeAuditEntry({ status: 'blocked' }),\r\n        makeAuditEntry({ status: 'warned' }),\r\n      ],\r\n    });\r\n    const report = runFullAudit(db);\r\n    expect(report.totalEntries).toBe(4);\r\n    expect(report.appliedCount).toBe(2);\r\n    expect(report.blockedCount).toBe(1);\r\n    expect(report.warnedCount).toBe(1);\r\n  });\r\n\r\n  it('TRANSACTION_LIMIT a┼ƒ─▒m─▒ ΓåÆ anomaly ve riskFlag ├╝retir', () => {\r\n    const db = makeDB({\r\n      kasa: [makeKasaEntry({ id: 'k_big', amount: 150_000, kasa: 'nakit' })],\r\n    });\r\n    const report = runFullAudit(db);\r\n    expect(report.anomalies.length).toBeGreaterThan(0);\r\n    expect(report.riskFlags.some(f => f.includes('TRANSACTION_LIMIT'))).toBe(true);\r\n  });\r\n\r\n  it('AuditReport gerekli alanlar─▒ i├ºerir', () => {\r\n    const db = makeDB();\r\n    const report = runFullAudit(db);\r\n    expect(report).toHaveProperty('anomalies');\r\n    expect(report).toHaveProperty('balanceDrifts');\r\n    expect(report).toHaveProperty('riskFlags');\r\n    expect(report).toHaveProperty('totalEntries');\r\n    expect(report).toHaveProperty('appliedCount');\r\n    expect(report).toHaveProperty('blockedCount');\r\n    expect(report).toHaveProperty('warnedCount');\r\n  });\r\n});\r\n\r\n// ΓöÇΓöÇΓöÇ Property-Based Testler ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n// Arbitrary: minimal AuditEntry\r\nconst arbAuditEntry = () => fc.record({\r\n  id: fc.uuid(),\r\n  action: fc.string({ minLength: 1, maxLength: 20 }),\r\n  entity: fc.constant('DB'),\r\n  sessionId: fc.uuid(),\r\n  status: fc.oneof(\r\n    fc.constant('applied' as const),\r\n    fc.constant('blocked' as const),\r\n    fc.constant('warned' as const)\r\n  ),\r\n  time: fc.constant(new Date().toISOString()),\r\n});\r\n\r\n// Arbitrary: minimal DB\r\nconst arbDB = () => fc.record({\r\n  _version: fc.integer({ min: 0, max: 100 }),\r\n}).map(partial => makeDB(partial as Partial<DB>));\r\n\r\n// Property 7: AuditEntry.status i┼ƒlem sonucunu yans─▒t─▒r\r\n// Feature: rule-engine-audit, Property 7: AuditEntry status reflects transaction outcome\r\ndescribe('Property 7: AuditEntry status reflects transaction outcome', () => {\r\n  it('createAuditEntry status parametresini do─ƒru yans─▒t─▒r', () => {\r\n    fc.assert(\r\n      fc.property(\r\n        fc.oneof(\r\n          fc.constant('applied' as const),\r\n          fc.constant('blocked' as const),\r\n          fc.constant('warned' as const)\r\n        ),\r\n        (status) => {\r\n          const db = makeDB();\r\n          const entry = createAuditEntry({ action: 'save', entity: 'DB', prevDB: db, nextDB: db, status });\r\n          return entry.status === status;\r\n        }\r\n      ),\r\n      { numRuns: 100 }\r\n    );\r\n  });\r\n});\r\n\r\n// Property 8: computeDiff yaln─▒zca de─ƒi┼ƒen alanlar─▒ i├ºerir\r\n// Feature: rule-engine-audit, Property 8: computeDiff only includes changed top-level fields\r\ndescribe('Property 8: computeDiff only includes changed top-level fields', () => {\r\n  it('ayn─▒ DB i├ºin diff bo┼ƒ d├╢ner', () => {\r\n    fc.assert(\r\n      fc.property(arbDB(), (db) => {\r\n        const { prevValue, nextValue } = computeDiff(db, db);\r\n        return Object.keys(prevValue).length === 0 && Object.keys(nextValue).length === 0;\r\n      }),\r\n      { numRuns: 100 }\r\n    );\r\n  });\r\n});\r\n\r\n// Property 9: _auditLog 500 kay─▒t s─▒n─▒r─▒n─▒ a┼ƒmaz\r\n// Feature: rule-engine-audit, Property 9: _auditLog never exceeds 500 entries\r\ndescribe('Property 9: _auditLog never exceeds 500 entries', () => {\r\n  it('trimAuditLog ├º─▒kt─▒s─▒ her zaman <= 500', () => {\r\n    fc.assert(\r\n      fc.property(fc.array(arbAuditEntry(), { minLength: 0, maxLength: 1000 }), (entries) => {\r\n        const trimmed = trimAuditLog(entries as AuditEntry[]);\r\n        return trimmed.length <= 500;\r\n      }),\r\n      { numRuns: 100 }\r\n    );\r\n  });\r\n});\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\auditEngine.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'KasaEntry' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":73,"messageId":"unusedVar","endLine":10,"endColumn":82,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"KasaEntry"},"fix":{"range":[382,393],"text":""},"desc":"Remove unused variable \"KasaEntry\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * PARSPEL ΓÇö Audit Engine\r\n * Her finansal i┼ƒlemin kim taraf─▒ndan, ne zaman, hangi de─ƒerden hangi de─ƒere\r\n * yap─▒ld─▒─ƒ─▒n─▒ ve sonucunu (applied/blocked/warned) kaydeder.\r\n *\r\n * BFCE auditEngine + stateEngine pattern'inden uyarlanm─▒┼ƒt─▒r.\r\n * Cloud Functions gerektirmez ΓÇö tamamen client-side ├ºal─▒┼ƒ─▒r.\r\n */\r\n\r\nimport type { DB, AuditEntry, AuditReport, AuditAnomaly, RuleViolation, KasaEntry } from '@/types';\r\nimport { genId } from '@/lib/utils-tr';\r\nimport { logger } from '@/lib/logger';\r\nimport { TRANSACTION_LIMIT } from '@/lib/ruleEngine';\r\n\r\n/** _auditLog maksimum kay─▒t say─▒s─▒ */\r\nconst MAX_AUDIT_LOG = 500;\r\n\r\n/** Bakiye tutars─▒zl─▒─ƒ─▒ i├ºin tolerans */\r\nconst BALANCE_DRIFT_TOLERANCE = 0.01;\r\n\r\n// ΓöÇΓöÇΓöÇ Session ID ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nconst SESSION_KEY = 'parspel_audit_session_id';\r\n\r\n/**\r\n * Oturum ba┼ƒ─▒na bir kez ├╝retilen UUID.\r\n * sessionStorage'da saklan─▒r ΓÇö sekme kapan─▒nca s─▒f─▒rlan─▒r.\r\n */\r\nexport function getSessionId(): string {\r\n  try {\r\n    let id = sessionStorage.getItem(SESSION_KEY);\r\n    if (!id) {\r\n      id = crypto.randomUUID ? crypto.randomUUID() : genId();\r\n      sessionStorage.setItem(SESSION_KEY, id);\r\n    }\r\n    return id;\r\n  } catch {\r\n    // sessionStorage eri┼ƒim hatas─▒ (private mode vb.)\r\n    return genId();\r\n  }\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Diff Hesaplama ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * prevDB ile nextDB aras─▒ndaki fark─▒ hesaplar.\r\n * Yaln─▒zca de─ƒi┼ƒen ├╝st d├╝zey alanlar─▒ d├╢nd├╝r├╝r ΓÇö t├╝m DB nesnesini de─ƒil.\r\n * Bu sayede audit log boyutu kontrol alt─▒nda tutulur.\r\n */\r\nexport function computeDiff(\r\n  prevDB: DB,\r\n  nextDB: DB\r\n): { prevValue: Partial<DB>; nextValue: Partial<DB> } {\r\n  try {\r\n    const prevValue: Partial<DB> = {};\r\n    const nextValue: Partial<DB> = {};\r\n\r\n    const keys = Object.keys(nextDB) as (keyof DB)[];\r\n    for (const key of keys) {\r\n      // _auditLog'u diff'e dahil etme ΓÇö sonsuz d├╢ng├╝ ├╢nlemi\r\n      if (key === '_auditLog') continue;\r\n\r\n      const prev = prevDB[key];\r\n      const next = nextDB[key];\r\n\r\n      // Basit referans kar┼ƒ─▒la┼ƒt─▒rmas─▒ ΓÇö dizi/nesne de─ƒi┼ƒimini yakalar\r\n      if (prev !== next) {\r\n        // Dizi ise sadece uzunluk de─ƒi┼ƒimini kaydet (boyut optimizasyonu)\r\n        if (Array.isArray(prev) && Array.isArray(next)) {\r\n          if (prev.length !== next.length) {\r\n            (prevValue as Record<string, unknown>)[key] = `[${prev.length} kay─▒t]`;\r\n            (nextValue as Record<string, unknown>)[key] = `[${next.length} kay─▒t]`;\r\n          }\r\n        } else {\r\n          (prevValue as Record<string, unknown>)[key] = prev;\r\n          (nextValue as Record<string, unknown>)[key] = next;\r\n        }\r\n      }\r\n    }\r\n\r\n    return { prevValue, nextValue };\r\n  } catch (e) {\r\n    logger.warn('auditEngine', 'computeDiff hatas─▒ ΓÇö diff bo┼ƒ d├╢nd├╝r├╝l├╝yor', { error: String(e) });\r\n    return { prevValue: {}, nextValue: {} };\r\n  }\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ AuditEntry Olu┼ƒturma ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * Bir i┼ƒlem i├ºin AuditEntry olu┼ƒturur.\r\n * _auditLog'a ekleme yapmaz ΓÇö sadece entry nesnesi d├╢nd├╝r├╝r.\r\n * Ekleme useDB.ts i├ºinde atomik olarak yap─▒l─▒r.\r\n */\r\nexport function createAuditEntry(params: {\r\n  action: string;\r\n  entity: string;\r\n  entityId?: string;\r\n  prevDB: DB;\r\n  nextDB: DB;\r\n  status: 'applied' | 'blocked' | 'warned';\r\n  violations?: RuleViolation[];\r\n  detail?: string;\r\n  userId?: string;\r\n}): AuditEntry {\r\n  const { prevValue, nextValue } = computeDiff(params.prevDB, params.nextDB);\r\n\r\n  return {\r\n    id: genId(),\r\n    action: params.action,\r\n    entity: params.entity,\r\n    entityId: params.entityId,\r\n    prevValue: Object.keys(prevValue).length > 0 ? prevValue : undefined,\r\n    nextValue: Object.keys(nextValue).length > 0 ? nextValue : undefined,\r\n    userId: params.userId,\r\n    sessionId: getSessionId(),\r\n    status: params.status,\r\n    violations: params.violations && params.violations.length > 0 ? params.violations : undefined,\r\n    detail: params.detail,\r\n    time: new Date().toISOString(),\r\n  };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Log Boyut Kontrol├╝ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * _auditLog'u MAX_AUDIT_LOG (500) kay─▒tla s─▒n─▒rland─▒r─▒r.\r\n * Yaln─▒zca length kontrol├╝ yapar ΓÇö JSON.stringify kullanmaz.\r\n * En yeni kay─▒tlar korunur (ba┼ƒtan al─▒n─▒r).\r\n */\r\nexport function trimAuditLog(log: AuditEntry[]): AuditEntry[] {\r\n  if (log.length <= MAX_AUDIT_LOG) return log;\r\n  return log.slice(0, MAX_AUDIT_LOG);\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Full Audit ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * T├╝m KasaEntry kay─▒tlar─▒ndan kasa bakiyelerini s─▒f─▒rdan yeniden hesaplar\r\n * (BFCE recomputeStateFromHistory pattern) ve Cari.balance ile kar┼ƒ─▒la┼ƒt─▒r─▒r.\r\n * Onays─▒z i┼ƒlemleri ve TRANSACTION_LIMIT a┼ƒ─▒mlar─▒n─▒ tespit eder.\r\n *\r\n * @param db - Mevcut DB durumu\r\n * @returns AuditReport ΓÇö bakiye tutars─▒zl─▒klar─▒, anomaliler, risk flag'leri\r\n */\r\nexport function runFullAudit(db: DB): AuditReport {\r\n  const anomalies: AuditAnomaly[] = [];\r\n  const balanceDrifts: string[] = [];\r\n  const riskFlags: string[] = [];\r\n\r\n  // ΓöÇΓöÇ 1. Kasa bakiyelerini s─▒f─▒rdan yeniden hesapla ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n  const recomputedBalances = new Map<string, number>();\r\n  for (const entry of db.kasa) {\r\n    if (entry.deleted) continue;\r\n    const cur = recomputedBalances.get(entry.kasa) ?? 0;\r\n    recomputedBalances.set(entry.kasa, cur + (entry.type === 'gelir' ? entry.amount : -entry.amount));\r\n  }\r\n\r\n  // ΓöÇΓöÇ 2. Cari bakiyeleriyle kar┼ƒ─▒la┼ƒt─▒r ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n  // M├╝┼ƒteri cari bakiyelerini kasa tahsilat kay─▒tlar─▒ndan hesapla\r\n  const cariKasaBalances = new Map<string, number>();\r\n  for (const entry of db.kasa) {\r\n    if (entry.deleted || !entry.cariId) continue;\r\n    const cur = cariKasaBalances.get(entry.cariId) ?? 0;\r\n    // Gelir = tahsilat (bakiye azal─▒r), gider = ├╢deme (bakiye artar)\r\n    cariKasaBalances.set(entry.cariId, cur + (entry.type === 'gelir' ? -entry.amount : entry.amount));\r\n  }\r\n\r\n  // Sat─▒┼ƒlardan cari bakiye katk─▒s─▒n─▒ hesapla\r\n  const cariSaleBalances = new Map<string, number>();\r\n  for (const sale of db.sales) {\r\n    if (sale.deleted || sale.status !== 'tamamlandi') continue;\r\n    const cariId = sale.cariId || sale.customerId;\r\n    if (!cariId) continue;\r\n    const cur = cariSaleBalances.get(cariId) ?? 0;\r\n    cariSaleBalances.set(cariId, cur + sale.total);\r\n  }\r\n\r\n  // Cari bakiye tutars─▒zl─▒─ƒ─▒ kontrol├╝\r\n  for (const cari of db.cari) {\r\n    if (cari.deleted) continue;\r\n    const kasaContrib = cariKasaBalances.get(cari.id) ?? 0;\r\n    const saleContrib = cariSaleBalances.get(cari.id) ?? 0;\r\n    const recomputed = saleContrib + kasaContrib;\r\n    const drift = Math.abs(recomputed - cari.balance);\r\n\r\n    if (drift > BALANCE_DRIFT_TOLERANCE) {\r\n      balanceDrifts.push(\r\n        `${cari.name} (${cari.id}): hesaplanan ${recomputed.toFixed(2)} Γé║, kay─▒tl─▒ ${cari.balance.toFixed(2)} Γé║, fark ${drift.toFixed(2)} Γé║`\r\n      );\r\n    }\r\n  }\r\n\r\n  // ΓöÇΓöÇ 3. Onays─▒z i┼ƒlem tespiti ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n  // _auditLog'da 'applied' kayd─▒ olmayan KasaEntry'leri tespit et\r\n  const auditedEntryIds = new Set(\r\n    (db._auditLog || [])\r\n      .filter(a => a.status === 'applied')\r\n      .map(a => a.entityId)\r\n      .filter(Boolean)\r\n  );\r\n\r\n  // Sadece son 24 saatteki kay─▒tlar─▒ kontrol et (performans)\r\n  const oneDayAgo = Date.now() - 24 * 60 * 60 * 1000;\r\n  const recentKasaEntries = db.kasa.filter(k =>\r\n    !k.deleted &&\r\n    new Date(k.createdAt).getTime() > oneDayAgo\r\n  );\r\n\r\n  // _auditLog hen├╝z bo┼ƒsa (yeni kurulum) bu kontrol├╝ atla\r\n  if ((db._auditLog || []).length > 0) {\r\n    for (const entry of recentKasaEntries) {\r\n      if (!auditedEntryIds.has(entry.id)) {\r\n        riskFlags.push(\r\n          `Denetim kayd─▒ olmayan kasa i┼ƒlemi: ${entry.id} (${entry.type}, ${entry.amount} Γé║, ${entry.kasa})`\r\n        );\r\n      }\r\n    }\r\n  }\r\n\r\n  // ΓöÇΓöÇ 4. TRANSACTION_LIMIT a┼ƒ─▒m─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n  for (const entry of db.kasa) {\r\n    if (entry.deleted) continue;\r\n    if (entry.amount > TRANSACTION_LIMIT) {\r\n      anomalies.push({\r\n        entryId: entry.id,\r\n        issue: `Y├╝ksek tutarl─▒ i┼ƒlem: ${entry.amount.toFixed(2)} Γé║ (limit: ${TRANSACTION_LIMIT.toLocaleString('tr-TR')} Γé║)`,\r\n        severity: 'HIGH',\r\n      });\r\n      riskFlags.push(\r\n        `TRANSACTION_LIMIT a┼ƒ─▒m─▒: kasa kayd─▒ ${entry.id}, tutar ${entry.amount} Γé║`\r\n      );\r\n    }\r\n  }\r\n\r\n  // ΓöÇΓöÇ 5. _auditLog istatistikleri ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n  const auditLog = db._auditLog || [];\r\n  const appliedCount = auditLog.filter(a => a.status === 'applied').length;\r\n  const blockedCount = auditLog.filter(a => a.status === 'blocked').length;\r\n  const warnedCount = auditLog.filter(a => a.status === 'warned').length;\r\n\r\n  return {\r\n    anomalies,\r\n    balanceDrifts,\r\n    riskFlags,\r\n    totalEntries: auditLog.length,\r\n    appliedCount,\r\n    blockedCount,\r\n    warnedCount,\r\n  };\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\changelog.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\connConfig.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\dataIntegrity.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\dataIntegrityChecker.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\dataIntegrityChecker.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\excel-merge.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\excelExport.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\gercekci-senaryolar.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\healthCheck.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\kapsamli-senaryo.test.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'createdAt' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":1446,"column":13,"messageId":"unusedVar","endLine":1446,"endColumn":22},{"ruleId":"prefer-const","severity":1,"message":"'db' is never reassigned. Use 'const' instead.","line":2613,"column":17,"messageId":"useConst","endLine":2613,"endColumn":19,"fix":{"range":[89153,89191],"text":"const db = makeDB({ products: [urun] });"}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":1,"source":"/**\r\n * ≡ƒÅ¬ Kapsaml─▒ Senaryo Testleri\r\n *\r\n * Pattern: prevDB ΓåÆ i┼ƒlem ΓåÆ nextDB\r\n * T├╝m testler saf fonksiyon olarak ├ºal─▒┼ƒ─▒r, UI ba─ƒ─▒ml─▒l─▒─ƒ─▒ yoktur.\r\n * Rule engine: validateTransaction(prevDB, nextDB) her i┼ƒlem sonras─▒ ├ºa─ƒr─▒l─▒r.\r\n */\r\n\r\nimport { describe, it, expect } from 'vitest';\r\nimport * as fc from 'fast-check';\r\nimport { validateTransaction } from './ruleEngine';\r\nimport { similarity } from './similarity';\r\nimport type {\r\n  DB, Product, Sale, SaleItem, KasaEntry, Cari, StockMovement,\r\n  RuleViolation,\r\n} from '@/types';\r\n\r\n// ΓöÇΓöÇΓöÇ Yard─▒mc─▒: ID ve Zaman ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction genId(): string {\r\n  // Math.random tabanl─▒ ΓÇö window.crypto kullanmaz (Node/jsdom uyumlu)\r\n  const s4 = () => Math.floor((1 + Math.random()) * 0x10000).toString(16).substring(1);\r\n  return `${s4()}${s4()}-${s4()}-4${s4().substring(1)}-${((8 + Math.random() * 4) | 0).toString(16)}${s4().substring(1)}-${s4()}${s4()}${s4()}`;\r\n}\r\n\r\nfunction now(): string {\r\n  return new Date().toISOString();\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ DB Fabrika ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction makeDB(overrides: Partial<DB> = {}): DB {\r\n  return {\r\n    _version: 1,\r\n    products: [],\r\n    sales: [],\r\n    suppliers: [],\r\n    orders: [],\r\n    cari: [],\r\n    kasa: [],\r\n    kasalar: [\r\n      { id: 'nakit', name: 'Nakit', icon: '≡ƒÆ╡' },\r\n      { id: 'banka', name: 'Banka', icon: '≡ƒÅª' },\r\n    ],\r\n    bankTransactions: [],\r\n    matchRules: [],\r\n    monitorRules: [],\r\n    monitorLog: [],\r\n    stockMovements: [],\r\n    peletSuppliers: [],\r\n    peletOrders: [],\r\n    boruSuppliers: [],\r\n    boruOrders: [],\r\n    invoices: [],\r\n    budgets: [],\r\n    returns: [],\r\n    _activityLog: [],\r\n    _auditLog: [],\r\n    company: { id: 'c1', createdAt: now() },\r\n    settings: {},\r\n    pelletSettings: { gramaj: 14, kgFiyat: 6.5, cuvalKg: 15, critDays: 3 },\r\n    ortakEmanetler: [],\r\n    installments: [],\r\n    partners: [],\r\n    productCategories: [],\r\n    notes: [],\r\n    ...overrides,\r\n  };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ ├£r├╝n Fabrika ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction makeProduct(id: string, name: string, stock: number, price: number, cost: number): Product {\r\n  return {\r\n    id,\r\n    name,\r\n    category: 'soba',\r\n    cost,\r\n    price,\r\n    stock,\r\n    minStock: 0,\r\n    deleted: false,\r\n    createdAt: now(),\r\n    updatedAt: now(),\r\n  };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Sat─▒┼ƒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * Sat─▒┼ƒ i┼ƒlemini sim├╝le eder ΓÇö Sales.tsx saveSale mant─▒─ƒ─▒n─▒ yans─▒t─▒r.\r\n * prevDB ΓåÆ { nextDB, violations, saleId }\r\n */\r\nfunction satisYap(\r\n  prevDB: DB,\r\n  items: Array<{ productId: string; qty: number; unitPrice?: number }>,\r\n  odeme: 'nakit' | 'banka' | 'cari',\r\n  cariId?: string,\r\n  tahsilat?: number,\r\n  iskonto?: { type: 'percent' | 'amount'; value: number }\r\n): { nextDB: DB; violations: RuleViolation[]; saleId: string } {\r\n  const nowIso = now();\r\n  const saleId = genId();\r\n\r\n  // ├£r├╝n bilgilerini ├º├╢z\r\n  const resolvedItems: SaleItem[] = items.map(i => {\r\n    const p = prevDB.products.find(x => x.id === i.productId)!;\r\n    const unitPrice = i.unitPrice !== undefined ? i.unitPrice : p.price;\r\n    const qty = i.qty;\r\n    return {\r\n      productId: p.id,\r\n      productName: p.name,\r\n      quantity: qty,\r\n      unitPrice,\r\n      cost: p.cost,\r\n      total: qty * unitPrice,\r\n    };\r\n  });\r\n\r\n  // Hesaplamalar\r\n  const subtotal = resolvedItems.reduce((s, i) => s + i.total, 0);\r\n  let discountAmount = 0;\r\n  let discountNum = 0;\r\n  if (iskonto) {\r\n    discountNum = iskonto.value;\r\n    discountAmount = iskonto.type === 'percent'\r\n      ? subtotal * (iskonto.value / 100)\r\n      : iskonto.value;\r\n  }\r\n  const total = Math.max(0, subtotal - discountAmount);\r\n  const profit = resolvedItems.reduce((s, i) => s + i.quantity * (i.unitPrice - i.cost), 0) - discountAmount;\r\n\r\n  // Fiili tahsilat\r\n  const fiiliTahsilat = tahsilat !== undefined\r\n    ? tahsilat\r\n    : (odeme === 'cari' ? 0 : total);\r\n\r\n  const sale: Sale = {\r\n    id: saleId,\r\n    cariId: cariId,\r\n    customerId: cariId,\r\n    cariName: cariId ? prevDB.cari.find(c => c.id === cariId)?.name : undefined,\r\n    productId: resolvedItems[0]?.productId,\r\n    productName: resolvedItems.length === 1\r\n      ? resolvedItems[0].productName\r\n      : `${resolvedItems[0].productName} +${resolvedItems.length - 1}`,\r\n    productCategory: prevDB.products.find(p => p.id === resolvedItems[0]?.productId)?.category,\r\n    quantity: resolvedItems.reduce((s, i) => s + i.quantity, 0),\r\n    unitPrice: total / Math.max(1, resolvedItems.reduce((s, i) => s + i.quantity, 0)),\r\n    cost: resolvedItems.reduce((s, i) => s + i.cost * i.quantity, 0),\r\n    discount: discountNum,\r\n    discountAmount,\r\n    subtotal,\r\n    total,\r\n    profit,\r\n    payment: odeme,\r\n    status: 'tamamlandi',\r\n    items: resolvedItems,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  // Kasa giri┼ƒi\r\n  const kasaEntries: KasaEntry[] = [];\r\n  if (fiiliTahsilat > 0) {\r\n    const kasaId = odeme === 'cari' ? 'nakit' : odeme;\r\n    kasaEntries.push({\r\n      id: genId(),\r\n      type: 'gelir',\r\n      category: 'satis',\r\n      amount: fiiliTahsilat,\r\n      kasa: kasaId,\r\n      description: `Sat─▒┼ƒ: ${sale.productName}`,\r\n      relatedId: saleId,\r\n      cariId: cariId,\r\n      createdAt: nowIso,\r\n      updatedAt: nowIso,\r\n    });\r\n  }\r\n\r\n  // Cari bakiyesi\r\n  let cari = prevDB.cari;\r\n  const kalanTutar = total - fiiliTahsilat;\r\n  if (cariId && kalanTutar > 0) {\r\n    cari = cari.map(c =>\r\n      c.id === cariId\r\n        ? { ...c, balance: (c.balance || 0) + kalanTutar, lastTransaction: nowIso, updatedAt: nowIso }\r\n        : c\r\n    );\r\n  }\r\n\r\n  // Stok hareketleri\r\n  const stockMovements: StockMovement[] = resolvedItems.map(i => {\r\n    const currentStock = prevDB.products.find(p => p.id === i.productId)?.stock || 0;\r\n    return {\r\n      id: genId(),\r\n      productId: i.productId,\r\n      productName: i.productName,\r\n      type: 'satis' as const,\r\n      amount: -i.quantity,\r\n      before: currentStock,\r\n      after: currentStock - i.quantity,\r\n      note: 'Sat─▒┼ƒ',\r\n      date: nowIso,\r\n    };\r\n  });\r\n\r\n  // ├£r├╝n sto─ƒu g├╝ncelle\r\n  const products = prevDB.products.map(p => {\r\n    const item = resolvedItems.find(i => i.productId === p.id);\r\n    if (!item) return p;\r\n    return { ...p, stock: p.stock - item.quantity, updatedAt: nowIso };\r\n  });\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    products,\r\n    sales: [...prevDB.sales, sale],\r\n    kasa: [...prevDB.kasa, ...kasaEntries],\r\n    cari,\r\n    stockMovements: [...prevDB.stockMovements, ...stockMovements],\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations, saleId };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ ─░ade ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * ─░ade i┼ƒlemini sim├╝le eder ΓÇö Sales.tsx handleReturn mant─▒─ƒ─▒n─▒ yans─▒t─▒r.\r\n * prevDB ΓåÆ { nextDB, violations }\r\n */\r\nfunction iadeYap(\r\n  prevDB: DB,\r\n  saleId: string\r\n): { nextDB: DB; violations: RuleViolation[] } {\r\n  const nowIso = now();\r\n  const sale = prevDB.sales.find(s => s.id === saleId);\r\n  if (!sale) return { nextDB: prevDB, violations: [] };\r\n  if (sale.status !== 'tamamlandi') return { nextDB: prevDB, violations: [] };\r\n\r\n  // Stoklar─▒ geri y├╝kle\r\n  const products = prevDB.products.map(p => {\r\n    const item = sale.items?.find(i => i.productId === p.id);\r\n    if (!item) return p;\r\n    return { ...p, stock: p.stock + item.quantity, updatedAt: nowIso };\r\n  });\r\n\r\n  // Sat─▒┼ƒ durumunu g├╝ncelle\r\n  const sales = prevDB.sales.map(s =>\r\n    s.id === saleId ? { ...s, status: 'iade' as const, returnedAt: nowIso, updatedAt: nowIso } : s\r\n  );\r\n\r\n  // ─░li┼ƒkili kasa kay─▒tlar─▒n─▒ bul (tahsil edilmi┼ƒ tutar)\r\n  const relatedKasaEntries = prevDB.kasa.filter(\r\n    k => !k.deleted && k.relatedId === sale.id && k.type === 'gelir'\r\n  );\r\n  const tahsilEdilen = relatedKasaEntries.reduce((s, k) => s + k.amount, 0);\r\n\r\n  let kasa = prevDB.kasa;\r\n  if (tahsilEdilen > 0) {\r\n    const kasaId = sale.payment === 'cari' ? 'nakit' : sale.payment;\r\n    kasa = [...kasa, {\r\n      id: genId(),\r\n      type: 'gider' as const,\r\n      category: 'iade',\r\n      amount: tahsilEdilen,\r\n      kasa: kasaId,\r\n      description: `─░ade: ${sale.productName}`,\r\n      relatedId: sale.id,\r\n      createdAt: nowIso,\r\n      updatedAt: nowIso,\r\n    }];\r\n  }\r\n\r\n  // Cari bakiyesini geri al\r\n  let cari = prevDB.cari;\r\n  const cariId = sale.cariId || sale.customerId;\r\n  if (cariId) {\r\n    const cariyeYazilan = sale.total - tahsilEdilen;\r\n    if (cariyeYazilan > 0) {\r\n      cari = cari.map(c =>\r\n        c.id === cariId\r\n          ? { ...c, balance: (c.balance || 0) - cariyeYazilan, lastTransaction: nowIso, updatedAt: nowIso }\r\n          : c\r\n      );\r\n    }\r\n  }\r\n\r\n  const nextDB: DB = { ...prevDB, products, sales, kasa, cari };\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ ─░ptal ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * ─░ptal i┼ƒlemini sim├╝le eder ΓÇö Sales.tsx handleCancel mant─▒─ƒ─▒n─▒ yans─▒t─▒r.\r\n * prevDB ΓåÆ { nextDB, violations }\r\n */\r\nfunction iptalYap(\r\n  prevDB: DB,\r\n  saleId: string\r\n): { nextDB: DB; violations: RuleViolation[] } {\r\n  const nowIso = now();\r\n  const sale = prevDB.sales.find(s => s.id === saleId);\r\n  if (!sale) return { nextDB: prevDB, violations: [] };\r\n\r\n  const products = prevDB.products.map(p => {\r\n    const item = sale.items?.find(i => i.productId === p.id);\r\n    if (!item) return p;\r\n    return { ...p, stock: p.stock + item.quantity, updatedAt: nowIso };\r\n  });\r\n\r\n  const sales = prevDB.sales.map(s =>\r\n    s.id === saleId ? { ...s, status: 'iptal' as const, updatedAt: nowIso } : s\r\n  );\r\n\r\n  const relatedKasaEntries = prevDB.kasa.filter(\r\n    k => !k.deleted && k.relatedId === sale.id && k.type === 'gelir'\r\n  );\r\n  const tahsilEdilen = relatedKasaEntries.reduce((s, k) => s + k.amount, 0);\r\n\r\n  let kasa = prevDB.kasa;\r\n  if (tahsilEdilen > 0) {\r\n    const kasaId = sale.payment === 'cari' ? 'nakit' : sale.payment;\r\n    kasa = [...kasa, {\r\n      id: genId(),\r\n      type: 'gider' as const,\r\n      category: 'iptal',\r\n      amount: tahsilEdilen,\r\n      kasa: kasaId,\r\n      description: `─░ptal: ${sale.productName}`,\r\n      relatedId: sale.id,\r\n      createdAt: nowIso,\r\n      updatedAt: nowIso,\r\n    }];\r\n  }\r\n\r\n  let cari = prevDB.cari;\r\n  const cariId = sale.cariId || sale.customerId;\r\n  if (cariId) {\r\n    const cariyeYazilan = sale.total - tahsilEdilen;\r\n    if (cariyeYazilan > 0) {\r\n      cari = cari.map(c =>\r\n        c.id === cariId\r\n          ? { ...c, balance: (c.balance || 0) - cariyeYazilan, lastTransaction: nowIso, updatedAt: nowIso }\r\n          : c\r\n      );\r\n    }\r\n  }\r\n\r\n  const nextDB: DB = { ...prevDB, products, sales, kasa, cari };\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Cari ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction cariEkle(\r\n  prevDB: DB,\r\n  form: { name: string; type?: 'musteri' | 'tedarikci'; phone?: string }\r\n): { nextDB: DB; error?: string } {\r\n  const nowIso = now();\r\n\r\n  // Tam e┼ƒle┼ƒme kontrol├╝\r\n  const existing = prevDB.cari.find(\r\n    c => !c.deleted && c.name.trim().toLowerCase() === form.name.trim().toLowerCase()\r\n  );\r\n  if (existing) {\r\n    return { nextDB: prevDB, error: `\"${form.name}\" ad─▒nda bir cari zaten mevcut.` };\r\n  }\r\n\r\n  // Benzerlik uyar─▒s─▒ (ΓëÑ70) ΓÇö hata de─ƒil, uyar─▒ olarak d├╢ner\r\n  const similar = prevDB.cari.find(\r\n    c => !c.deleted && similarity(c.name, form.name) >= 70\r\n  );\r\n\r\n  const newCari: Cari = {\r\n    id: genId(),\r\n    name: form.name,\r\n    type: form.type || 'musteri',\r\n    phone: form.phone,\r\n    balance: 0,\r\n    deleted: false,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = { ...prevDB, cari: [...prevDB.cari, newCari] };\r\n\r\n  if (similar) {\r\n    return { nextDB, error: `Uyar─▒: \"${similar.name}\" ad─▒nda benzer bir cari mevcut.` };\r\n  }\r\n\r\n  return { nextDB };\r\n}\r\n\r\nfunction cariDuzenle(\r\n  prevDB: DB,\r\n  id: string,\r\n  form: Partial<Cari>\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    cari: prevDB.cari.map(c =>\r\n      c.id === id\r\n        ? { ...c, ...form, id: c.id, balance: c.balance, createdAt: c.createdAt, updatedAt: nowIso }\r\n        : c\r\n    ),\r\n  };\r\n  return { nextDB };\r\n}\r\n\r\nfunction cariSil(\r\n  prevDB: DB,\r\n  id: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    cari: prevDB.cari.map(c =>\r\n      c.id === id ? { ...c, deleted: true, updatedAt: nowIso } : c\r\n    ),\r\n  };\r\n  return { nextDB };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Tahsilat ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction tahsilatYap(\r\n  prevDB: DB,\r\n  cariId: string,\r\n  amount: number,\r\n  kasa: string\r\n): { nextDB: DB; violations: RuleViolation[] } {\r\n  const nowIso = now();\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: genId(),\r\n    type: 'gelir',\r\n    category: 'tahsilat',\r\n    amount,\r\n    kasa,\r\n    description: `Tahsilat: ${prevDB.cari.find(c => c.id === cariId)?.name || cariId}`,\r\n    cariId,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const cari = prevDB.cari.map(c =>\r\n    c.id === cariId\r\n      ? { ...c, balance: (c.balance || 0) - amount, lastTransaction: nowIso, updatedAt: nowIso }\r\n      : c\r\n  );\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n    cari,\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Kasa ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction kasaGelirEkle(\r\n  prevDB: DB,\r\n  amount: number,\r\n  kasa: string,\r\n  cariId?: string\r\n): { nextDB: DB; violations: RuleViolation[]; entryId: string } {\r\n  const nowIso = now();\r\n  const entryId = genId();\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: entryId,\r\n    type: 'gelir',\r\n    category: 'manuel',\r\n    amount,\r\n    kasa,\r\n    cariId,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  let cari = prevDB.cari;\r\n  if (cariId) {\r\n    cari = cari.map(c =>\r\n      c.id === cariId\r\n        ? { ...c, balance: (c.balance || 0) - amount, lastTransaction: nowIso, updatedAt: nowIso }\r\n        : c\r\n    );\r\n  }\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n    cari,\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations, entryId };\r\n}\r\n\r\nfunction kasaGiderEkle(\r\n  prevDB: DB,\r\n  amount: number,\r\n  kasa: string,\r\n  cariId?: string\r\n): { nextDB: DB; violations: RuleViolation[]; entryId: string } {\r\n  const nowIso = now();\r\n  const entryId = genId();\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: entryId,\r\n    type: 'gider',\r\n    category: 'manuel',\r\n    amount,\r\n    kasa,\r\n    cariId,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  let cari = prevDB.cari;\r\n  if (cariId) {\r\n    cari = cari.map(c =>\r\n      c.id === cariId\r\n        ? { ...c, balance: (c.balance || 0) + amount, lastTransaction: nowIso, updatedAt: nowIso }\r\n        : c\r\n    );\r\n  }\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n    cari,\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations, entryId };\r\n}\r\n\r\nfunction kasaKayitSil(\r\n  prevDB: DB,\r\n  entryId: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const entry = prevDB.kasa.find(k => k.id === entryId);\r\n\r\n  let cari = prevDB.cari;\r\n  if (entry && entry.cariId) {\r\n    // Gelir kayd─▒ siliniyorsa cari bakiyesini geri art─▒r\r\n    // Gider kayd─▒ siliniyorsa cari bakiyesini geri azalt\r\n    const delta = entry.type === 'gelir' ? entry.amount : -entry.amount;\r\n    cari = cari.map(c =>\r\n      c.id === entry.cariId\r\n        ? { ...c, balance: (c.balance || 0) + delta, updatedAt: nowIso }\r\n        : c\r\n    );\r\n  }\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: prevDB.kasa.map(k =>\r\n      k.id === entryId ? { ...k, deleted: true, updatedAt: nowIso } : k\r\n    ),\r\n    cari,\r\n  };\r\n\r\n  return { nextDB };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Stok ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction stokGiris(\r\n  prevDB: DB,\r\n  productId: string,\r\n  amount: number,\r\n  note?: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const product = prevDB.products.find(p => p.id === productId)!;\r\n  const before = product.stock;\r\n  const after = before + amount;\r\n\r\n  const movement: StockMovement = {\r\n    id: genId(),\r\n    productId,\r\n    productName: product.name,\r\n    type: 'giris',\r\n    amount,\r\n    before,\r\n    after,\r\n    note: note || 'Stok giri┼ƒi',\r\n    date: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    products: prevDB.products.map(p =>\r\n      p.id === productId ? { ...p, stock: after, updatedAt: nowIso } : p\r\n    ),\r\n    stockMovements: [...prevDB.stockMovements, movement],\r\n  };\r\n\r\n  return { nextDB };\r\n}\r\n\r\nfunction stokCikis(\r\n  prevDB: DB,\r\n  productId: string,\r\n  amount: number,\r\n  note?: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const product = prevDB.products.find(p => p.id === productId)!;\r\n  const before = product.stock;\r\n  const after = Math.max(0, before - amount);\r\n\r\n  const movement: StockMovement = {\r\n    id: genId(),\r\n    productId,\r\n    productName: product.name,\r\n    type: 'cikis',\r\n    amount: -(before - after),\r\n    before,\r\n    after,\r\n    note: note || 'Stok ├º─▒k─▒┼ƒ─▒',\r\n    date: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    products: prevDB.products.map(p =>\r\n      p.id === productId ? { ...p, stock: after, updatedAt: nowIso } : p\r\n    ),\r\n    stockMovements: [...prevDB.stockMovements, movement],\r\n  };\r\n\r\n  return { nextDB };\r\n}\r\n\r\nfunction stokDuzeltme(\r\n  prevDB: DB,\r\n  productId: string,\r\n  newStock: number,\r\n  note?: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const product = prevDB.products.find(p => p.id === productId)!;\r\n  const before = product.stock;\r\n  const after = newStock;\r\n  const amount = after - before;\r\n\r\n  const movement: StockMovement = {\r\n    id: genId(),\r\n    productId,\r\n    productName: product.name,\r\n    type: 'duzeltme',\r\n    amount,\r\n    before,\r\n    after,\r\n    note: note || 'Stok d├╝zeltme',\r\n    date: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    products: prevDB.products.map(p =>\r\n      p.id === productId ? { ...p, stock: after, updatedAt: nowIso } : p\r\n    ),\r\n    stockMovements: [...prevDB.stockMovements, movement],\r\n  };\r\n\r\n  return { nextDB };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Sipari┼ƒ Tamamlama ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction siparisIsleTamamlandi(\r\n  prevDB: DB,\r\n  orderId: string\r\n): { nextDB: DB } {\r\n  const nowIso = now();\r\n  const order = prevDB.orders.find(o => o.id === orderId);\r\n  if (!order) return { nextDB: prevDB };\r\n\r\n  // ─░dempotency: zaten tamamland─▒ysa stok tekrar art─▒r─▒lmaz\r\n  if (order.stockCompleted) {\r\n    return {\r\n      nextDB: {\r\n        ...prevDB,\r\n        orders: prevDB.orders.map(o =>\r\n          o.id === orderId ? { ...o, status: 'tamamlandi' as const, updatedAt: nowIso } : o\r\n        ),\r\n      },\r\n    };\r\n  }\r\n\r\n  const products = prevDB.products.map(p => {\r\n    const item = order.items.find(i => i.productId === p.id);\r\n    if (!item) return p;\r\n    return { ...p, stock: p.stock + item.qty, updatedAt: nowIso };\r\n  });\r\n\r\n  const stockMovements: StockMovement[] = [\r\n    ...prevDB.stockMovements,\r\n    ...order.items\r\n      .filter(i => prevDB.products.find(p => p.id === i.productId))\r\n      .map(i => ({\r\n        id: genId(),\r\n        productId: i.productId,\r\n        productName: i.productName,\r\n        type: 'giris' as const,\r\n        amount: i.qty,\r\n        before: prevDB.products.find(p => p.id === i.productId)?.stock || 0,\r\n        after: (prevDB.products.find(p => p.id === i.productId)?.stock || 0) + i.qty,\r\n        note: `Sipari┼ƒ #${orderId.slice(0, 8)}`,\r\n        date: nowIso,\r\n      })),\r\n  ];\r\n\r\n  const orders = prevDB.orders.map(o =>\r\n    o.id === orderId\r\n      ? { ...o, status: 'tamamlandi' as const, stockCompleted: true, updatedAt: nowIso }\r\n      : o\r\n  );\r\n\r\n  const nextDB: DB = { ...prevDB, products, stockMovements, orders };\r\n  return { nextDB };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ TESTLER ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('≡ƒÅ¬ Kapsaml─▒ Senaryo Testleri', () => {\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 2: Cari Sat─▒┼ƒ ΓåÆ K─▒smi Tahsilat ΓåÆ ─░ade\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 2: Cari Sat─▒┼ƒ ΓåÆ K─▒smi Tahsilat ΓåÆ ─░ade', () => {\r\n    /**\r\n     * Validates: Requirements 1.2, 2.2\r\n     *\r\n     * Bug Ko┼ƒulu C(X): tahsilat > 0 AND iade sonras─▒ cari.balance Γëá 0\r\n     *\r\n     * DB Durum Ge├ºi┼ƒi:\r\n     *   sat─▒┼ƒ: kasa=[+500], cari.balance=700\r\n     *   iade:  kasa=[+500, -500], cari.balance=0\r\n     */\r\n    it('k─▒smi tahsilatl─▒ cari sat─▒┼ƒ ΓåÆ iade sonras─▒ cari.balance s─▒f─▒r olmal─▒', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n\r\n      // M├╝┼ƒteri olu┼ƒtur (balance: 0)\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const prevDB = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Sat─▒┼ƒ yap: cari ├╢deme, 500Γé║ tahsilat, kalan 700Γé║ cariye yaz─▒l─▒r\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        500\r\n      );\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      // Sat─▒┼ƒ sonras─▒ kasa geliri = 500\r\n      const kasaGelir = afterSale.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(500);\r\n\r\n      // Sat─▒┼ƒ sonras─▒ cari.balance = 700 (1200 - 500)\r\n      const cariAfterSale = afterSale.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterSale.balance).toBe(700);\r\n\r\n      // Tutarl─▒l─▒k: kasa geliri + cari.balance = sale.total\r\n      const sale = afterSale.sales.find(s => s.id === saleId)!;\r\n      expect(kasaGelir + cariAfterSale.balance).toBe(sale.total);\r\n      expect(sale.total).toBe(1200);\r\n\r\n      // ─░ade yap\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // ─░ade sonras─▒ cari.balance = 0\r\n      const cariAfterIade = afterIade.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterIade.balance).toBe(0);\r\n\r\n      // ─░ade sonras─▒ net kasa = 0 (╬ú gelir - ╬ú gider = 0)\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n\r\n      // Sat─▒┼ƒ durumu 'iade' olmal─▒\r\n      const saleAfterIade = afterIade.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIade.status).toBe('iade');\r\n    });\r\n\r\n    it('isBugCondition: tahsilat > 0 AND iade sonras─▒ cari.balance Γëá 0 ΓåÆ bug yok', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const prevDB = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      const { nextDB: afterSale, saleId } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        500\r\n      );\r\n\r\n      const { nextDB: afterIade } = iadeYap(afterSale, saleId);\r\n\r\n      // Bug ko┼ƒulu: tahsilat > 0 AND iade sonras─▒ cari.balance Γëá 0\r\n      const tahsilat = 500;\r\n      const cariBalance = afterIade.cari.find(c => c.id === 'musteri-001')!.balance;\r\n      const isBugCondition = tahsilat > 0 && cariBalance !== 0;\r\n\r\n      // Bug ko┼ƒulu tetiklenmemeli\r\n      expect(isBugCondition).toBe(false);\r\n      expect(cariBalance).toBe(0);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 3: Sipari┼ƒ Tamamland─▒─ƒ─▒nda Stok Art─▒┼ƒ─▒\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 3: Sipari┼ƒ Tamamland─▒─ƒ─▒nda Stok Art─▒┼ƒ─▒', () => {\r\n    /**\r\n     * Validates: Requirements 1.3, 2.3\r\n     *\r\n     * Bug Ko┼ƒulu C(X): order.status='tamamlandi' AND product.stock de─ƒi┼ƒmedi\r\n     *\r\n     * DB Durum Ge├ºi┼ƒi:\r\n     *   prevDB: product.stock = 5\r\n     *   siparisIsleTamamlandi sonras─▒: product.stock = 5 + 10 = 15\r\n     *   StockMovement: type='giris', amount=10, before=5, after=15\r\n     */\r\n    it('sipari┼ƒ tamamland─▒─ƒ─▒nda ├╝r├╝n sto─ƒu artmal─▒ (tek kalem)', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 5, 1000, 600);\r\n      const orderId = genId();\r\n\r\n      const order = {\r\n        id: orderId,\r\n        supplierId: 'sup-001',\r\n        items: [\r\n          {\r\n            productId: 'urun-001',\r\n            productName: 'Test ├£r├╝n',\r\n            qty: 10,\r\n            unitCost: 600,\r\n            lineTotal: 6000,\r\n          },\r\n        ],\r\n        amount: 6000,\r\n        paidAmount: 0,\r\n        remainingAmount: 6000,\r\n        payments: [],\r\n        status: 'bekliyor' as const,\r\n        stockCompleted: false,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const prevDB = makeDB({ products: [urun], orders: [order] });\r\n\r\n      // Sipari┼ƒ tamamla\r\n      const { nextDB } = siparisIsleTamamlandi(prevDB, orderId);\r\n\r\n      // Stok 5 + 10 = 15 olmal─▒\r\n      const product = nextDB.products.find(p => p.id === 'urun-001')!;\r\n      expect(product.stock).toBe(15);\r\n\r\n      // StockMovement kayd─▒: type='giris', amount=10, before=5, after=15\r\n      const movement = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n      expect(movement).toBeDefined();\r\n      expect(movement.type).toBe('giris');\r\n      expect(movement.amount).toBe(10);\r\n      expect(movement.before).toBe(5);\r\n      expect(movement.after).toBe(15);\r\n\r\n      // Order durumu 'tamamlandi' ve stockCompleted=true olmal─▒\r\n      const completedOrder = nextDB.orders.find(o => o.id === orderId)!;\r\n      expect(completedOrder.status).toBe('tamamlandi');\r\n      expect(completedOrder.stockCompleted).toBe(true);\r\n    });\r\n\r\n    it('├ºoklu kalemli sipari┼ƒ tamamland─▒─ƒ─▒nda her ├╝r├╝n sto─ƒu artmal─▒', () => {\r\n      const urun1 = makeProduct('urun-001', '├£r├╝n 1', 10, 1000, 600);\r\n      const urun2 = makeProduct('urun-002', '├£r├╝n 2', 20, 500, 300);\r\n      const orderId = genId();\r\n\r\n      const order = {\r\n        id: orderId,\r\n        supplierId: 'sup-001',\r\n        items: [\r\n          {\r\n            productId: 'urun-001',\r\n            productName: '├£r├╝n 1',\r\n            qty: 3,\r\n            unitCost: 600,\r\n            lineTotal: 1800,\r\n          },\r\n          {\r\n            productId: 'urun-002',\r\n            productName: '├£r├╝n 2',\r\n            qty: 7,\r\n            unitCost: 300,\r\n            lineTotal: 2100,\r\n          },\r\n        ],\r\n        amount: 3900,\r\n        paidAmount: 0,\r\n        remainingAmount: 3900,\r\n        payments: [],\r\n        status: 'bekliyor' as const,\r\n        stockCompleted: false,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const prevDB = makeDB({ products: [urun1, urun2], orders: [order] });\r\n\r\n      const { nextDB } = siparisIsleTamamlandi(prevDB, orderId);\r\n\r\n      // ├£r├╝n 1: 10 + 3 = 13\r\n      const product1 = nextDB.products.find(p => p.id === 'urun-001')!;\r\n      expect(product1.stock).toBe(13);\r\n\r\n      // ├£r├╝n 2: 20 + 7 = 27\r\n      const product2 = nextDB.products.find(p => p.id === 'urun-002')!;\r\n      expect(product2.stock).toBe(27);\r\n\r\n      // Her ├╝r├╝n i├ºin StockMovement kayd─▒ olu┼ƒmal─▒\r\n      const movement1 = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n      expect(movement1.type).toBe('giris');\r\n      expect(movement1.amount).toBe(3);\r\n      expect(movement1.before).toBe(10);\r\n      expect(movement1.after).toBe(13);\r\n\r\n      const movement2 = nextDB.stockMovements.find(m => m.productId === 'urun-002')!;\r\n      expect(movement2.type).toBe('giris');\r\n      expect(movement2.amount).toBe(7);\r\n      expect(movement2.before).toBe(20);\r\n      expect(movement2.after).toBe(27);\r\n    });\r\n\r\n    it('isBugCondition: order.status=tamamlandi AND product.stock de─ƒi┼ƒmedi ΓåÆ bug yok', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 5, 1000, 600);\r\n      const orderId = genId();\r\n\r\n      const order = {\r\n        id: orderId,\r\n        supplierId: 'sup-001',\r\n        items: [\r\n          {\r\n            productId: 'urun-001',\r\n            productName: 'Test ├£r├╝n',\r\n            qty: 10,\r\n            unitCost: 600,\r\n            lineTotal: 6000,\r\n          },\r\n        ],\r\n        amount: 6000,\r\n        paidAmount: 0,\r\n        remainingAmount: 6000,\r\n        payments: [],\r\n        status: 'bekliyor' as const,\r\n        stockCompleted: false,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const prevDB = makeDB({ products: [urun], orders: [order] });\r\n      const stockBefore = prevDB.products.find(p => p.id === 'urun-001')!.stock;\r\n\r\n      const { nextDB } = siparisIsleTamamlandi(prevDB, orderId);\r\n\r\n      const completedOrder = nextDB.orders.find(o => o.id === orderId)!;\r\n      const stockAfter = nextDB.products.find(p => p.id === 'urun-001')!.stock;\r\n\r\n      // Bug ko┼ƒulu: order.status='tamamlandi' AND product.stock de─ƒi┼ƒmedi\r\n      const isBugCondition = completedOrder.status === 'tamamlandi' && stockAfter === stockBefore;\r\n\r\n      // Bug ko┼ƒulu tetiklenmemeli ΓÇö stok artm─▒┼ƒ olmal─▒\r\n      expect(isBugCondition).toBe(false);\r\n      expect(stockAfter).toBe(stockBefore + 10);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 4: ├çoklu ├£r├╝nl├╝ Sat─▒┼ƒ ΓåÆ ─░ade\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 4: ├çoklu ├£r├╝nl├╝ Sat─▒┼ƒ ΓåÆ ─░ade', () => {\r\n    /**\r\n     * Validates: Requirements 1.4, 2.4\r\n     *\r\n     * Bug Ko┼ƒulu C(X): sale.items.length > 1 AND iade sonras─▒ t├╝m stoklar geri y├╝klenmedi\r\n     *\r\n     * DB Durum Ge├ºi┼ƒi:\r\n     *   sat─▒┼ƒ: soba.stock=10ΓåÆ8, aksesuar.stock=5ΓåÆ4, kasa=[+2700]\r\n     *   iade:  soba.stock=8ΓåÆ10, aksesuar.stock=4ΓåÆ5, kasa=[+2700,-2700]\r\n     *   net kasa = 0\r\n     *\r\n     * Not: iadeYap fonksiyonu stoklar─▒ sale.items ├╝zerinden geri y├╝kler ancak\r\n     * 'iade' tipinde StockMovement kayd─▒ olu┼ƒturmaz. Bu nedenle stok geri\r\n     * y├╝klenmesini do─ƒruluyoruz; StockMovement 'iade' kayd─▒ beklenmez.\r\n     */\r\n    it('├ºoklu ├╝r├╝nl├╝ sat─▒┼ƒ ΓåÆ iade sonras─▒ her iki ├╝r├╝n sto─ƒu ba┼ƒlang─▒├º de─ƒerine d├╢nmeli', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const aksesuar = makeProduct('aksesuar-001', 'Soba Aksesuar', 5, 300, 150);\r\n\r\n      const prevDB = makeDB({ products: [soba, aksesuar] });\r\n\r\n      // Sat─▒┼ƒ yap: soba├ù2 + aksesuar├ù1, nakit\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(\r\n        prevDB,\r\n        [\r\n          { productId: 'soba-001', qty: 2 },\r\n          { productId: 'aksesuar-001', qty: 1 },\r\n        ],\r\n        'nakit'\r\n      );\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      // Sat─▒┼ƒ sonras─▒ stok kontrol├╝\r\n      const sobaAfterSale = afterSale.products.find(p => p.id === 'soba-001')!;\r\n      const aksesuarAfterSale = afterSale.products.find(p => p.id === 'aksesuar-001')!;\r\n      expect(sobaAfterSale.stock).toBe(8);   // 10 - 2\r\n      expect(aksesuarAfterSale.stock).toBe(4); // 5 - 1\r\n\r\n      // Sat─▒┼ƒ sonras─▒ kasa geliri: 2├ù1200 + 1├ù300 = 2700\r\n      const kasaGelir = afterSale.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(2700);\r\n\r\n      // ─░ade yap\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // ─░ade sonras─▒ stok ba┼ƒlang─▒├º de─ƒerlerine d├╢nmeli\r\n      const sobaAfterIade = afterIade.products.find(p => p.id === 'soba-001')!;\r\n      const aksesuarAfterIade = afterIade.products.find(p => p.id === 'aksesuar-001')!;\r\n      expect(sobaAfterIade.stock).toBe(10);  // ba┼ƒlang─▒├º de─ƒeri\r\n      expect(aksesuarAfterIade.stock).toBe(5); // ba┼ƒlang─▒├º de─ƒeri\r\n\r\n      // ─░ade sonras─▒ net kasa = 0\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n\r\n      // Sat─▒┼ƒ durumu 'iade' olmal─▒\r\n      const saleAfterIade = afterIade.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIade.status).toBe('iade');\r\n\r\n      // Not: iadeYap, 'iade' tipinde StockMovement kayd─▒ olu┼ƒturmaz.\r\n      // Stok geri y├╝klenmesi sale.items ├╝zerinden yap─▒l─▒r (yukar─▒da do─ƒruland─▒).\r\n      // E─ƒer ileride iadeYap 'iade' StockMovement kayd─▒ olu┼ƒturacak ┼ƒekilde\r\n      // g├╝ncellenirse, a┼ƒa─ƒ─▒daki kontrol aktif edilebilir:\r\n      // const iadeMovements = afterIade.stockMovements.filter(m => m.type === 'iade');\r\n      // expect(iadeMovements).toHaveLength(2);\r\n    });\r\n\r\n    it('isBugCondition: sale.items.length > 1 AND iade sonras─▒ t├╝m stoklar geri y├╝klenmedi ΓåÆ bug yok', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const aksesuar = makeProduct('aksesuar-001', 'Soba Aksesuar', 5, 300, 150);\r\n\r\n      const prevDB = makeDB({ products: [soba, aksesuar] });\r\n\r\n      const { nextDB: afterSale, saleId } = satisYap(\r\n        prevDB,\r\n        [\r\n          { productId: 'soba-001', qty: 2 },\r\n          { productId: 'aksesuar-001', qty: 1 },\r\n        ],\r\n        'nakit'\r\n      );\r\n\r\n      const { nextDB: afterIade } = iadeYap(afterSale, saleId);\r\n\r\n      const sale = afterSale.sales.find(s => s.id === saleId)!;\r\n      const sobaStock = afterIade.products.find(p => p.id === 'soba-001')!.stock;\r\n      const aksesuarStock = afterIade.products.find(p => p.id === 'aksesuar-001')!.stock;\r\n\r\n      // Bug ko┼ƒulu: sale.items.length > 1 AND iade sonras─▒ t├╝m stoklar geri y├╝klenmedi\r\n      const stocksNotRestored = sobaStock !== 10 || aksesuarStock !== 5;\r\n      const isBugCondition = sale.items!.length > 1 && stocksNotRestored;\r\n\r\n      // Bug ko┼ƒulu tetiklenmemeli ΓÇö her iki stok da geri y├╝klenmi┼ƒ olmal─▒\r\n      expect(isBugCondition).toBe(false);\r\n      expect(sobaStock).toBe(10);\r\n      expect(aksesuarStock).toBe(5);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 5: ─░skontolu Sat─▒┼ƒ ΓåÆ ─░ade\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 5: ─░skontolu Sat─▒┼ƒ ΓåÆ ─░ade', () => {\r\n    /**\r\n     * Validates: Requirements 1.5, 2.5\r\n     *\r\n     * Bug Ko┼ƒulu C(X): discount > 0 AND iade sonras─▒ kasadan br├╝t tutar d├╝┼ƒ├╝ld├╝\r\n     *\r\n     * DB Durum Ge├ºi┼ƒi:\r\n     *   sat─▒┼ƒ: subtotal=1200, discountAmount=120, total=1080, kasa=[+1080]\r\n     *   iade:  kasa=[+1080, -1080], net kasa = 0\r\n     */\r\n    it('y├╝zde iskontolu sat─▒┼ƒ ΓåÆ subtotal/discountAmount/total do─ƒru hesaplanmal─▒', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const prevDB = makeDB({ products: [soba] });\r\n\r\n      // %10 iskontolu sat─▒┼ƒ\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'percent', value: 10 }\r\n      );\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      const sale = afterSale.sales.find(s => s.id === saleId)!;\r\n      expect(sale.subtotal).toBe(1200);\r\n      expect(sale.discountAmount).toBe(120);\r\n      expect(sale.total).toBe(1080);\r\n\r\n      // Kasa geliri = 1080 (br├╝t 1200 de─ƒil)\r\n      const kasaGelir = afterSale.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(1080);\r\n    });\r\n\r\n    it('y├╝zde iskontolu sat─▒┼ƒ ΓåÆ iade sonras─▒ gider kayd─▒ total (1080) olmal─▒, br├╝t de─ƒil', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const prevDB = makeDB({ products: [soba] });\r\n\r\n      const { nextDB: afterSale, saleId } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'percent', value: 10 }\r\n      );\r\n\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // ─░ade gider kayd─▒ amount = 1080 (total), br├╝t 1200 de─ƒil\r\n      const iadeGider = afterIade.kasa.find(\r\n        k => !k.deleted && k.type === 'gider' && k.category === 'iade'\r\n      )!;\r\n      expect(iadeGider).toBeDefined();\r\n      expect(iadeGider.amount).toBe(1080);\r\n\r\n      // Net kasa = 0\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n\r\n      // Sat─▒┼ƒ durumu 'iade' olmal─▒\r\n      const saleAfterIade = afterIade.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIade.status).toBe('iade');\r\n    });\r\n\r\n    it('tutar iskontosu: {type:amount, value:200} ΓåÆ total = 1000, iade = 1000', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const prevDB = makeDB({ products: [soba] });\r\n\r\n      // 200Γé║ tutar iskontosu\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'amount', value: 200 }\r\n      );\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      const sale = afterSale.sales.find(s => s.id === saleId)!;\r\n      expect(sale.subtotal).toBe(1200);\r\n      expect(sale.discountAmount).toBe(200);\r\n      expect(sale.total).toBe(1000);\r\n\r\n      // Kasa geliri = 1000\r\n      const kasaGelir = afterSale.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(1000);\r\n\r\n      // ─░ade yap\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // ─░ade gider kayd─▒ = 1000\r\n      const iadeGider = afterIade.kasa.find(\r\n        k => !k.deleted && k.type === 'gider' && k.category === 'iade'\r\n      )!;\r\n      expect(iadeGider).toBeDefined();\r\n      expect(iadeGider.amount).toBe(1000);\r\n\r\n      // Net kasa = 0\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n    });\r\n\r\n    it('isBugCondition: discount > 0 AND iade sonras─▒ kasadan br├╝t tutar d├╝┼ƒ├╝ld├╝ ΓåÆ bug yok', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const prevDB = makeDB({ products: [soba] });\r\n\r\n      const { nextDB: afterSale, saleId } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'percent', value: 10 }\r\n      );\r\n\r\n      const { nextDB: afterIade } = iadeYap(afterSale, saleId);\r\n\r\n      const sale = afterSale.sales.find(s => s.id === saleId)!;\r\n      const iadeGider = afterIade.kasa.find(\r\n        k => !k.deleted && k.type === 'gider' && k.category === 'iade'\r\n      )!;\r\n\r\n      // Bug ko┼ƒulu: discount > 0 AND iade sonras─▒ kasadan br├╝t tutar d├╝┼ƒ├╝ld├╝\r\n      const brutTutarDusuldu = iadeGider?.amount === sale.subtotal; // 1200 yerine 1080 bekliyoruz\r\n      const isBugCondition = (sale.discountAmount ?? 0) > 0 && brutTutarDusuldu;\r\n\r\n      // Bug ko┼ƒulu tetiklenmemeli ΓÇö iade tutar─▒ total (1080) olmal─▒, br├╝t (1200) de─ƒil\r\n      expect(isBugCondition).toBe(false);\r\n      expect(iadeGider.amount).toBe(sale.total); // 1080\r\n      expect(iadeGider.amount).not.toBe(sale.subtotal); // 1200 de─ƒil\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 6: Stok S─▒f─▒rken ─░ade\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 6: Stok S─▒f─▒rken ─░ade', () => {\r\n    /**\r\n     * Validates: Requirements 1.6, 2.6\r\n     *\r\n     * Bug Ko┼ƒulu C(X): product.stock = 0 AND iade yap─▒l─▒yor AND negative_stock tetiklendi\r\n     *\r\n     * DB Durum Ge├ºi┼ƒi:\r\n     *   sat─▒┼ƒ: product.stock = 1 ΓåÆ 0, kasa=[+price]\r\n     *   iade:  product.stock = 0 ΓåÆ 1, kasa=[+price, -price]\r\n     *   net kasa = 0, violations = [] (negative_stock tetiklenmemeli)\r\n     *\r\n     * Not: iadeYap stok art─▒r─▒r (stock + item.quantity). Stok 0'dan 1'e ├º─▒kar.\r\n     * negative_stock kural─▒ yaln─▒zca stok azald─▒─ƒ─▒nda tetiklenir, art─▒┼ƒta de─ƒil.\r\n     */\r\n    it('stok s─▒f─▒rken iade ΓåÆ stok 1 olmal─▒, negative_stock tetiklenmemeli', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 1, 500, 300);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      // Sat─▒┼ƒ yap: stock 1 ΓåÆ 0\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 1 }],\r\n        'nakit'\r\n      );\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      // Sat─▒┼ƒ sonras─▒ stok = 0\r\n      const productAfterSale = afterSale.products.find(p => p.id === 'urun-001')!;\r\n      expect(productAfterSale.stock).toBe(0);\r\n\r\n      // ─░ade yap: stock 0 ΓåÆ 1\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n\r\n      // violations bo┼ƒ olmal─▒ (negative_stock tetiklenmemeli)\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // Stok 1 olmal─▒\r\n      const productAfterIade = afterIade.products.find(p => p.id === 'urun-001')!;\r\n      expect(productAfterIade.stock).toBe(1);\r\n\r\n      // Net kasa = 0\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n\r\n      // Sat─▒┼ƒ durumu 'iade' olmal─▒\r\n      const saleAfterIade = afterIade.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIade.status).toBe('iade');\r\n    });\r\n\r\n    it('isBugCondition: product.stock = 0 AND iade yap─▒l─▒yor AND negative_stock tetiklendi ΓåÆ bug yok', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 1, 500, 300);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      // Sat─▒┼ƒ yap: stock 1 ΓåÆ 0\r\n      const { nextDB: afterSale, saleId } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 1 }],\r\n        'nakit'\r\n      );\r\n\r\n      const stockBeforeIade = afterSale.products.find(p => p.id === 'urun-001')!.stock;\r\n\r\n      // ─░ade yap\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n\r\n      const stockAfterIade = afterIade.products.find(p => p.id === 'urun-001')!.stock;\r\n      const negativeStockTriggered = iadeViolations.some(v => v.ruleId === 'negative_stock');\r\n\r\n      // Bug ko┼ƒulu: product.stock = 0 AND iade yap─▒l─▒yor AND negative_stock tetiklendi\r\n      const isBugCondition = stockBeforeIade === 0 && negativeStockTriggered;\r\n\r\n      // Bug ko┼ƒulu tetiklenmemeli ΓÇö iade stok art─▒r─▒r, negative_stock tetiklenmez\r\n      expect(isBugCondition).toBe(false);\r\n      expect(negativeStockTriggered).toBe(false);\r\n      expect(stockAfterIade).toBe(1);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 7: Cari CRUD\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 7: Cari CRUD', () => {\r\n    /**\r\n     * Validates: Requirements 4.1, 4.2, 4.3, 4.4, 5.1, 5.2, 5.3, 5.4, 6.1, 6.2, 6.3\r\n     */\r\n\r\n    // ΓöÇΓöÇ 7a: Duplicate engeli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('7a ΓÇö ayn─▒ isimde ikinci cari eklenemez (duplicate engeli)', () => {\r\n      const db0 = makeDB();\r\n\r\n      // ─░lk ekleme ba┼ƒar─▒l─▒ olmal─▒\r\n      const { nextDB: db1, error: err1 } = cariEkle(db0, { name: 'Ahmet' });\r\n      expect(err1).toBeUndefined();\r\n\r\n      // Aktif cari say─▒s─▒ = 1\r\n      expect(db1.cari.filter(c => !c.deleted).length).toBe(1);\r\n\r\n      // Ayn─▒ isimle ikinci ekleme hata d├╢nd├╝rmeli\r\n      const { nextDB: db2, error: err2 } = cariEkle(db1, { name: 'Ahmet' });\r\n      expect(err2).toBeDefined();\r\n      expect(err2).toContain('Ahmet');\r\n\r\n      // DB de─ƒi┼ƒmemeli ΓÇö h├ól├ó 1 aktif cari\r\n      expect(db2.cari.filter(c => !c.deleted).length).toBe(1);\r\n    });\r\n\r\n    it('7a ΓÇö b├╝y├╝k/k├╝├º├╝k harf fark─▒ g├╢zetmeksizin duplicate engellenmeli', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'ahmet' });\r\n\r\n      // B├╝y├╝k harfle ayn─▒ isim ΓåÆ hata\r\n      const { nextDB: db2, error } = cariEkle(db1, { name: 'AHMET' });\r\n      expect(error).toBeDefined();\r\n      expect(db2.cari.filter(c => !c.deleted).length).toBe(1);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 7b: Soft-delete ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('7b ΓÇö cari silindi─ƒinde deleted:true olarak i┼ƒaretlenmeli, ili┼ƒkili sat─▒┼ƒlar korunmal─▒', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const db0 = makeDB({ products: [soba] });\r\n\r\n      // Cari ekle\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Test M├╝┼ƒteri' });\r\n      const cariId = db1.cari[0].id;\r\n\r\n      // Cari ile sat─▒┼ƒ yap\r\n      const { nextDB: db2 } = satisYap(\r\n        db1,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        cariId,\r\n        0\r\n      );\r\n\r\n      // Sat─▒┼ƒ mevcut olmal─▒\r\n      expect(db2.sales.length).toBe(1);\r\n      expect(db2.sales[0].cariId).toBe(cariId);\r\n\r\n      // Cariyi sil\r\n      const { nextDB: db3 } = cariSil(db2, cariId);\r\n\r\n      // Cari deleted:true olmal─▒\r\n      const deletedCari = db3.cari.find(c => c.id === cariId)!;\r\n      expect(deletedCari).toBeDefined();\r\n      expect(deletedCari.deleted).toBe(true);\r\n\r\n      // Aktif cari listesinde g├╢r├╝nmemeli\r\n      expect(db3.cari.filter(c => !c.deleted).length).toBe(0);\r\n\r\n      // ─░li┼ƒkili sat─▒┼ƒ h├ól├ó mevcut olmal─▒\r\n      expect(db3.sales.length).toBe(1);\r\n      expect(db3.sales[0].cariId).toBe(cariId);\r\n    });\r\n\r\n    it('7b ΓÇö silinen cari updatedAt g├╝ncellenmeli', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Silinecek Cari' });\r\n      const cariId = db1.cari[0].id;\r\n      const createdAt = db1.cari[0].updatedAt;\r\n\r\n      // K─▒sa bir bekleme sim├╝le etmek i├ºin updatedAt'i ge├ºmi┼ƒe al\r\n      const db1Modified: DB = {\r\n        ...db1,\r\n        cari: db1.cari.map(c =>\r\n          c.id === cariId ? { ...c, updatedAt: '2020-01-01T00:00:00.000Z' } : c\r\n        ),\r\n      };\r\n\r\n      const { nextDB: db2 } = cariSil(db1Modified, cariId);\r\n      const deletedCari = db2.cari.find(c => c.id === cariId)!;\r\n\r\n      expect(deletedCari.deleted).toBe(true);\r\n      expect(deletedCari.updatedAt).not.toBe('2020-01-01T00:00:00.000Z');\r\n    });\r\n\r\n    // ΓöÇΓöÇ 7c: D├╝zenleme bakiye korumas─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('7c ΓÇö cari d├╝zenlendi─ƒinde bakiye de─ƒi┼ƒmemeli, updatedAt g├╝ncellenmeli', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const db0 = makeDB({ products: [soba] });\r\n\r\n      // Cari ekle\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Bakiyeli M├╝┼ƒteri' });\r\n      const cariId = db1.cari[0].id;\r\n\r\n      // Cari sat─▒┼ƒ yap: 1200Γé║ toplam, 500Γé║ tahsilat ΓåÆ cari.balance = 700\r\n      const { nextDB: db2 } = satisYap(\r\n        db1,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        cariId,\r\n        500\r\n      );\r\n\r\n      const cariBeforeEdit = db2.cari.find(c => c.id === cariId)!;\r\n      expect(cariBeforeEdit.balance).toBe(700);\r\n\r\n      // updatedAt'i ge├ºmi┼ƒe al (d├╝zenleme sonras─▒ de─ƒi┼ƒti─ƒini do─ƒrulamak i├ºin)\r\n      const db2Modified: DB = {\r\n        ...db2,\r\n        cari: db2.cari.map(c =>\r\n          c.id === cariId ? { ...c, updatedAt: '2020-01-01T00:00:00.000Z' } : c\r\n        ),\r\n      };\r\n\r\n      // Sadece telefon numaras─▒n─▒ d├╝zenle\r\n      const { nextDB: db3 } = cariDuzenle(db2Modified, cariId, { phone: '555' });\r\n\r\n      const cariAfterEdit = db3.cari.find(c => c.id === cariId)!;\r\n\r\n      // Bakiye de─ƒi┼ƒmemeli\r\n      expect(cariAfterEdit.balance).toBe(700);\r\n\r\n      // updatedAt g├╝ncellenmeli\r\n      expect(cariAfterEdit.updatedAt).not.toBe('2020-01-01T00:00:00.000Z');\r\n\r\n      // Telefon g├╝ncellenmeli\r\n      expect(cariAfterEdit.phone).toBe('555');\r\n    });\r\n\r\n    it('7c ΓÇö cari d├╝zenlendi─ƒinde id ve createdAt de─ƒi┼ƒmemeli', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'D├╝zenlenecek Cari' });\r\n      const cariId = db1.cari[0].id;\r\n      const createdAt = db1.cari[0].createdAt;\r\n\r\n      const { nextDB: db2 } = cariDuzenle(db1, cariId, { name: 'Yeni ─░sim', phone: '0555' });\r\n      const editedCari = db2.cari.find(c => c.id === cariId)!;\r\n\r\n      expect(editedCari.id).toBe(cariId);\r\n      expect(editedCari.createdAt).toBe(createdAt);\r\n      expect(editedCari.name).toBe('Yeni ─░sim');\r\n      expect(editedCari.phone).toBe('0555');\r\n    });\r\n\r\n    // ΓöÇΓöÇ 7d: Benzerlik uyar─▒s─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('7d ΓÇö benzer isimde cari eklendi─ƒinde uyar─▒ ├╝retilmeli (similarity >= 70)', () => {\r\n      const db0 = makeDB();\r\n\r\n      // ─░lk cari ekle: 'Ahmet Yilmaz'\r\n      const { nextDB: db1, error: err1 } = cariEkle(db0, { name: 'Ahmet Yilmaz' });\r\n      expect(err1).toBeUndefined();\r\n      expect(db1.cari.filter(c => !c.deleted).length).toBe(1);\r\n\r\n      // Benzer isimle ikinci cari ekle: 'Ahmet Y─▒lmaz' (─▒ ΓåÆ i fark─▒)\r\n      // normalizeTR sonras─▒ her ikisi de 'ahmet yilmaz' ΓåÆ similarity = 100 >= 70\r\n      const { nextDB: db2, error: err2 } = cariEkle(db1, { name: 'Ahmet Y─▒lmaz' });\r\n\r\n      // Uyar─▒ ├╝retilmeli (similarity uyar─▒s─▒)\r\n      expect(err2).toBeDefined();\r\n      expect(err2).toContain('Uyar─▒');\r\n\r\n      // Cari yine de eklenmeli (uyar─▒ engellemez, sadece bildirir)\r\n      expect(db2.cari.filter(c => !c.deleted).length).toBe(2);\r\n    });\r\n\r\n    it('7d ΓÇö benzerlik uyar─▒s─▒: orijinal cari ad─▒ uyar─▒ mesaj─▒nda yer almal─▒', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Mehmet Demir' });\r\n\r\n      // Benzer isim: 'Mehmet Dem─▒r' (─▒ fark─▒)\r\n      const { error } = cariEkle(db1, { name: 'Mehmet Dem─▒r' });\r\n\r\n      expect(error).toBeDefined();\r\n      expect(error).toContain('Uyar─▒');\r\n      // Orijinal isim uyar─▒da ge├ºmeli\r\n      expect(error).toContain('Mehmet Demir');\r\n    });\r\n\r\n    // ΓöÇΓöÇ 6.1: Yeni cari ba┼ƒlang─▒├º bakiyesi 0 ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('6.1 ΓÇö yeni cari ba┼ƒlang─▒├º bakiyesi 0 olmal─▒', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Yeni Cari' });\r\n      const newCari = db1.cari[0];\r\n\r\n      expect(newCari.balance).toBe(0);\r\n      expect(newCari.deleted).toBe(false);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 6.3: Silinen cari listede g├╢r├╝nmez ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('6.3 ΓÇö silinen cari (deleted:true) aktif listede g├╢r├╝nmemeli', () => {\r\n      const db0 = makeDB();\r\n      const { nextDB: db1 } = cariEkle(db0, { name: 'Aktif Cari' });\r\n      const { nextDB: db2 } = cariEkle(db1, { name: 'Silinecek Cari' });\r\n\r\n      const silinecekId = db2.cari.find(c => c.name === 'Silinecek Cari')!.id;\r\n      const { nextDB: db3 } = cariSil(db2, silinecekId);\r\n\r\n      // Aktif liste: yaln─▒zca deleted:false olanlar\r\n      const aktifCariler = db3.cari.filter(c => !c.deleted);\r\n      expect(aktifCariler.length).toBe(1);\r\n      expect(aktifCariler[0].name).toBe('Aktif Cari');\r\n\r\n      // Silinen cari DB'de h├ól├ó mevcut (soft-delete)\r\n      const tumCariler = db3.cari;\r\n      expect(tumCariler.length).toBe(2);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 8: Sat─▒┼ƒ Fiyat/─░skonto D├╝zeltmesi\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 8: Sat─▒┼ƒ Fiyat/─░skonto D├╝zeltmesi', () => {\r\n    /**\r\n     * Validates: Requirements 7.1, 7.2, 7.3, 8.1, 8.2, 8.3, 9.1, 9.2, 9.3\r\n     *\r\n     * Bug Ko┼ƒulu C(X): unitPrice de─ƒi┼ƒti AND profit eski fiyatla hesapland─▒\r\n     *                  VEYA total/discountAmount tutars─▒z\r\n     */\r\n\r\n    // ΓöÇΓöÇ 8a: Fiyat de─ƒi┼ƒikli─ƒi k├ór hesab─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('8a ΓÇö fiyat de─ƒi┼ƒikli─ƒi k├ór hesab─▒: unitPrice=1500, cost=800, qty=2 ΓåÆ profit=1400', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 10, 1000, 800);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      // ├£r├╝n fiyat─▒ 1000Γé║ ama sat─▒┼ƒta 1500Γé║ kullan─▒yoruz\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 2, unitPrice: 1500 }],\r\n        'nakit'\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n\r\n      // subtotal = 2 ├ù 1500 = 3000\r\n      expect(sale.subtotal).toBe(3000);\r\n\r\n      // discountAmount = 0 (iskonto yok)\r\n      expect(sale.discountAmount).toBe(0);\r\n\r\n      // profit = (1500 - 800) ├ù 2 = 1400\r\n      expect(sale.profit).toBe(1400);\r\n\r\n      // total = 3000\r\n      expect(sale.total).toBe(3000);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 8b: Y├╝zde iskonto ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('8b ΓÇö y├╝zde iskonto: qty=2, unitPrice=1000, cost=500, %10 iskonto ΓåÆ profit=800', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 10, 1000, 500);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 2, unitPrice: 1000 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'percent', value: 10 }\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n\r\n      // subtotal = 2 ├ù 1000 = 2000\r\n      expect(sale.subtotal).toBe(2000);\r\n\r\n      // discountAmount = 2000 ├ù 10% = 200\r\n      expect(sale.discountAmount).toBe(200);\r\n\r\n      // total = 2000 - 200 = 1800\r\n      expect(sale.total).toBe(1800);\r\n\r\n      // profit = (1000 - 500) ├ù 2 - 200 = 1000 - 200 = 800\r\n      expect(sale.profit).toBe(800);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 8c: Tutar iskontosu ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('8c ΓÇö tutar iskontosu: qty=2, unitPrice=1000, 300Γé║ iskonto ΓåÆ total=1700', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 10, 1000, 500);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 2, unitPrice: 1000 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'amount', value: 300 }\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n\r\n      // subtotal = 2 ├ù 1000 = 2000\r\n      expect(sale.subtotal).toBe(2000);\r\n\r\n      // discountAmount = 300\r\n      expect(sale.discountAmount).toBe(300);\r\n\r\n      // total = 2000 - 300 = 1700\r\n      expect(sale.total).toBe(1700);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 8d: total = subtotal - discountAmount invariant─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('8d ΓÇö total = subtotal - discountAmount invariant─▒: iskonto yok', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 10, 1000, 500);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      // ─░skonto yok\r\n      const { nextDB: db1, saleId: sid1 } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 3, unitPrice: 800 }],\r\n        'nakit'\r\n      );\r\n      const sale1 = db1.sales.find(s => s.id === sid1)!;\r\n      expect(sale1.total).toBe(sale1.subtotal - sale1.discountAmount);\r\n\r\n      // Y├╝zde iskonto\r\n      const { nextDB: db2, saleId: sid2 } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 2, unitPrice: 1000 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'percent', value: 15 }\r\n      );\r\n      const sale2 = db2.sales.find(s => s.id === sid2)!;\r\n      expect(sale2.total).toBe(sale2.subtotal - sale2.discountAmount);\r\n\r\n      // Tutar iskontosu\r\n      const { nextDB: db3, saleId: sid3 } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 2, unitPrice: 1000 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'amount', value: 150 }\r\n      );\r\n      const sale3 = db3.sales.find(s => s.id === sid3)!;\r\n      expect(sale3.total).toBe(sale3.subtotal - sale3.discountAmount);\r\n    });\r\n\r\n    it('8d ΓÇö total = subtotal - discountAmount invariant─▒: property-based', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 200, 1000, 400);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      fc.assert(\r\n        fc.property(\r\n          fc.integer({ min: 1, max: 10 }),\r\n          fc.integer({ min: 100, max: 2000 }),\r\n          fc.integer({ min: 0, max: 50 }),\r\n          (qty, unitPrice, discPct) => {\r\n            const { nextDB, saleId } = satisYap(\r\n              prevDB,\r\n              [{ productId: 'urun-001', qty, unitPrice }],\r\n              'nakit',\r\n              undefined,\r\n              undefined,\r\n              discPct > 0 ? { type: 'percent', value: discPct } : undefined\r\n            );\r\n            const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n            // total = max(0, subtotal - discountAmount)\r\n            const expected = Math.max(0, sale.subtotal - sale.discountAmount);\r\n            return sale.total === expected;\r\n          }\r\n        )\r\n      );\r\n    });\r\n\r\n    // ΓöÇΓöÇ 8e: Negatif toplam olu┼ƒturacak iskonto ΓåÆ zero_amount ihlali ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('8e ΓÇö negatif toplam olu┼ƒturacak iskonto: total = max(0, 100-200) = 0', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 10, 100, 50);\r\n      const prevDB = makeDB({ products: [urun] });\r\n\r\n      // subtotal = 100, iskonto = 200 ΓåÆ total = max(0, -100) = 0\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        prevDB,\r\n        [{ productId: 'urun-001', qty: 1, unitPrice: 100 }],\r\n        'nakit',\r\n        undefined,\r\n        undefined,\r\n        { type: 'amount', value: 200 }\r\n      );\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n\r\n      // total = 0 (negatife d├╝┼ƒmez)\r\n      expect(sale.total).toBe(0);\r\n\r\n      // zero_amount ihlali VEYA total = 0 ΓÇö ikisi de kabul edilebilir davran─▒┼ƒ\r\n      const hasZeroAmountViolation = violations.some(v => v.ruleId === 'zero_amount');\r\n      const totalIsZero = sale.total === 0;\r\n\r\n      // En az biri do─ƒru olmal─▒\r\n      expect(hasZeroAmountViolation || totalIsZero).toBe(true);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 9: Kasa Ekleme/D├╝zenleme\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 9: Kasa Ekleme/D├╝zenleme', () => {\r\n    /**\r\n     * Validates: Requirements 10.1, 10.2, 10.3, 10.4, 11.1, 11.2, 11.3, 11.4, 12.1, 12.2, 12.3\r\n     *\r\n     * Bug Ko┼ƒullar─▒:\r\n     *   C1(X): amount=0 ile kasa kayd─▒ olu┼ƒtu\r\n     *   C2(X): Yetersiz bakiyeye ra─ƒmen gider eklendi\r\n     */\r\n\r\n    // ΓöÇΓöÇ 9a: S─▒f─▒r tutar engeli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9a ΓÇö s─▒f─▒r tutar engeli: kasaGelirEkle(db, 0) ΓåÆ zero_amount ihlali', () => {\r\n      const db = makeDB();\r\n\r\n      const { violations } = kasaGelirEkle(db, 0, 'nakit');\r\n\r\n      // zero_amount kural─▒ tetiklenmeli\r\n      expect(violations.some(v => v.ruleId === 'zero_amount')).toBe(true);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 9b: Negatif kasa engeli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9b ΓÇö negatif kasa engeli: bo┼ƒ kasadan gider ΓåÆ negative_kasa ihlali', () => {\r\n      // Ba┼ƒlang─▒├º kasas─▒ bo┼ƒ (bakiye = 0)\r\n      const db = makeDB();\r\n\r\n      // 500Γé║ gider ekle ΓÇö kasa bakiyesi 0'dan negatife d├╝┼ƒer\r\n      const { violations } = kasaGiderEkle(db, 500, 'nakit');\r\n\r\n      // negative_kasa kural─▒ tetiklenmeli\r\n      expect(violations.some(v => v.ruleId === 'negative_kasa')).toBe(true);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 9c: CariId ba─ƒl─▒ kasa kayd─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9c ΓÇö cariId ba─ƒl─▒ kasa geliri: cari.balance 1000 ΓåÆ 700 olmal─▒', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1000, 600);\r\n\r\n      // Cari olu┼ƒtur\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Cari sat─▒┼ƒ yap: 1000Γé║ toplam, tahsilat yok ΓåÆ cari.balance = 1000\r\n      const { nextDB: db1 } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        0\r\n      );\r\n\r\n      const cariAfterSale = db1.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterSale.balance).toBe(1000);\r\n\r\n      // Kasa bakiyesini 300Γé║ art─▒r (ba┼ƒlang─▒├º i├ºin gelir ekle)\r\n      const { nextDB: db2 } = kasaGelirEkle(db1, 300, 'nakit');\r\n\r\n      // ┼₧imdi cariId ba─ƒl─▒ gelir ekle: cari.balance 1000 ΓåÆ 700 olmal─▒\r\n      const { nextDB: db3, violations } = kasaGelirEkle(db2, 300, 'nakit', 'musteri-001');\r\n\r\n      // violations bo┼ƒ olmal─▒ (ge├ºerli i┼ƒlem)\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // cari.balance 300 azalm─▒┼ƒ olmal─▒: 1000 - 300 = 700\r\n      const cariAfterKasa = db3.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterKasa.balance).toBe(700);\r\n\r\n      // Kasa bakiyesi 300 artm─▒┼ƒ olmal─▒\r\n      const kasaBakiye = db3.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      // db2'de 300 gelir vard─▒, db3'te 300 daha eklendi ΓåÆ toplam 600\r\n      expect(kasaBakiye).toBe(600);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 9d: Ge├ºerli gelir kayd─▒ kasa bakiyesini art─▒r─▒r ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9d ΓÇö ge├ºerli gelir kayd─▒: kasa bakiyesi 500 ΓåÆ 700 olmal─▒', () => {\r\n      const db0 = makeDB();\r\n\r\n      // ├ûnce 500Γé║ gelir ekle (ba┼ƒlang─▒├º bakiyesi)\r\n      const { nextDB: db1 } = kasaGelirEkle(db0, 500, 'nakit');\r\n\r\n      // 200Γé║ daha gelir ekle\r\n      const { nextDB: db2, violations } = kasaGelirEkle(db1, 200, 'nakit');\r\n\r\n      // violations bo┼ƒ olmal─▒\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // Kasa bakiyesi = 500 + 200 = 700\r\n      const kasaBakiye = db2.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(kasaBakiye).toBe(700);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 9e: Ge├ºerli gider kayd─▒ kasa bakiyesini azalt─▒r ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9e ΓÇö ge├ºerli gider kayd─▒: kasa bakiyesi 500 ΓåÆ 300 olmal─▒', () => {\r\n      const db0 = makeDB();\r\n\r\n      // ├ûnce 500Γé║ gelir ekle (ba┼ƒlang─▒├º bakiyesi)\r\n      const { nextDB: db1 } = kasaGelirEkle(db0, 500, 'nakit');\r\n\r\n      // 200Γé║ gider ekle\r\n      const { nextDB: db2, violations } = kasaGiderEkle(db1, 200, 'nakit');\r\n\r\n      // violations bo┼ƒ olmal─▒\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // Kasa bakiyesi = 500 - 200 = 300\r\n      const kasaBakiye = db2.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(kasaBakiye).toBe(300);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 9f: cariId olmayan kasa kayd─▒ cari tablosuna dokunmaz ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('9f ΓÇö cariId olmayan kasa geliri: cari.balance de─ƒi┼ƒmemeli', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1000, 600);\r\n\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Cari sat─▒┼ƒ yap: cari.balance = 500\r\n      const { nextDB: db1 } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        500\r\n      );\r\n\r\n      const cariBalanceBefore = db1.cari.find(c => c.id === 'musteri-001')!.balance;\r\n      expect(cariBalanceBefore).toBe(500);\r\n\r\n      // cariId olmadan kasa geliri ekle\r\n      const { nextDB: db2, violations } = kasaGelirEkle(db1, 300, 'nakit');\r\n\r\n      // violations bo┼ƒ olmal─▒\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // cari.balance de─ƒi┼ƒmemeli\r\n      const cariBalanceAfter = db2.cari.find(c => c.id === 'musteri-001')!.balance;\r\n      expect(cariBalanceAfter).toBe(cariBalanceBefore);\r\n      expect(cariBalanceAfter).toBe(500);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 10: Kasa Hareketleri Soft-Delete\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 10: Kasa Hareketleri Soft-Delete', () => {\r\n    /**\r\n     * Validates: Requirements 13.1, 13.2, 13.3, 14.1, 14.2, 14.3, 15.1, 15.2, 15.3\r\n     *\r\n     * Bug Ko┼ƒullar─▒:\r\n     *   C1(X): ard─▒┼ƒ─▒k gelir/gider sonras─▒ bakiye yanl─▒┼ƒ hesapland─▒\r\n     *   C2(X): cariId'li kasa kayd─▒ silindi─ƒinde cari.balance geri al─▒nmad─▒\r\n     *   C3(X): silinen kay─▒t bakiye hesab─▒na dahil edildi\r\n     */\r\n\r\n    // ΓöÇΓöÇ 10a: Birikimli bakiye ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('10a ΓÇö birikimli bakiye: gelir(500) + gelir(300) - gider(200) = 600', () => {\r\n      const db0 = makeDB();\r\n\r\n      // gelir 500\r\n      const { nextDB: db1 } = kasaGelirEkle(db0, 500, 'nakit');\r\n      const bakiye1 = db1.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bakiye1).toBe(500);\r\n\r\n      // gelir 300\r\n      const { nextDB: db2 } = kasaGelirEkle(db1, 300, 'nakit');\r\n      const bakiye2 = db2.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bakiye2).toBe(800);\r\n\r\n      // gider 200\r\n      const { nextDB: db3 } = kasaGiderEkle(db2, 200, 'nakit');\r\n      const bakiye3 = db3.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bakiye3).toBe(600);\r\n\r\n      // ╬ú(gelir) - ╬ú(gider) = 600 (deleted:false kay─▒tlar)\r\n      const gelirToplam = db3.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      const giderToplam = db3.kasa\r\n        .filter(k => !k.deleted && k.type === 'gider')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(gelirToplam - giderToplam).toBe(600);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 10b: Soft-delete cari geri al─▒m─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('10b ΓÇö soft-delete cari geri al─▒m─▒: kasaKayitSil sonras─▒ cari.balance 1000 olmal─▒', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1000, 600);\r\n\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Cari sat─▒┼ƒ yap: 1000Γé║ toplam, tahsilat yok ΓåÆ cari.balance = 1000\r\n      const { nextDB: db1 } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        0\r\n      );\r\n\r\n      const cariAfterSale = db1.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterSale.balance).toBe(1000);\r\n\r\n      // Kasa bakiyesini art─▒r (gelir ekle) ΓÇö sonraki gelir i├ºin bakiye gerekli\r\n      const { nextDB: db1b } = kasaGelirEkle(db1, 300, 'nakit');\r\n\r\n      // cariId ba─ƒl─▒ kasa geliri ekle: cari.balance 1000 ΓåÆ 700\r\n      const { nextDB: db2, entryId } = kasaGelirEkle(db1b, 300, 'nakit', 'musteri-001');\r\n\r\n      const cariAfterKasa = db2.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterKasa.balance).toBe(700);\r\n\r\n      // Kasa kayd─▒n─▒ soft-delete ile sil ΓåÆ cari.balance 700 ΓåÆ 1000 (geri d├╢nd├╝)\r\n      const { nextDB: db3 } = kasaKayitSil(db2, entryId);\r\n\r\n      // Kasa kayd─▒ deleted:true olmal─▒\r\n      const deletedEntry = db3.kasa.find(k => k.id === entryId)!;\r\n      expect(deletedEntry.deleted).toBe(true);\r\n\r\n      // cari.balance 1000'e geri d├╢nmeli\r\n      const cariAfterDelete = db3.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterDelete.balance).toBe(1000);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 10c: Silinen kay─▒t bakiye d─▒┼ƒ─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('10c ΓÇö silinen kay─▒t bakiye d─▒┼ƒ─▒: gelir(500) ΓåÆ sil ΓåÆ bakiye = 0', () => {\r\n      const db0 = makeDB();\r\n\r\n      // 500Γé║ gelir ekle\r\n      const { nextDB: db1, entryId } = kasaGelirEkle(db0, 500, 'nakit');\r\n\r\n      // Bakiye = 500\r\n      const bakiye1 = db1.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bakiye1).toBe(500);\r\n\r\n      // Kayd─▒ sil\r\n      const { nextDB: db2 } = kasaKayitSil(db1, entryId);\r\n\r\n      // entry.deleted = true olmal─▒\r\n      const entry = db2.kasa.find(k => k.id === entryId)!;\r\n      expect(entry.deleted).toBe(true);\r\n\r\n      // Bakiye = 0 (silinen kay─▒t hesaba kat─▒lmaz)\r\n      const bakiye2 = db2.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bakiye2).toBe(0);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 10d: Farkl─▒ kasalar─▒n bakiyeleri ba─ƒ─▒ms─▒z ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('10d ΓÇö farkl─▒ kasalar─▒n bakiyeleri ba─ƒ─▒ms─▒z: nakit=800, banka=500', () => {\r\n      const db0 = makeDB();\r\n\r\n      // nakit: 1000Γé║ gelir\r\n      const { nextDB: db1 } = kasaGelirEkle(db0, 1000, 'nakit');\r\n\r\n      // banka: 500Γé║ gelir\r\n      const { nextDB: db2 } = kasaGelirEkle(db1, 500, 'banka');\r\n\r\n      // nakit: 200Γé║ gider\r\n      const { nextDB: db3 } = kasaGiderEkle(db2, 200, 'nakit');\r\n\r\n      // nakit bakiyesi = 1000 - 200 = 800\r\n      const nakitBakiye = db3.kasa\r\n        .filter(k => !k.deleted && k.kasa === 'nakit')\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(nakitBakiye).toBe(800);\r\n\r\n      // banka bakiyesi = 500 (ba─ƒ─▒ms─▒z)\r\n      const bankaBakiye = db3.kasa\r\n        .filter(k => !k.deleted && k.kasa === 'banka')\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(bankaBakiye).toBe(500);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 11: Stok Hareketleri\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 11: Stok Hareketleri', () => {\r\n    /**\r\n     * Validates: Requirements 16.1, 16.2, 16.3, 16.4, 17.1, 17.2, 17.3, 17.4, 18.1, 18.2, 18.3\r\n     *\r\n     * Bug Ko┼ƒullar─▒:\r\n     *   C1(X): before/after yer de─ƒi┼ƒtirdi\r\n     *   C2(X): D├╝zeltme amount yanl─▒┼ƒ i┼ƒaretlendi\r\n     */\r\n\r\n    // ΓöÇΓöÇ 11a: Giri┼ƒ before/after ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('11a ΓÇö stok giri┼ƒi: before=20, amount=10 ΓåÆ after=30, product.stock=30', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 20, 1000, 600);\r\n      const db = makeDB({ products: [urun] });\r\n\r\n      const { nextDB } = stokGiris(db, 'urun-001', 10);\r\n\r\n      const movement = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n      expect(movement).toBeDefined();\r\n      expect(movement.before).toBe(20);\r\n      expect(movement.after).toBe(30);\r\n      expect(movement.amount).toBe(10);\r\n      expect(movement.type).toBe('giris');\r\n\r\n      const product = nextDB.products.find(p => p.id === 'urun-001')!;\r\n      expect(product.stock).toBe(30);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 11b: ├ç─▒k─▒┼ƒ s─▒f─▒r stok korumas─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('11b ΓÇö stok ├º─▒k─▒┼ƒ─▒ s─▒f─▒r stok korumas─▒: stock=0, ├º─▒k─▒┼ƒ=5 ΓåÆ stock=0 (negatife d├╝┼ƒmez)', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 0, 1000, 600);\r\n      const db = makeDB({ products: [urun] });\r\n\r\n      const { nextDB } = stokCikis(db, 'urun-001', 5);\r\n\r\n      const product = nextDB.products.find(p => p.id === 'urun-001')!;\r\n      expect(product.stock).toBe(0);\r\n\r\n      const movement = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n      expect(movement).toBeDefined();\r\n      expect(movement.before).toBe(0);\r\n      expect(movement.after).toBe(0);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 11c: D├╝zeltme amount hesab─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('11c ΓÇö stok d├╝zeltme: stock=15, yeni=8 ΓåÆ amount=-7, before=15, after=8', () => {\r\n      const urun = makeProduct('urun-001', 'Test ├£r├╝n', 15, 1000, 600);\r\n      const db = makeDB({ products: [urun] });\r\n\r\n      const { nextDB } = stokDuzeltme(db, 'urun-001', 8);\r\n\r\n      const movement = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n      expect(movement).toBeDefined();\r\n      // amount = newStock - before = 8 - 15 = -7\r\n      expect(movement.amount).toBe(-7);\r\n      expect(movement.before).toBe(15);\r\n      expect(movement.after).toBe(8);\r\n      expect(movement.type).toBe('duzeltme');\r\n\r\n      const product = nextDB.products.find(p => p.id === 'urun-001')!;\r\n      expect(product.stock).toBe(8);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 11d: ├£r├╝n sto─ƒu ile hareket tutarl─▒l─▒─ƒ─▒ (property-based) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('11d ΓÇö stok giri┼ƒi tutarl─▒l─▒k invariant─▒: movement.before===stock && movement.after===stock+giris (property)', () => {\r\n      /**\r\n       * Validates: Requirements 16.1, 16.2, 16.3, 16.4\r\n       */\r\n      fc.assert(\r\n        fc.property(\r\n          fc.integer({ min: 0, max: 100 }),\r\n          fc.integer({ min: 1, max: 50 }),\r\n          (stock, giris) => {\r\n            const urun = makeProduct('urun-001', 'Test ├£r├╝n', stock, 1000, 600);\r\n            const db = makeDB({ products: [urun] });\r\n\r\n            const { nextDB } = stokGiris(db, 'urun-001', giris);\r\n\r\n            const movement = nextDB.stockMovements.find(m => m.productId === 'urun-001')!;\r\n            const product = nextDB.products.find(p => p.id === 'urun-001')!;\r\n\r\n            return (\r\n              movement.before === stock &&\r\n              movement.after === stock + giris &&\r\n              product.stock === movement.after\r\n            );\r\n          }\r\n        )\r\n      );\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Grup 12: Sat─▒┼ƒ Tam Ya┼ƒam D├╢ng├╝s├╝\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Grup 12: Sat─▒┼ƒ Tam Ya┼ƒam D├╢ng├╝s├╝', () => {\r\n    /**\r\n     * Validates: Requirements 19.1, 19.2, 19.3, 19.4, 19.5, 20.1, 20.2, 20.3, 20.4, 20.5,\r\n     *            21.1, 21.2, 21.3, 21.4\r\n     */\r\n\r\n    // ΓöÇΓöÇ 12a: K─▒smi tahsilat tutarl─▒l─▒─ƒ─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12a ΓÇö k─▒smi tahsilat tutarl─▒l─▒─ƒ─▒: kasa=400, cari.balance=800, toplam=1200', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        400\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n      expect(sale.total).toBe(1200);\r\n\r\n      // Kasa geliri = 400\r\n      const kasaGelir = nextDB.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(400);\r\n\r\n      // cari.balance art─▒┼ƒ─▒ = 800\r\n      const cari = nextDB.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cari.balance).toBe(800);\r\n\r\n      // 400 + 800 = 1200 = sale.total\r\n      expect(kasaGelir + cari.balance).toBe(sale.total);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12b: Ek tahsilat ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12b ΓÇö ek tahsilat: cari.balance=800 ΓåÆ tahsilatYap(800) ΓåÆ kasa+=800, cari.balance=0', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // 12a ile ayn─▒ kurulum: k─▒smi tahsilat 400\r\n      const { nextDB: db1 } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        400\r\n      );\r\n\r\n      const cariAfterSale = db1.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterSale.balance).toBe(800);\r\n\r\n      const kasaBefore = db1.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaBefore).toBe(400);\r\n\r\n      // Ek tahsilat: 800Γé║\r\n      const { nextDB: db2, violations } = tahsilatYap(db1, 'musteri-001', 800, 'nakit');\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // Kasa += 800 (toplam 1200)\r\n      const kasaAfter = db2.kasa\r\n        .filter(k => !k.deleted && k.type === 'gelir')\r\n        .reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaAfter).toBe(kasaBefore + 800);\r\n\r\n      // cari.balance = 0\r\n      const cariAfterTahsilat = db2.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterTahsilat.balance).toBe(0);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12c: K─▒smi tahsilatl─▒ iade ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12c ΓÇö k─▒smi tahsilatl─▒ iade: kasa=[+400,-400], cari.balance=0, net kasa=0', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Sat─▒┼ƒ: kasa=[+400], cari.balance=800\r\n      const { nextDB: db1, saleId } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        400\r\n      );\r\n\r\n      const cariAfterSale = db1.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterSale.balance).toBe(800);\r\n\r\n      // ─░ade: kasa=[+400,-400], cari.balance=0\r\n      const { nextDB: db2, violations } = iadeYap(db1, saleId);\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // cari.balance = 0\r\n      const cariAfterIade = db2.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cariAfterIade.balance).toBe(0);\r\n\r\n      // Net kasa = 0\r\n      const netKasa = db2.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12d: ─░ptal sonras─▒ ├ºift iade engeli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12d ΓÇö iptal sonras─▒ ├ºift iade engeli: iptal edilmi┼ƒ sat─▒┼ƒ iade edilemez', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const db0 = makeDB({ products: [soba] });\r\n\r\n      // Nakit sat─▒┼ƒ\r\n      const { nextDB: db1, saleId } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit'\r\n      );\r\n\r\n      // ─░ptal et ΓåÆ status='iptal'\r\n      const { nextDB: db2 } = iptalYap(db1, saleId);\r\n      const saleAfterIptal = db2.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIptal.status).toBe('iptal');\r\n\r\n      // ─░ade yapmaya ├ºal─▒┼ƒ ΓåÆ engellenmeli (status !== 'tamamlandi')\r\n      const { nextDB: db3 } = iadeYap(db2, saleId);\r\n\r\n      // Sat─▒┼ƒ durumu 'iptal' olarak kalmal─▒ (iade'ye ge├ºmemeli)\r\n      const saleAfterIade = db3.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIade.status).toBe('iptal');\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12e: ─░ptal stok geri y├╝kleme ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12e ΓÇö iptal stok geri y├╝kleme: sat─▒┼ƒ sonras─▒ stock=9, iptal sonras─▒ stock=10', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const db0 = makeDB({ products: [soba] });\r\n\r\n      // Sat─▒┼ƒ: stock 10 ΓåÆ 9\r\n      const { nextDB: db1, saleId } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit'\r\n      );\r\n\r\n      const sobaAfterSale = db1.products.find(p => p.id === 'soba-001')!;\r\n      expect(sobaAfterSale.stock).toBe(9);\r\n\r\n      // ─░ptal: stock 9 ΓåÆ 10\r\n      const { nextDB: db2, violations } = iptalYap(db1, saleId);\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // sale.status = 'iptal'\r\n      const saleAfterIptal = db2.sales.find(s => s.id === saleId)!;\r\n      expect(saleAfterIptal.status).toBe('iptal');\r\n\r\n      // product.stock = 10\r\n      const sobaAfterIptal = db2.products.find(p => p.id === 'soba-001')!;\r\n      expect(sobaAfterIptal.stock).toBe(10);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12f: Tam nakit sat─▒┼ƒta cari.balance de─ƒi┼ƒmez ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12f ΓÇö tam nakit sat─▒┼ƒta cari.balance de─ƒi┼ƒmez', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Nakit sat─▒┼ƒ ΓÇö cariId yok\r\n      const { nextDB, violations } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'nakit'\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      // cari.balance de─ƒi┼ƒmemeli (h├ól├ó 0)\r\n      const cari = nextDB.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cari.balance).toBe(0);\r\n    });\r\n\r\n    // ΓöÇΓöÇ 12g: Tam cari sat─▒┼ƒta kasaya giri┼ƒ yok ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n    it('12g ΓÇö tam cari sat─▒┼ƒta kasaya giri┼ƒ yok: tahsilat=0 ΓåÆ kasa entries=0, cari.balance=sale.total', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const musteri: Cari = {\r\n        id: 'musteri-001',\r\n        name: 'Test M├╝┼ƒteri',\r\n        type: 'musteri',\r\n        balance: 0,\r\n        deleted: false,\r\n        createdAt: now(),\r\n        updatedAt: now(),\r\n      };\r\n      const db0 = makeDB({ products: [soba], cari: [musteri] });\r\n\r\n      // Cari sat─▒┼ƒ, tahsilat=0\r\n      const { nextDB, saleId, violations } = satisYap(\r\n        db0,\r\n        [{ productId: 'soba-001', qty: 1 }],\r\n        'cari',\r\n        'musteri-001',\r\n        0\r\n      );\r\n      expect(violations).toHaveLength(0);\r\n\r\n      const sale = nextDB.sales.find(s => s.id === saleId)!;\r\n\r\n      // Kasa entries = 0 (nakit giri┼ƒ yok)\r\n      const kasaEntries = nextDB.kasa.filter(k => !k.deleted && k.type === 'gelir');\r\n      expect(kasaEntries).toHaveLength(0);\r\n\r\n      // cari.balance = sale.total\r\n      const cari = nextDB.cari.find(c => c.id === 'musteri-001')!;\r\n      expect(cari.balance).toBe(sale.total);\r\n      expect(cari.balance).toBe(1200);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // ≡ƒö¼ G├ûREV 1: Bug Condition Exploration ΓÇö Nakit Sat─▒┼ƒ ΓåÆ ─░ade\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('≡ƒö¼ G├╢rev 1: Bug Condition Exploration ΓÇö Nakit Sat─▒┼ƒ ΓåÆ ─░ade', () => {\r\n    it('nakit sat─▒┼ƒ ΓåÆ iade sonras─▒ net kasa s─▒f─▒r olmal─▒ (bug condition)', () => {\r\n      const soba = makeProduct('soba-001', 'Standart Soba', 10, 1200, 800);\r\n      const prevDB = makeDB({ products: [soba] });\r\n\r\n      // Sat─▒┼ƒ yap\r\n      const { nextDB: afterSale, saleId, violations: saleViolations } = satisYap(prevDB, [{ productId: 'soba-001', qty: 1 }], 'nakit');\r\n      expect(saleViolations).toHaveLength(0);\r\n\r\n      // Kasa geliri kontrol\r\n      const kasaGelir = afterSale.kasa.filter(k => !k.deleted && k.type === 'gelir').reduce((s, k) => s + k.amount, 0);\r\n      expect(kasaGelir).toBe(1200);\r\n\r\n      // ─░ade yap\r\n      const { nextDB: afterIade, violations: iadeViolations } = iadeYap(afterSale, saleId);\r\n      expect(iadeViolations).toHaveLength(0);\r\n\r\n      // Net kasa s─▒f─▒r olmal─▒\r\n      const netKasa = afterIade.kasa\r\n        .filter(k => !k.deleted)\r\n        .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n      expect(netKasa).toBe(0);\r\n\r\n      // Sat─▒┼ƒ durumu iade olmal─▒\r\n      const sale = afterIade.sales.find(s => s.id === saleId)!;\r\n      expect(sale.status).toBe('iade');\r\n\r\n      // Stok geri y├╝klenmeli\r\n      const product = afterIade.products.find(p => p.id === 'soba-001')!;\r\n      expect(product.stock).toBe(10);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // ≡ƒö¼ Property-Based Tests ΓÇö Global ─░nvariantlar\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('≡ƒö¼ Property-Based Tests ΓÇö Global ─░nvariantlar', () => {\r\n\r\n    /**\r\n     * P1 ΓÇö Kasa Bakiyesi Tutarl─▒l─▒─ƒ─▒\r\n     * Validates: Requirements 2.1, 2.4\r\n     *\r\n     * Herhangi bir kasa kay─▒t dizisi i├ºin, silinmemi┼ƒ kay─▒tlar─▒n\r\n     * toplam─▒ her zaman tutarl─▒ olmal─▒d─▒r.\r\n     */\r\n    it('P1 ΓÇö Kasa Bakiyesi Tutarl─▒l─▒─ƒ─▒: silinmemi┼ƒ kay─▒tlar─▒n toplam─▒ tutarl─▒ olmal─▒', () => {\r\n      fc.assert(\r\n        fc.property(\r\n          fc.array(fc.record({\r\n            type: fc.constantFrom('gelir', 'gider') as fc.Arbitrary<'gelir' | 'gider'>,\r\n            amount: fc.integer({ min: 1, max: 100000 }),\r\n            deleted: fc.boolean(),\r\n          })),\r\n          (entries) => {\r\n            const beklenen = entries\r\n              .filter(e => !e.deleted)\r\n              .reduce((s, e) => s + (e.type === 'gelir' ? e.amount : -e.amount), 0);\r\n            const computed = entries\r\n              .filter(e => !e.deleted)\r\n              .reduce((s, e) => s + (e.type === 'gelir' ? e.amount : -e.amount), 0);\r\n            return computed === beklenen;\r\n          }\r\n        ),\r\n        { numRuns: 100 }\r\n      );\r\n    });\r\n\r\n    /**\r\n     * P2 ΓÇö Stok Negatife D├╝┼ƒmez\r\n     * Validates: Requirements 2.5, 3.1\r\n     *\r\n     * Stok miktar─▒ndan fazla sat─▒┼ƒ yap─▒lmaya ├ºal─▒┼ƒ─▒ld─▒─ƒ─▒nda\r\n     * negative_stock ihlali ├╝retilmeli; aksi h├ólde ihlal olmamal─▒.\r\n     */\r\n    it('P2 ΓÇö Stok Negatife D├╝┼ƒmez: yetersiz stokta negative_stock ihlali ├╝retilmeli', () => {\r\n      fc.assert(\r\n        fc.property(\r\n          fc.integer({ min: 0, max: 200 }),\r\n          fc.integer({ min: 1, max: 300 }),\r\n          (stock, satisMiktari) => {\r\n            const urun = makeProduct('urun-p2', 'Test', stock, 1000, 500);\r\n            const db = makeDB({ products: [urun] });\r\n            const { violations } = satisYap(db, [{ productId: 'urun-p2', qty: satisMiktari }], 'nakit');\r\n            if (satisMiktari > stock) {\r\n              return violations.some(v => v.ruleId === 'negative_stock');\r\n            }\r\n            return violations.length === 0;\r\n          }\r\n        ),\r\n        { numRuns: 100 }\r\n      );\r\n    });\r\n\r\n    /**\r\n     * P3 ΓÇö Sat─▒┼ƒ Toplam Tutarl─▒l─▒─ƒ─▒\r\n     * Validates: Requirements 2.1, 3.2\r\n     *\r\n     * Herhangi bir adet, fiyat, maliyet ve iskonto kombinasyonu i├ºin\r\n     * toplam negatif olmamal─▒ ve k├ór hesab─▒ tutarl─▒ olmal─▒d─▒r.\r\n     */\r\n    it('P3 ΓÇö Sat─▒┼ƒ Toplam Tutarl─▒l─▒─ƒ─▒: total >= 0 ve profit hesab─▒ tutarl─▒ olmal─▒', () => {\r\n      fc.assert(\r\n        fc.property(\r\n          fc.integer({ min: 1, max: 10 }),\r\n          fc.integer({ min: 100, max: 5000 }),\r\n          fc.integer({ min: 0, max: 100 }),\r\n          fc.integer({ min: 0, max: 50 }),\r\n          (qty, price, cost, discPct) => {\r\n            const subtotal = qty * price;\r\n            const discountAmount = subtotal * (discPct / 100);\r\n            const total = subtotal - discountAmount;\r\n            const profit = (price - cost) * qty - discountAmount;\r\n            return total >= 0 && profit === (price - cost) * qty - discountAmount;\r\n          }\r\n        ),\r\n        { numRuns: 100 }\r\n      );\r\n    });\r\n\r\n    /**\r\n     * P4 ΓÇö ─░ade Sonras─▒ S─▒f─▒r Net\r\n     * Validates: Requirements 2.1, 3.5\r\n     *\r\n     * Herhangi bir nakit sat─▒┼ƒ ΓåÆ tam iade senaryosunda\r\n     * net kasa bakiyesi s─▒f─▒r olmal─▒d─▒r.\r\n     */\r\n    it('P4 ΓÇö ─░ade Sonras─▒ S─▒f─▒r Net: nakit sat─▒┼ƒ ΓåÆ iade ΓåÆ net kasa = 0', () => {\r\n      fc.assert(\r\n        fc.property(\r\n          fc.integer({ min: 1, max: 100 }),\r\n          fc.integer({ min: 100, max: 10000 }),\r\n          (qty, price) => {\r\n            const urun = makeProduct('urun-p4', 'Test', qty, price, Math.floor(price * 0.6));\r\n            let db = makeDB({ products: [urun] });\r\n            const { nextDB: afterSale, saleId } = satisYap(db, [{ productId: 'urun-p4', qty }], 'nakit');\r\n            const { nextDB: afterIade } = iadeYap(afterSale, saleId);\r\n            const net = afterIade.kasa\r\n              .filter(k => !k.deleted)\r\n              .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n            return net === 0;\r\n          }\r\n        ),\r\n        { numRuns: 100 }\r\n      );\r\n    });\r\n\r\n  });\r\n\r\n});\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\logger.ts","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement. Only these console methods are allowed: warn, error, info.","line":80,"column":28,"messageId":"limited","endLine":80,"endColumn":41}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * ├£retim s─▒n─▒f─▒ yap─▒land─▒r─▒lm─▒┼ƒ loglama servisi\r\n * - Seviyeler: debug | info | warn | error | critical\r\n * - Kategoriler: auth | firebase | db | ui | sync | health | perf | system\r\n * - localStorage kal─▒c─▒l─▒─ƒ─▒ (maks 500 kay─▒t)\r\n * - Abonelik sistemi (canl─▒ log izleme)\r\n * - Performans zamanlay─▒c─▒lar─▒\r\n */\r\n\r\nexport type LogLevel = 'debug' | 'info' | 'warn' | 'error' | 'critical';\r\nexport type LogCategory = 'auth' | 'firebase' | 'db' | 'ui' | 'sync' | 'health' | 'perf' | 'system' | 'auditEngine' | 'ruleEngine';\r\n\r\nexport interface LogEntry {\r\n  id: string;\r\n  ts: string;\r\n  level: LogLevel;\r\n  cat: LogCategory;\r\n  msg: string;\r\n  data?: unknown;\r\n  sessionId: string;\r\n  ms?: number;\r\n}\r\n\r\nconst LOG_KEY = 'sobaLogs_v2';\r\nconst MAX_LOGS = 500;\r\nconst SESSION_ID = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;\r\n\r\nconst LEVEL_WEIGHT: Record<LogLevel, number> = {\r\n  debug: 0, info: 1, warn: 2, error: 3, critical: 4,\r\n};\r\n\r\nconst LEVEL_COLORS: Record<LogLevel, string> = {\r\n  debug: '#64748b',\r\n  info: '#3b82f6',\r\n  warn: '#f59e0b',\r\n  error: '#ef4444',\r\n  critical: '#dc2626',\r\n};\r\n\r\nlet _minLevel: LogLevel = import.meta.env.DEV ? 'debug' : 'info';\r\nlet _listeners: Array<(entry: LogEntry) => void> = [];\r\nlet _writeBuffer: LogEntry[] = [];\r\nlet _writeTimer: ReturnType<typeof setTimeout> | null = null;\r\n\r\n/** localStorage'a toplu yaz (debounced, 300ms) */\r\nfunction flushBuffer() {\r\n  if (!_writeBuffer.length) return;\r\n  try {\r\n    const raw = localStorage.getItem(LOG_KEY);\r\n    const existing: LogEntry[] = raw ? JSON.parse(raw) : [];\r\n    const merged = [..._writeBuffer, ...existing].slice(0, MAX_LOGS);\r\n    localStorage.setItem(LOG_KEY, JSON.stringify(merged));\r\n    _writeBuffer = [];\r\n  } catch {\r\n    _writeBuffer = [];\r\n  }\r\n}\r\n\r\nfunction scheduleFlush() {\r\n  if (_writeTimer) clearTimeout(_writeTimer);\r\n  _writeTimer = setTimeout(flushBuffer, 300);\r\n}\r\n\r\nfunction emit(level: LogLevel, cat: LogCategory, msg: string, data?: unknown, ms?: number): LogEntry {\r\n  const entry: LogEntry = {\r\n    id: `${Date.now().toString(36)}${Math.random().toString(36).slice(2, 5)}`,\r\n    ts: new Date().toISOString(),\r\n    level, cat, msg, sessionId: SESSION_ID,\r\n    ...(data !== undefined ? { data } : {}),\r\n    ...(ms !== undefined ? { ms } : {}),\r\n  };\r\n\r\n  if (LEVEL_WEIGHT[level] >= LEVEL_WEIGHT[_minLevel]) {\r\n    const prefix = `%c[${level.toUpperCase()}] %c[${cat}] %c${msg}`;\r\n    const styles = [\r\n      `color:${LEVEL_COLORS[level]}; font-weight:bold`,\r\n      'color:#8b5cf6; font-weight:600',\r\n      'color:#cbd5e1',\r\n    ];\r\n    if (level === 'debug') console.debug(prefix, ...styles, data ?? '');\r\n    else if (level === 'info') console.info(prefix, ...styles, data ?? '');\r\n    else if (level === 'warn') console.warn(prefix, ...styles, data ?? '');\r\n    else console.error(prefix, ...styles, data ?? '');\r\n  }\r\n\r\n  _writeBuffer.push(entry);\r\n  scheduleFlush();\r\n\r\n  _listeners.forEach(fn => { try { fn(entry); } catch { /* listener hatas─▒ ana ak─▒┼ƒ─▒ etkilemesin */ } });\r\n\r\n  return entry;\r\n}\r\n\r\nexport const logger = {\r\n  debug:    (cat: LogCategory, msg: string, data?: unknown) => emit('debug',    cat, msg, data),\r\n  info:     (cat: LogCategory, msg: string, data?: unknown) => emit('info',     cat, msg, data),\r\n  warn:     (cat: LogCategory, msg: string, data?: unknown) => emit('warn',     cat, msg, data),\r\n  error:    (cat: LogCategory, msg: string, data?: unknown) => emit('error',    cat, msg, data),\r\n  critical: (cat: LogCategory, msg: string, data?: unknown) => emit('critical', cat, msg, data),\r\n\r\n  /** Performans zamanlay─▒c─▒s─▒: const t = logger.time('perf','etiket'); ... t.end() */\r\n  time(cat: LogCategory, label: string) {\r\n    const start = performance.now();\r\n    return {\r\n      end(data?: unknown) {\r\n        const ms = Math.round(performance.now() - start);\r\n        emit('debug', cat, `ΓÅ▒ ${label} [${ms}ms]`, data, ms);\r\n        return ms;\r\n      },\r\n    };\r\n  },\r\n\r\n  /** Minimum log seviyesini ayarla */\r\n  setLevel(level: LogLevel) { _minLevel = level; },\r\n\r\n  /** Yeni log giri┼ƒlerine abone ol; abonelikten ├º─▒kmak i├ºin d├╢nen fonksiyonu ├ºa─ƒ─▒r */\r\n  subscribe(fn: (entry: LogEntry) => void): () => void {\r\n    _listeners.push(fn);\r\n    return () => { _listeners = _listeners.filter(l => l !== fn); };\r\n  },\r\n\r\n  /** Kay─▒tl─▒ loglar─▒ al ΓÇö opsiyonel filtre ile */\r\n  getLogs(filter?: { level?: LogLevel; cat?: LogCategory; limit?: number; since?: string }): LogEntry[] {\r\n    flushBuffer();\r\n    try {\r\n      const raw = localStorage.getItem(LOG_KEY);\r\n      let logs: LogEntry[] = raw ? JSON.parse(raw) : [];\r\n      if (filter?.level) {\r\n        const minW = LEVEL_WEIGHT[filter.level];\r\n        logs = logs.filter(l => LEVEL_WEIGHT[l.level] >= minW);\r\n      }\r\n      if (filter?.cat)   logs = logs.filter(l => l.cat === filter.cat);\r\n      if (filter?.since) logs = logs.filter(l => l.ts >= filter.since!);\r\n      if (filter?.limit) logs = logs.slice(0, filter.limit);\r\n      return logs;\r\n    } catch { return []; }\r\n  },\r\n\r\n  /** Log say─▒s─▒n─▒ d├╢nd├╝r */\r\n  count(filter?: { level?: LogLevel }): number {\r\n    return this.getLogs(filter).length;\r\n  },\r\n\r\n  /** Loglar─▒ temizle */\r\n  clearLogs() {\r\n    _writeBuffer = [];\r\n    try { localStorage.removeItem(LOG_KEY); } catch { /* ignore */ }\r\n  },\r\n\r\n  /** Mevcut oturum ID'si */\r\n  getSessionId: () => SESSION_ID,\r\n\r\n  /** T├╝m loglar─▒ JSON olarak indir */\r\n  exportLogs() {\r\n    flushBuffer();\r\n    const logs = this.getLogs();\r\n    const blob = new Blob([JSON.stringify(logs, null, 2)], { type: 'application/json' });\r\n    const url = URL.createObjectURL(blob);\r\n    const a = document.createElement('a');\r\n    a.href = url;\r\n    a.download = `soba-logs-${new Date().toISOString().slice(0, 10)}.json`;\r\n    a.click();\r\n    URL.revokeObjectURL(url);\r\n    logger.info('system', 'Loglar d─▒┼ƒa aktar─▒ld─▒', { count: logs.length });\r\n  },\r\n};\r\n\r\n// ΓöÇΓöÇ Global hata yakalay─▒c─▒lar ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nwindow.addEventListener('unhandledrejection', (e) => {\r\n  emit('error', 'system', 'Yakalanmam─▒┼ƒ Promise reddi', {\r\n    reason: e.reason instanceof Error ? e.reason.message : String(e.reason),\r\n    stack: e.reason instanceof Error ? e.reason.stack?.slice(0, 300) : undefined,\r\n  });\r\n});\r\n\r\nwindow.addEventListener('error', (e) => {\r\n  emit('error', 'system', e.message || 'Script hatas─▒', {\r\n    filename: e.filename,\r\n    line: e.lineno,\r\n    col: e.colno,\r\n  });\r\n});\r\n\r\n// Ba┼ƒlang─▒├º kayd─▒\r\nemit('info', 'system', 'Uygulama ba┼ƒlat─▒ld─▒', {\r\n  sessionId: SESSION_ID,\r\n  url: window.location.href,\r\n  ua: navigator.userAgent.slice(0, 80),\r\n  ts: new Date().toISOString(),\r\n});\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\notificationEngine.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\offline-ai.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\permissions.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Directory' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":105,"column":25,"messageId":"unusedVar","endLine":105,"endColumn":34}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Capacitor ─░zin Y├╢neticisi\r\n * Bildirim, dosya sistemi ve di─ƒer izinleri y├╢netir.\r\n * ─░zinler uygulama ba┼ƒlang─▒c─▒nda istenir.\r\n */\r\n\r\nimport { Capacitor } from '@capacitor/core';\r\n\r\n// ΓöÇΓöÇ Bildirim ─░zni ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport async function requestNotificationPermission(): Promise<boolean> {\r\n  if (!Capacitor.isNativePlatform()) {\r\n    // Web: Notification API\r\n    if (!('Notification' in window)) return false;\r\n    if (Notification.permission === 'granted') return true;\r\n    if (Notification.permission === 'denied') return false;\r\n    const result = await Notification.requestPermission();\r\n    return result === 'granted';\r\n  }\r\n\r\n  try {\r\n    const { LocalNotifications } = await import('@capacitor/local-notifications');\r\n    const perm = await LocalNotifications.requestPermissions();\r\n    return perm.display === 'granted';\r\n  } catch {\r\n    return false;\r\n  }\r\n}\r\n\r\n// ΓöÇΓöÇ Yerel Bildirim G├╢nder ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport async function sendLocalNotification(title: string, body: string, id = Date.now()) {\r\n  if (!Capacitor.isNativePlatform()) {\r\n    // Web fallback\r\n    if (Notification.permission === 'granted') {\r\n      new Notification(title, { body, icon: '/pwa-192.png' });\r\n    }\r\n    return;\r\n  }\r\n\r\n  try {\r\n    const { LocalNotifications } = await import('@capacitor/local-notifications');\r\n    await LocalNotifications.schedule({\r\n      notifications: [{\r\n        id,\r\n        title,\r\n        body,\r\n        schedule: { at: new Date(Date.now() + 100) },\r\n        sound: undefined,\r\n        attachments: undefined,\r\n        actionTypeId: '',\r\n        extra: null,\r\n      }],\r\n    });\r\n  } catch (e) {\r\n    console.warn('Bildirim g├╢nderilemedi:', e);\r\n  }\r\n}\r\n\r\n// ΓöÇΓöÇ Dosya Kaydetme (Filesystem) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport async function saveFileToDevice(filename: string, data: string, mimeType = 'application/octet-stream'): Promise<boolean> {\r\n  if (!Capacitor.isNativePlatform()) {\r\n    // Web: blob download\r\n    const blob = new Blob([data], { type: mimeType });\r\n    const url = URL.createObjectURL(blob);\r\n    const a = document.createElement('a');\r\n    a.href = url;\r\n    a.download = filename;\r\n    a.click();\r\n    URL.revokeObjectURL(url);\r\n    return true;\r\n  }\r\n\r\n  try {\r\n    const { Filesystem, Directory } = await import('@capacitor/filesystem');\r\n    await Filesystem.writeFile({\r\n      path: filename,\r\n      data,\r\n      directory: Directory.Documents,\r\n      encoding: 'utf8' as never,\r\n    });\r\n    return true;\r\n  } catch (e) {\r\n    console.warn('Dosya kaydedilemedi:', e);\r\n    return false;\r\n  }\r\n}\r\n\r\n// ΓöÇΓöÇ T├╝m ─░zinleri Ba┼ƒlang─▒├ºta ─░ste ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nexport async function requestAllPermissions(): Promise<void> {\r\n  // Bildirim izni\r\n  await requestNotificationPermission().catch(() => {});\r\n\r\n  if (!Capacitor.isNativePlatform()) return;\r\n\r\n  // Mikrofon izni (sesli AI asistan i├ºin)\r\n  try {\r\n    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });\r\n    stream.getTracks().forEach(t => t.stop()); // hemen kapat, sadece izin al\r\n    console.info('[permissions] Mikrofon izni verildi');\r\n  } catch {\r\n    console.warn('[permissions] Mikrofon izni reddedildi');\r\n  }\r\n\r\n  // Depolama izni (Excel export i├ºin)\r\n  try {\r\n    const { Filesystem, Directory } = await import('@capacitor/filesystem');\r\n    await Filesystem.requestPermissions();\r\n    console.info('[permissions] Depolama izni verildi');\r\n  } catch {\r\n    console.warn('[permissions] Depolama izni reddedildi');\r\n  }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\ruleEngine.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\ruleEngine.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Sale' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":45,"messageId":"unusedVar","endLine":10,"endColumn":49,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Sale"},"fix":{"range":[361,367],"text":""},"desc":"Remove unused variable \"Sale\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * PARSPEL ΓÇö Rule Engine\r\n * save() ├ºa─ƒr─▒s─▒ndan ├╢nce finansal kurallar─▒ senkron olarak de─ƒerlendirir.\r\n * ─░hlal durumunda i┼ƒlemi engeller (severity: 'block') veya uyar─▒r (severity: 'warn').\r\n *\r\n * BFCE ruleRunner pattern'inden uyarlanm─▒┼ƒt─▒r.\r\n * Cloud Functions gerektirmez ΓÇö tamamen client-side ├ºal─▒┼ƒ─▒r.\r\n */\r\n\r\nimport type { DB, RuleViolation, KasaEntry, Sale } from '@/types';\r\nimport { logger } from '@/lib/logger';\r\n\r\n/** Maksimum tek i┼ƒlem tutar─▒ (BFCE TRANSACTION_LIMIT uyarlamas─▒ ΓÇö TRY i├ºin ├╢l├ºeklendirildi) */\r\nexport const TRANSACTION_LIMIT = 100_000;\r\n\r\n/** M├╝kerrer i┼ƒlem kontrol├╝ i├ºin zaman penceresi (ms) */\r\nconst DUPLICATE_WINDOW_MS = 60_000;\r\n\r\n/** validateTransaction i├ºin maksimum ├ºal─▒┼ƒma s├╝resi (ms) */\r\nconst RULE_TIMEOUT_MS = 50;\r\n\r\n// ΓöÇΓöÇΓöÇ Kural Aray├╝z├╝ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ninterface Rule {\r\n  id: string;\r\n  name: string;\r\n  severity: 'block' | 'warn';\r\n  evaluate: (prevDB: DB, nextDB: DB) => RuleViolation[];\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Yard─▒mc─▒: Kasa Bakiyesi Hesapla ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction computeKasaBalances(entries: KasaEntry[]): Map<string, number> {\r\n  const map = new Map<string, number>();\r\n  for (const e of entries) {\r\n    if (e.deleted) continue;\r\n    const cur = map.get(e.kasa) ?? 0;\r\n    map.set(e.kasa, cur + (e.type === 'gelir' ? e.amount : -e.amount));\r\n  }\r\n  return map;\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Kurallar ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * Kural 1: Negatif Stok\r\n * Herhangi bir ├╝r├╝n├╝n stock de─ƒeri 0'─▒n alt─▒na d├╝┼ƒecekse engelle.\r\n */\r\nconst negativeStockRule: Rule = {\r\n  id: 'negative_stock',\r\n  name: 'Negatif Stok',\r\n  severity: 'block',\r\n  evaluate: (_prevDB: DB, nextDB: DB): RuleViolation[] => {\r\n    const violations: RuleViolation[] = [];\r\n    for (const p of nextDB.products) {\r\n      if (!p.deleted && p.stock < 0) {\r\n        violations.push({\r\n          ruleId: 'negative_stock',\r\n          ruleName: 'Negatif Stok',\r\n          message: `\"${p.name}\" sto─ƒu negatife d├╝┼ƒt├╝ (${p.stock}). ─░┼ƒlem engellendi.`,\r\n          severity: 'block',\r\n          relatedIds: [p.id],\r\n        });\r\n      }\r\n    }\r\n    return violations;\r\n  },\r\n};\r\n\r\n/**\r\n * Kural 2: Negatif Kasa Bakiyesi\r\n * Herhangi bir kasan─▒n hesaplanan bakiyesi 0'─▒n alt─▒na d├╝┼ƒecekse engelle.\r\n */\r\nconst negativeKasaRule: Rule = {\r\n  id: 'negative_kasa',\r\n  name: 'Negatif Kasa Bakiyesi',\r\n  severity: 'block',\r\n  evaluate: (_prevDB: DB, nextDB: DB): RuleViolation[] => {\r\n    const violations: RuleViolation[] = [];\r\n    const balances = computeKasaBalances(nextDB.kasa);\r\n    for (const [kasaId, balance] of balances) {\r\n      if (balance < -0.001) {\r\n        violations.push({\r\n          ruleId: 'negative_kasa',\r\n          ruleName: 'Negatif Kasa Bakiyesi',\r\n          message: `\"${kasaId}\" kasas─▒ negatife d├╝┼ƒt├╝ (${balance.toFixed(2)} Γé║). ─░┼ƒlem engellendi.`,\r\n          severity: 'block',\r\n          relatedIds: [kasaId],\r\n        });\r\n      }\r\n    }\r\n    return violations;\r\n  },\r\n};\r\n\r\n/**\r\n * Kural 3: M├╝kerrer ─░┼ƒlem\r\n * Ayn─▒ cariId + amount + kasa kombinasyonu son 60 saniyede mevcutsa uyar.\r\n * (severity: 'warn' ΓÇö i┼ƒlemi engellemez, sadece uyar─▒r)\r\n */\r\nconst duplicateTransactionRule: Rule = {\r\n  id: 'duplicate_transaction',\r\n  name: 'M├╝kerrer ─░┼ƒlem',\r\n  severity: 'warn',\r\n  evaluate: (prevDB: DB, nextDB: DB): RuleViolation[] => {\r\n    const violations: RuleViolation[] = [];\r\n    const now = Date.now();\r\n    const windowStart = now - DUPLICATE_WINDOW_MS;\r\n\r\n    // nextDB'de prevDB'de olmayan yeni kasa kay─▒tlar─▒n─▒ bul\r\n    const prevIds = new Set(prevDB.kasa.map(k => k.id));\r\n    const newEntries = nextDB.kasa.filter(k => !prevIds.has(k.id) && !k.deleted);\r\n\r\n    for (const newEntry of newEntries) {\r\n      if (!newEntry.cariId || !newEntry.amount) continue;\r\n\r\n      // Son 60 saniyede ayn─▒ cariId + amount + kasa kombinasyonu var m─▒?\r\n      const duplicate = prevDB.kasa.find(k =>\r\n        !k.deleted &&\r\n        k.cariId === newEntry.cariId &&\r\n        k.amount === newEntry.amount &&\r\n        k.kasa === newEntry.kasa &&\r\n        new Date(k.createdAt).getTime() > windowStart\r\n      );\r\n\r\n      if (duplicate) {\r\n        violations.push({\r\n          ruleId: 'duplicate_transaction',\r\n          ruleName: 'M├╝kerrer ─░┼ƒlem',\r\n          message: `Son 60 saniyede ayn─▒ cari (${newEntry.cariId}), tutar (${newEntry.amount} Γé║) ve kasa (${newEntry.kasa}) kombinasyonu zaten kaydedildi. M├╝kerrer i┼ƒlem olabilir.`,\r\n          severity: 'warn',\r\n          relatedIds: [duplicate.id, newEntry.id],\r\n        });\r\n      }\r\n    }\r\n    return violations;\r\n  },\r\n};\r\n\r\n/**\r\n * Kural 4: S─▒f─▒r veya Negatif Tutar\r\n * KasaEntry.amount <= 0 veya Sale.total <= 0 olan i┼ƒlemleri engelle.\r\n * (BFCE limitRule uyarlamas─▒)\r\n */\r\nconst zeroAmountRule: Rule = {\r\n  id: 'zero_amount',\r\n  name: 'S─▒f─▒r veya Negatif Tutar',\r\n  severity: 'block',\r\n  evaluate: (prevDB: DB, nextDB: DB): RuleViolation[] => {\r\n    const violations: RuleViolation[] = [];\r\n    const prevKasaIds = new Set(prevDB.kasa.map(k => k.id));\r\n    const prevSaleIds = new Set(prevDB.sales.map(s => s.id));\r\n\r\n    // Yeni kasa kay─▒tlar─▒nda s─▒f─▒r/negatif tutar kontrol├╝\r\n    for (const k of nextDB.kasa) {\r\n      if (!prevKasaIds.has(k.id) && !k.deleted && k.amount <= 0) {\r\n        violations.push({\r\n          ruleId: 'zero_amount',\r\n          ruleName: 'S─▒f─▒r veya Negatif Tutar',\r\n          message: `Kasa kayd─▒ ge├ºersiz tutar i├ºeriyor (${k.amount} Γé║). Tutar 0'dan b├╝y├╝k olmal─▒d─▒r.`,\r\n          severity: 'block',\r\n          relatedIds: [k.id],\r\n        });\r\n      }\r\n    }\r\n\r\n    // Yeni sat─▒┼ƒlarda s─▒f─▒r/negatif toplam kontrol├╝\r\n    for (const s of nextDB.sales) {\r\n      if (!prevSaleIds.has(s.id) && !s.deleted && s.total <= 0) {\r\n        violations.push({\r\n          ruleId: 'zero_amount',\r\n          ruleName: 'S─▒f─▒r veya Negatif Tutar',\r\n          message: `Sat─▒┼ƒ kayd─▒ ge├ºersiz toplam i├ºeriyor (${s.total} Γé║). Toplam 0'dan b├╝y├╝k olmal─▒d─▒r.`,\r\n          severity: 'block',\r\n          relatedIds: [s.id],\r\n        });\r\n      }\r\n    }\r\n\r\n    return violations;\r\n  },\r\n};\r\n\r\n// ΓöÇΓöÇΓöÇ Kural Listesi (geni┼ƒletilebilir) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * Aktif kural listesi.\r\n * Yeni kural eklemek i├ºin bu diziye Rule nesnesi ekle ΓÇö ba┼ƒka dosya de─ƒi┼ƒikli─ƒi gerekmez.\r\n */\r\nexport const rules: Rule[] = [\r\n  negativeStockRule,\r\n  negativeKasaRule,\r\n  duplicateTransactionRule,\r\n  zeroAmountRule,\r\n];\r\n\r\n// ΓöÇΓöÇΓöÇ Ana Fonksiyon ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\n/**\r\n * T├╝m kurallar─▒ ├ºal─▒┼ƒt─▒r─▒r ve ihlalleri d├╢nd├╝r├╝r.\r\n *\r\n * - Senkron ├ºal─▒┼ƒ─▒r (async/await yok)\r\n * - 50ms timeout korumal─▒\r\n * - Her kural kendi try/catch blo─ƒuna sahip\r\n * - T├╝m fonksiyon try/catch ile sar─▒l─▒ ΓÇö hata durumunda bo┼ƒ dizi d├╢ner\r\n *\r\n * @param prevDB - G├╝ncelleme ├╢ncesi DB durumu\r\n * @param nextDB - G├╝ncelleme sonras─▒ DB durumu (updater(prevDB) sonucu)\r\n * @returns ─░hlal listesi ΓÇö bo┼ƒsa kural ihlali yok\r\n */\r\nexport function validateTransaction(prevDB: DB, nextDB: DB): RuleViolation[] {\r\n  const startTime = performance.now();\r\n\r\n  try {\r\n    const allViolations: RuleViolation[] = [];\r\n\r\n    for (const rule of rules) {\r\n      // Timeout kontrol├╝\r\n      if (performance.now() - startTime > RULE_TIMEOUT_MS) {\r\n        logger.warn('ruleEngine', `Kural de─ƒerlendirmesi ${RULE_TIMEOUT_MS}ms s─▒n─▒r─▒n─▒ a┼ƒt─▒ ΓÇö kalan kurallar atland─▒`, {\r\n          completedRules: allViolations.length,\r\n          remainingRules: rules.length,\r\n        });\r\n        break;\r\n      }\r\n\r\n      try {\r\n        const violations = rule.evaluate(prevDB, nextDB);\r\n        allViolations.push(...violations);\r\n      } catch (ruleError) {\r\n        // Tek bir kural─▒n hatas─▒ di─ƒer kurallar─▒ etkilemez\r\n        logger.warn('ruleEngine', `Kural \"${rule.id}\" de─ƒerlendirme hatas─▒ ΓÇö atland─▒`, {\r\n          error: String(ruleError),\r\n        });\r\n      }\r\n    }\r\n\r\n    return allViolations;\r\n  } catch (e) {\r\n    // T├╝m fonksiyon hatas─▒ ΓÇö fail-open: bo┼ƒ dizi d├╢nd├╝r, uygulama ├º├╢kmez\r\n    logger.warn('ruleEngine', 'validateTransaction beklenmedik hata ΓÇö kural de─ƒerlendirmesi atland─▒', {\r\n      error: String(e),\r\n    });\r\n    return [];\r\n  }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\safeXlsx.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\similarity.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\similarity.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\soba-satis-senaryosu.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\userManager.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\utils-tr.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\utils-tr.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\lib\\uygulama-gercek.test.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Supplier' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":66,"messageId":"unusedVar","endLine":10,"endColumn":74,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Supplier"},"fix":{"range":[379,389],"text":""},"desc":"Remove unused variable \"Supplier\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Order' is defined but never used. Allowed unused vars must match /^_/u.","line":10,"column":76,"messageId":"unusedVar","endLine":10,"endColumn":81,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Order"},"fix":{"range":[389,396],"text":""},"desc":"Remove unused variable \"Order\"."}]},{"ruleId":"prefer-const","severity":1,"message":"'violations' is never reassigned. Use 'const' instead.","line":337,"column":9,"messageId":"useConst","endLine":337,"endColumn":59,"fix":{"range":[9095,9155],"text":"const violations: ReturnType<typeof validateTransaction> = [];"}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":1,"source":"/**\r\n * ≡ƒÅ¬ Ger├ºek Uygulama Entegrasyon Testleri\r\n *\r\n * Tam i┼ƒ g├╝n├╝ senaryosu: a├º─▒l─▒┼ƒ ΓåÆ sat─▒┼ƒlar ΓåÆ tedarik ├╢demesi ΓåÆ tahsilat ΓåÆ kapan─▒┼ƒ.\r\n * Pattern: prevDB ΓåÆ i┼ƒlem ΓåÆ nextDB, rule engine her ad─▒mda ├ºal─▒┼ƒ─▒r.\r\n */\r\n\r\nimport { describe, it, expect } from 'vitest';\r\nimport { validateTransaction } from './ruleEngine';\r\nimport type { DB, Product, Sale, KasaEntry, Cari, StockMovement, Supplier, Order } from '@/types';\r\n\r\n// ΓöÇΓöÇΓöÇ Yard─▒mc─▒lar ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction genId(): string {\r\n  return Math.random().toString(36).slice(2, 10) + Math.random().toString(36).slice(2, 10);\r\n}\r\n\r\nfunction now(): string {\r\n  return new Date().toISOString();\r\n}\r\n\r\nfunction makeDB(overrides: Partial<DB> = {}): DB {\r\n  return {\r\n    _version: 1,\r\n    products: [],\r\n    sales: [],\r\n    suppliers: [],\r\n    orders: [],\r\n    cari: [],\r\n    kasa: [],\r\n    kasalar: [\r\n      { id: 'nakit', name: 'Nakit', icon: '≡ƒÆ╡' },\r\n      { id: 'banka', name: 'Banka', icon: '≡ƒÅª' },\r\n      { id: 'pos', name: 'POS', icon: '≡ƒÆ│' },\r\n    ],\r\n    bankTransactions: [],\r\n    matchRules: [],\r\n    monitorRules: [],\r\n    monitorLog: [],\r\n    stockMovements: [],\r\n    peletSuppliers: [],\r\n    peletOrders: [],\r\n    boruSuppliers: [],\r\n    boruOrders: [],\r\n    invoices: [],\r\n    budgets: [],\r\n    returns: [],\r\n    _activityLog: [],\r\n    _auditLog: [],\r\n    company: { id: 'c1', createdAt: now() },\r\n    settings: {},\r\n    pelletSettings: { gramaj: 14, kgFiyat: 6.5, cuvalKg: 15, critDays: 3 },\r\n    ortakEmanetler: [],\r\n    installments: [],\r\n    partners: [],\r\n    productCategories: [],\r\n    notes: [],\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nfunction makeProduct(\r\n  id: string,\r\n  name: string,\r\n  stock: number,\r\n  price: number,\r\n  cost: number,\r\n  category = 'soba'\r\n): Product {\r\n  return {\r\n    id,\r\n    name,\r\n    category,\r\n    cost,\r\n    price,\r\n    stock,\r\n    minStock: 2,\r\n    deleted: false,\r\n    createdAt: now(),\r\n    updatedAt: now(),\r\n  };\r\n}\r\n\r\nfunction makeCari(id: string, name: string, balance = 0): Cari {\r\n  return {\r\n    id,\r\n    name,\r\n    type: 'musteri',\r\n    balance,\r\n    deleted: false,\r\n    createdAt: now(),\r\n    updatedAt: now(),\r\n  };\r\n}\r\n\r\n/** Nakit / kart / banka sat─▒┼ƒ─▒ sim├╝le eder */\r\nfunction satisYap(\r\n  prevDB: DB,\r\n  productId: string,\r\n  adet: number,\r\n  odeme: 'nakit' | 'banka' | 'pos'\r\n): { nextDB: DB; violations: ReturnType<typeof validateTransaction>; saleId: string } {\r\n  const product = prevDB.products.find(p => p.id === productId)!;\r\n  const saleId = genId();\r\n  const nowIso = now();\r\n  const total = product.price * adet;\r\n  const profit = (product.price - product.cost) * adet;\r\n\r\n  const sale: Sale = {\r\n    id: saleId,\r\n    productId: product.id,\r\n    productName: product.name,\r\n    productCategory: product.category,\r\n    quantity: adet,\r\n    unitPrice: product.price,\r\n    cost: product.cost,\r\n    discount: 0,\r\n    discountAmount: 0,\r\n    subtotal: total,\r\n    total,\r\n    profit,\r\n    payment: odeme,\r\n    status: 'tamamlandi',\r\n    items: [{ productId: product.id, productName: product.name, quantity: adet, unitPrice: product.price, cost: product.cost, total }],\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: genId(),\r\n    type: 'gelir',\r\n    category: 'satis',\r\n    amount: total,\r\n    kasa: odeme,\r\n    description: `Sat─▒┼ƒ: ${product.name} x${adet}`,\r\n    relatedId: saleId,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const stokHareket: StockMovement = {\r\n    id: genId(),\r\n    productId: product.id,\r\n    productName: product.name,\r\n    type: 'satis',\r\n    amount: -adet,\r\n    before: product.stock,\r\n    after: product.stock - adet,\r\n    note: `Sat─▒┼ƒ x${adet}`,\r\n    date: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    sales: [...prevDB.sales, sale],\r\n    products: prevDB.products.map(p =>\r\n      p.id === productId ? { ...p, stock: p.stock - adet, updatedAt: nowIso } : p\r\n    ),\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n    stockMovements: [...prevDB.stockMovements, stokHareket],\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations, saleId };\r\n}\r\n\r\n/** Cari (veresiye) sat─▒┼ƒ sim├╝le eder */\r\nfunction cariSatisYap(\r\n  prevDB: DB,\r\n  productId: string,\r\n  adet: number,\r\n  cariId: string\r\n): { nextDB: DB; violations: ReturnType<typeof validateTransaction>; saleId: string } {\r\n  const product = prevDB.products.find(p => p.id === productId)!;\r\n  const saleId = genId();\r\n  const nowIso = now();\r\n  const total = product.price * adet;\r\n  const profit = (product.price - product.cost) * adet;\r\n\r\n  const sale: Sale = {\r\n    id: saleId,\r\n    productId: product.id,\r\n    productName: product.name,\r\n    productCategory: product.category,\r\n    cariId,\r\n    cariName: prevDB.cari.find(c => c.id === cariId)?.name,\r\n    quantity: adet,\r\n    unitPrice: product.price,\r\n    cost: product.cost,\r\n    discount: 0,\r\n    discountAmount: 0,\r\n    subtotal: total,\r\n    total,\r\n    profit,\r\n    payment: 'cari',\r\n    status: 'tamamlandi',\r\n    items: [{ productId: product.id, productName: product.name, quantity: adet, unitPrice: product.price, cost: product.cost, total }],\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const stokHareket: StockMovement = {\r\n    id: genId(),\r\n    productId: product.id,\r\n    productName: product.name,\r\n    type: 'satis',\r\n    amount: -adet,\r\n    before: product.stock,\r\n    after: product.stock - adet,\r\n    note: `Cari sat─▒┼ƒ x${adet}`,\r\n    date: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    sales: [...prevDB.sales, sale],\r\n    products: prevDB.products.map(p =>\r\n      p.id === productId ? { ...p, stock: p.stock - adet, updatedAt: nowIso } : p\r\n    ),\r\n    kasa: prevDB.kasa, // cari sat─▒┼ƒta kasaya nakit girmez\r\n    stockMovements: [...prevDB.stockMovements, stokHareket],\r\n    cari: prevDB.cari.map(c =>\r\n      c.id === cariId\r\n        ? { ...c, balance: (c.balance || 0) + total, lastTransaction: nowIso, updatedAt: nowIso }\r\n        : c\r\n    ),\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations, saleId };\r\n}\r\n\r\n/** Tahsilat sim├╝le eder (cari bakiyesini d├╝┼ƒ├╝r├╝r, kasaya nakit girer) */\r\nfunction tahsilatYap(\r\n  prevDB: DB,\r\n  cariId: string,\r\n  amount: number,\r\n  kasa: 'nakit' | 'banka'\r\n): { nextDB: DB; violations: ReturnType<typeof validateTransaction> } {\r\n  const nowIso = now();\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: genId(),\r\n    type: 'gelir',\r\n    category: 'tahsilat',\r\n    amount,\r\n    kasa,\r\n    description: `Tahsilat: ${prevDB.cari.find(c => c.id === cariId)?.name || cariId}`,\r\n    cariId,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n    cari: prevDB.cari.map(c =>\r\n      c.id === cariId\r\n        ? { ...c, balance: (c.balance || 0) - amount, lastTransaction: nowIso, updatedAt: nowIso }\r\n        : c\r\n    ),\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations };\r\n}\r\n\r\n/** Gider kayd─▒ sim├╝le eder (kira, elektrik, tedarik├ºi ├╢demesi vb.) */\r\nfunction giderEkle(\r\n  prevDB: DB,\r\n  amount: number,\r\n  kasa: 'nakit' | 'banka',\r\n  aciklama: string\r\n): { nextDB: DB; violations: ReturnType<typeof validateTransaction> } {\r\n  const nowIso = now();\r\n\r\n  const kasaEntry: KasaEntry = {\r\n    id: genId(),\r\n    type: 'gider',\r\n    category: 'genel',\r\n    amount,\r\n    kasa,\r\n    description: aciklama,\r\n    createdAt: nowIso,\r\n    updatedAt: nowIso,\r\n  };\r\n\r\n  const nextDB: DB = {\r\n    ...prevDB,\r\n    kasa: [...prevDB.kasa, kasaEntry],\r\n  };\r\n\r\n  const violations = validateTransaction(prevDB, nextDB);\r\n  return { nextDB, violations };\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ Yard─▒mc─▒: Kasa bakiyesi hesapla ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\nfunction kasaBakiyesi(db: DB, kasaId: string): number {\r\n  return db.kasa\r\n    .filter(k => !k.deleted && k.kasa === kasaId)\r\n    .reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n}\r\n\r\n// ΓöÇΓöÇΓöÇ TESTLER ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\n\r\ndescribe('≡ƒÅ¬ Ger├ºek Uygulama Entegrasyon Testleri', () => {\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Senaryo 1: Tam ─░┼ƒ G├╝n├╝ Ak─▒┼ƒ─▒\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Senaryo 1: Tam i┼ƒ g├╝n├╝ ΓÇö a├º─▒l─▒┼ƒ ΓåÆ sat─▒┼ƒlar ΓåÆ tahsilat ΓåÆ kapan─▒┼ƒ', () => {\r\n    // Ba┼ƒlang─▒├º: 30 soba (1.200 Γé║/ad), nakit kasada 5.000 Γé║ a├º─▒l─▒┼ƒ bakiyesi\r\n    const soba = makeProduct('soba-001', 'Standart Soba', 30, 1_200, 800);\r\n    const musteri = makeCari('cari-001', 'Mehmet Demir', 0);\r\n\r\n    // A├º─▒l─▒┼ƒ kasas─▒\r\n    const acilisKasaEntry: KasaEntry = {\r\n      id: 'acilis-001',\r\n      type: 'gelir',\r\n      category: 'acilis',\r\n      amount: 5_000,\r\n      kasa: 'nakit',\r\n      description: 'G├╝n ba┼ƒ─▒ a├º─▒l─▒┼ƒ bakiyesi',\r\n      createdAt: now(),\r\n      updatedAt: now(),\r\n    };\r\n\r\n    let db = makeDB({\r\n      products: [soba],\r\n      cari: [musteri],\r\n      kasa: [acilisKasaEntry],\r\n    });\r\n\r\n    // Sabah: 3 nakit soba sat─▒┼ƒ─▒\r\n    let violations: ReturnType<typeof validateTransaction> = [];\r\n\r\n    const sabahSatis1 = satisYap(db, 'soba-001', 2, 'nakit');\r\n    violations.push(...sabahSatis1.violations);\r\n    db = sabahSatis1.nextDB;\r\n\r\n    const sabahSatis2 = satisYap(db, 'soba-001', 1, 'banka');\r\n    violations.push(...sabahSatis2.violations);\r\n    db = sabahSatis2.nextDB;\r\n\r\n    // ├û─ƒlen: Cari sat─▒┼ƒ (5 soba veresiye)\r\n    const oglenSatis = cariSatisYap(db, 'soba-001', 5, 'cari-001');\r\n    violations.push(...oglenSatis.violations);\r\n    db = oglenSatis.nextDB;\r\n\r\n    // ├û─ƒle aras─▒: elektrik faturas─▒ gideri\r\n    const gider1 = giderEkle(db, 1_500, 'nakit', 'Elektrik faturas─▒');\r\n    violations.push(...gider1.violations);\r\n    db = gider1.nextDB;\r\n\r\n    // Ak┼ƒam: Tahsilat (Mehmet Demir 3.000 Γé║ ├╢d├╝yor)\r\n    const tahsilat1 = tahsilatYap(db, 'cari-001', 3_000, 'nakit');\r\n    violations.push(...tahsilat1.violations);\r\n    db = tahsilat1.nextDB;\r\n\r\n    // Son pos sat─▒┼ƒ─▒\r\n    const aksamSatis = satisYap(db, 'soba-001', 1, 'pos');\r\n    violations.push(...aksamSatis.violations);\r\n    db = aksamSatis.nextDB;\r\n\r\n    it('g├╝n boyunca kural ihlali olmamal─▒', () => {\r\n      expect(violations).toHaveLength(0);\r\n    });\r\n\r\n    it('toplam sat─▒┼ƒ adedi 9 olmal─▒ (2+1+5+1)', () => {\r\n      expect(db.sales).toHaveLength(4); // 4 sat─▒┼ƒ i┼ƒlemi\r\n      const toplamAdet = db.sales.reduce((s, sale) => s + sale.quantity, 0);\r\n      expect(toplamAdet).toBe(9);\r\n    });\r\n\r\n    it('stok 30 ΓåÆ 21 olmal─▒ (9 soba sat─▒ld─▒)', () => {\r\n      const s = db.products.find(p => p.id === 'soba-001')!;\r\n      expect(s.stock).toBe(21);\r\n    });\r\n\r\n    it('nakit kasa: 5000 + 2400 - 1500 + 3000 = 8900 Γé║', () => {\r\n      // acilis: +5000, sabahSatis1 (2├ù1200=2400): +2400, gider1: -1500, tahsilat1: +3000\r\n      expect(kasaBakiyesi(db, 'nakit')).toBe(8_900);\r\n    });\r\n\r\n    it('banka kasa: sabahSatis2 (1200) = 1200 Γé║', () => {\r\n      expect(kasaBakiyesi(db, 'banka')).toBe(1_200);\r\n    });\r\n\r\n    it('pos kasa: aksamSatis (1200) = 1200 Γé║', () => {\r\n      expect(kasaBakiyesi(db, 'pos')).toBe(1_200);\r\n    });\r\n\r\n    it('cari bakiyesi: 6000 (5 soba veresiye) - 3000 (tahsilat) = 3000 Γé║', () => {\r\n      const cari = db.cari.find(c => c.id === 'cari-001')!;\r\n      expect(cari.balance).toBe(3_000);\r\n    });\r\n\r\n    it('stok hareketleri 4 kay─▒t i├ºermeli (her sat─▒┼ƒ i├ºin 1)', () => {\r\n      expect(db.stockMovements).toHaveLength(4);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Senaryo 2: Yetersiz kasa bakiyesi ile gider ekleme engeli\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Senaryo 2: Kasa bakiyesi yetersizken gider ekleme engellenir', () => {\r\n    // Kasada sadece 500 Γé║ var, 1000 Γé║ gider girilmeye ├ºal─▒┼ƒ─▒l─▒yor\r\n    const acilisKasa: KasaEntry = {\r\n      id: 'acilis-002',\r\n      type: 'gelir',\r\n      category: 'acilis',\r\n      amount: 500,\r\n      kasa: 'nakit',\r\n      description: 'A├º─▒l─▒┼ƒ',\r\n      createdAt: now(),\r\n      updatedAt: now(),\r\n    };\r\n    const db0 = makeDB({ kasa: [acilisKasa] });\r\n\r\n    const { violations } = giderEkle(db0, 1_000, 'nakit', 'Kira ├╢demesi');\r\n\r\n    it('negative_kasa ihlali ├╝retmeli', () => {\r\n      expect(violations.some(v => v.ruleId === 'negative_kasa')).toBe(true);\r\n    });\r\n\r\n    it('ihlal severity block olmal─▒', () => {\r\n      const v = violations.find(v => v.ruleId === 'negative_kasa')!;\r\n      expect(v.severity).toBe('block');\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Senaryo 3: ├çoklu ├╝r├╝n sat─▒┼ƒ─▒ ve stok tutarl─▒l─▒─ƒ─▒\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n\r\n  describe('Senaryo 3: ─░ki farkl─▒ ├╝r├╝n, ba─ƒ─▒ms─▒z stok takibi', () => {\r\n    const boru = makeProduct('boru-001', 'Baca Borusu', 50, 200, 120, 'aksesuar');\r\n    const soba = makeProduct('soba-002', 'L├╝ks Soba', 10, 3_000, 2_000);\r\n    let db = makeDB({ products: [boru, soba] });\r\n\r\n    const s1 = satisYap(db, 'boru-001', 10, 'nakit');\r\n    db = s1.nextDB;\r\n    const s2 = satisYap(db, 'soba-002', 3, 'banka');\r\n    db = s2.nextDB;\r\n\r\n    it('boru stok 50 ΓåÆ 40 olmal─▒', () => {\r\n      expect(db.products.find(p => p.id === 'boru-001')!.stock).toBe(40);\r\n    });\r\n\r\n    it('soba stok 10 ΓåÆ 7 olmal─▒', () => {\r\n      expect(db.products.find(p => p.id === 'soba-002')!.stock).toBe(7);\r\n    });\r\n\r\n    it('nakit kasada 10 ├ù 200 = 2000 Γé║ olmal─▒', () => {\r\n      expect(kasaBakiyesi(db, 'nakit')).toBe(2_000);\r\n    });\r\n\r\n    it('banka kasada 3 ├ù 3000 = 9000 Γé║ olmal─▒', () => {\r\n      expect(kasaBakiyesi(db, 'banka')).toBe(9_000);\r\n    });\r\n\r\n    it('toplam k├ór: (10├ù80) + (3├ù1000) = 800 + 3000 = 3800 Γé║', () => {\r\n      const toplamKar = db.sales.reduce((s, sale) => s + sale.profit, 0);\r\n      expect(toplamKar).toBe(3_800);\r\n    });\r\n\r\n    it('iki ayr─▒ sat─▒┼ƒ i├ºin kural ihlali olmamal─▒', () => {\r\n      expect([...s1.violations, ...s2.violations]).toHaveLength(0);\r\n    });\r\n  });\r\n\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ\r\n  // Senaryo 4: Ard─▒┼ƒ─▒k tahsilat ak─▒┼ƒ─▒ ΓÇö cari bakiye s─▒f─▒ra iner\r\n  // ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓò