},\r\n  { id: 'baglantilar', icon: '≡ƒöî', label: 'Ba─ƒlant─▒lar' },\r\n  { id: 'company', icon: '≡ƒÅó', label: '┼₧irket' },\r\n  { id: 'categories', icon: '≡ƒÅ╖∩╕Å', label: 'Kategoriler' },\r\n  { id: 'pellet', icon: '≡ƒ¬╡', label: 'Pelet' },\r\n  { id: 'sound', icon: '≡ƒöè', label: 'Ses' },\r\n  { id: 'backup', icon: '≡ƒÆ╛', label: 'Yedek & Geri Y├╝kleme' },\r\n  { id: 'excel_export', icon: '≡ƒôè', label: 'Excel ├ç─▒kt─▒' },\r\n  { id: 'activity', icon: '≡ƒôï', label: 'Aktivite' },\r\n  { id: 'shortcuts', icon: 'Γî¿∩╕Å', label: 'K─▒sayollar' },\r\n  { id: 'repair', icon: '≡ƒöº', label: 'Veri Onar─▒m' },\r\n  { id: 'excel', icon: '≡ƒôÑ', label: 'Excel ─░├ºe Aktar' },\r\n  { id: 'data', icon: '≡ƒùä∩╕Å', label: 'Veri Y├╢netimi' },\r\n  { id: 'security', icon: '≡ƒöÉ', label: 'G├╝venlik' },\r\n  { id: 'sysmap', icon: '≡ƒù║∩╕Å', label: 'Sistem Haritas─▒' },\r\n  { id: 'about', icon: 'Γä╣∩╕Å', label: 'Hakk─▒nda' },\r\n] as const;\r\n\r\ntype Tab = typeof TABS_LIST[number]['id'];\r\n\r\nfunction loadSoundSettings(): SoundSettings {\r\n  try {\r\n    const raw = localStorage.getItem('sobaYonetim');\r\n    if (!raw) return { enabled: true, volume: 0.5, theme: 'standart' };\r\n    const parsed = JSON.parse(raw);\r\n    return { enabled: true, volume: 0.5, theme: 'standart', ...(parsed.soundSettings || {}) };\r\n  } catch {\r\n    return { enabled: true, volume: 0.5, theme: 'standart' };\r\n  }\r\n}\r\n\r\nfunction saveSoundSettingsToStorage(settings: SoundSettings) {\r\n  try {\r\n    const raw = localStorage.getItem('sobaYonetim');\r\n    const parsed = raw ? JSON.parse(raw) : {};\r\n    parsed.soundSettings = settings;\r\n    localStorage.setItem('sobaYonetim', JSON.stringify(parsed));\r\n  } catch { /* localStorage yazma hatas─▒ ΓÇö sessizce ge├º */ }\r\n}\r\n\r\nexport default function Settings({ db, save, exportJSON, importJSON }: Props) {\r\n  const { showToast: _showToast } = useToast();\r\n  const showToast = _showToast as (m: string, t?: string) => void;\r\n  const { showConfirm } = useConfirm();\r\n  const { playSound } = useSoundFeedback();\r\n  const [company, setCompany] = useState(() => {\r\n    // db.company bo┼ƒsa db.settings'den doldur (setup wizard buraya yazar)\r\n    const s = db.settings as Record<string, string> | undefined;\r\n    return {\r\n      ...db.company,\r\n      name: db.company.name || s?.companyName || '',\r\n      city: (db.company as any).city || s?.city || '',\r\n    };\r\n  });\r\n  const [pellet, setPellet] = useState({ ...db.pelletSettings });\r\n  const [tab, setTab] = useState<Tab>('arayuz');\r\n  const [uiPrefs, setUiPrefs] = useState<UIPrefs>(loadUIPrefs);\r\n  const [connCfg, setConnCfg] = useState<ConnConfig>(loadConnConfig);\r\n\r\n  const saveCompany = () => {\r\n    save(prev => ({\r\n      ...prev,\r\n      company: { ...company, id: prev.company.id, createdAt: prev.company.createdAt },\r\n      settings: { ...prev.settings, companyName: company.name, city: (company as any).city || '' },\r\n    }));\r\n    showToast('┼₧irket bilgileri kaydedildi!', 'success');\r\n  };\r\n\r\n  const savePellet = () => {\r\n    save(prev => ({ ...prev, pelletSettings: { ...pellet } }));\r\n    showToast('Pelet ayarlar─▒ kaydedildi!', 'success');\r\n  };\r\n\r\n  const clearData = () => {\r\n    showConfirm('T├╝m Verileri Sil', 'T├£M verileriniz kal─▒c─▒ olarak silinecek! Bu i┼ƒlem geri al─▒namaz. Emin misiniz?', () => {\r\n      localStorage.removeItem('sobaYonetim');\r\n      window.location.reload();\r\n    }, true);\r\n  };\r\n\r\n  const dataStats = [\r\n    { label: '├£r├╝nler', count: db.products.length, icon: '≡ƒôª' },\r\n    { label: 'Sat─▒┼ƒlar', count: db.sales.length, icon: '≡ƒ¢Æ' },\r\n    { label: 'Tedarik├ºiler', count: db.suppliers.length, icon: '≡ƒÅ¡' },\r\n    { label: 'Cari Hesaplar', count: db.cari.length, icon: '≡ƒæñ' },\r\n    { label: 'Kasa ─░┼ƒlemleri', count: db.kasa.length, icon: '≡ƒÆ░' },\r\n    { label: 'Banka ─░┼ƒlemleri', count: db.bankTransactions.length, icon: '≡ƒÅª' },\r\n    { label: 'Pelet Tedarik├ºi', count: db.peletSuppliers.length, icon: '≡ƒ¬╡' },\r\n    { label: 'Boru Tedarik├ºi', count: db.boruSuppliers.length, icon: '≡ƒö⌐' },\r\n  ];\r\n\r\n  const totalRecords = dataStats.reduce((s, d) => s + d.count, 0);\r\n\r\n  const shortcuts = [\r\n    { key: 'Ctrl + 1', desc: '├ûzet (Dashboard)' },\r\n    { key: 'Ctrl + 2', desc: '├£r├╝nler' },\r\n    { key: 'Ctrl + 3', desc: 'Sat─▒┼ƒ' },\r\n    { key: 'Ctrl + 4', desc: 'Kasa' },\r\n    { key: 'Ctrl + 5', desc: 'Raporlar' },\r\n    { key: '+ Butonu', desc: 'H─▒zl─▒ Eylem Men├╝s├╝ (sa─ƒ alt)' },\r\n    { key: 'Ctrl + Z', desc: 'Geri Al (taray─▒c─▒ d├╝zeyi)' },\r\n  ];\r\n\r\n  return (\r\n    <div style={{ maxWidth: 720 }}>\r\n      <div style={{ display: 'flex', gap: 6, marginBottom: 24, flexWrap: 'wrap', background: 'rgba(0,0,0,0.2)', borderRadius: 12, padding: 6, width: 'fit-content' }}>\r\n        {TABS_LIST.map(t => (\r\n          <button key={t.id} onClick={() => setTab(t.id)} style={{ padding: '8px 16px', border: 'none', borderRadius: 8, cursor: 'pointer', fontWeight: 700, fontSize: '0.85rem', background: tab === t.id ? 'linear-gradient(135deg, #ff5722, #ff7043)' : 'transparent', color: tab === t.id ? '#fff' : '#64748b', boxShadow: tab === t.id ? '0 4px 12px rgba(255,87,34,0.3)' : 'none', transition: 'all 0.15s' }}>\r\n            {t.icon} {t.label}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {tab === 'arayuz' && (\r\n        <ArayuzAyarlari prefs={uiPrefs} onChange={p => { setUiPrefs(p); saveUIPrefs(p); applyUIPrefs(p); }} showToast={showToast} />\r\n      )}\r\n\r\n      {tab === 'baglantilar' && (\r\n        <BaglantiAyarlari\r\n          cfg={connCfg}\r\n          onChange={c => { setConnCfg(c); saveConnConfig(c); }}\r\n          showToast={showToast}\r\n        />\r\n      )}\r\n\r\n      {tab === 'company' && (\r\n        <Card title=\"≡ƒÅó ┼₧irket Bilgileri\">\r\n          <div style={{ display: 'grid', gap: 14 }}>\r\n            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>\r\n              <FV label=\"┼₧irket Ad─▒\" value={company.name || ''} onChange={v => setCompany(c => ({ ...c, name: v }))} />\r\n              <FV label=\"┼₧ehir\" value={(company as any).city || ''} onChange={v => setCompany(c => ({ ...c, city: v } as any))} />\r\n              <FV label=\"Vergi No\" value={company.taxNo || ''} onChange={v => setCompany(c => ({ ...c, taxNo: v }))} />\r\n              <FV label=\"Telefon\" value={company.phone || ''} onChange={v => setCompany(c => ({ ...c, phone: v }))} />\r\n              <FV label=\"E-posta\" type=\"email\" value={company.email || ''} onChange={v => setCompany(c => ({ ...c, email: v }))} />\r\n            </div>\r\n            <div><label style={lbl}>Adres</label><textarea value={company.address || ''} onChange={e => setCompany(c => ({ ...c, address: e.target.value }))} style={{ ...inp, minHeight: 70 }} /></div>\r\n            <button onClick={saveCompany} style={btnPrimary}>≡ƒÆ╛ ┼₧irket Bilgilerini Kaydet</button>\r\n          </div>\r\n        </Card>\r\n      )}\r\n\r\n      {tab === 'pellet' && (\r\n        <Card title=\"≡ƒ¬╡ Pelet Ayarlar─▒\">\r\n          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 14 }}>\r\n            <FV label=\"Gramaj (gr/torba)\" type=\"number\" inputMode=\"decimal\" value={String(pellet.gramaj)} onChange={v => setPellet(p => ({ ...p, gramaj: parseFloat(v) || 0 }))} />\r\n            <FV label=\"Kg Fiyat─▒ (Γé║)\" type=\"number\" inputMode=\"decimal\" value={String(pellet.kgFiyat)} onChange={v => setPellet(p => ({ ...p, kgFiyat: parseFloat(v) || 0 }))} />\r\n            <FV label=\"├çuval Kg\" type=\"number\" inputMode=\"decimal\" value={String(pellet.cuvalKg)} onChange={v => setPellet(p => ({ ...p, cuvalKg: parseFloat(v) || 0 }))} />\r\n            <FV label=\"Kritik G├╝n Say─▒s─▒\" type=\"number\" inputMode=\"decimal\" value={String(pellet.critDays)} onChange={v => setPellet(p => ({ ...p, critDays: parseInt(v) || 0 }))} />\r\n          </div>\r\n          <div style={{ marginTop: 14, background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.15)', borderRadius: 10, padding: '12px 16px', color: '#94a3b8', fontSize: '0.85rem' }}>\r\n            ≡ƒÆí Mevcut de─ƒerler: {pellet.cuvalKg}kg ├ºuval ┬╖ Γé║{pellet.kgFiyat}/kg ┬╖ {pellet.gramaj}gr/torba\r\n          </div>\r\n          <button onClick={savePellet} style={{ ...btnPrimary, marginTop: 16 }}>≡ƒÆ╛ Pelet Ayarlar─▒n─▒ Kaydet</button>\r\n        </Card>\r\n      )}\r\n\r\n      {tab === 'sound' && (\r\n        <SoundSettingsPanel playSound={playSound} />\r\n      )}\r\n\r\n      {tab === 'backup' && (\r\n        <div style={{ display: 'grid', gap: 14 }}>\r\n          <Card title=\"≡ƒôñ Yedek Al\">\r\n            <p style={{ color: '#64748b', fontSize: '0.88rem', marginBottom: 16, lineHeight: 1.6 }}>T├╝m verilerinizi <strong style={{ color: '#f59e0b' }}>JSON format─▒nda</strong> d─▒┼ƒa aktar─▒n.</p>\r\n            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(120px, 1fr))', gap: 10, marginBottom: 16 }}>\r\n              {dataStats.slice(0, 4).map(d => (\r\n                <div key={d.label} style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '10px 12px', textAlign: 'center' }}>\r\n                  <div style={{ fontSize: '1.2rem', marginBottom: 4 }}>{d.icon}</div>\r\n                  <div style={{ fontSize: '1.1rem', fontWeight: 800, color: '#f1f5f9' }}>{d.count}</div>\r\n                  <div style={{ color: '#334155', fontSize: '0.72rem' }}>{d.label}</div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <div style={{ background: 'rgba(16,185,129,0.06)', border: '1px solid rgba(16,185,129,0.15)', borderRadius: 10, padding: '10px 16px', marginBottom: 16, color: '#10b981', fontSize: '0.85rem', fontWeight: 600 }}>\r\n              Toplam {totalRecords} kay─▒t yedeklenecek\r\n            </div>\r\n            <button onClick={exportJSON} style={{ ...btnPrimary, background: 'linear-gradient(135deg, #059669, #10b981)' }}>\r\n              Yede─ƒi ─░ndir (.json)\r\n            </button>\r\n          </Card>\r\n\r\n          <FullRestorePanel showToast={showToast} showConfirm={showConfirm as (t: string, m: string, ok: () => void, d?: boolean) => void} save={save} db={db} />\r\n\r\n          <SelectiveRestore showToast={showToast} showConfirm={showConfirm as (t: string, m: string, ok: () => void, d?: boolean) => void} save={save} db={db} />\r\n\r\n          <SmartImportManager db={db} save={save} showToast={showToast} showConfirm={showConfirm as (t: string, m: string, ok: () => void, d?: boolean) => void} />\r\n        </div>\r\n      )}\r\n\r\n      {tab === 'excel_export' && (\r\n        <ExcelExportPanel db={db} />\r\n      )}\r\n\r\n      {tab === 'activity' && (\r\n        <ActivityPanel db={db} save={save} showToast={showToast} showConfirm={showConfirm as (t: string, m: string, ok: () => void, d?: boolean) => void} />\r\n      )}\r\n\r\n      {tab === 'shortcuts' && (\r\n        <Card title=\"Γî¿∩╕Å Klavye K─▒sayollar─▒\">\r\n          <p style={{ color: '#64748b', fontSize: '0.85rem', marginBottom: 16 }}>Uygulamay─▒ daha h─▒zl─▒ kullanmak i├ºin a┼ƒa─ƒ─▒daki k─▒sayollar─▒ kullanabilirsiniz.</p>\r\n          <div style={{ display: 'grid', gap: 8 }}>\r\n            {shortcuts.map((s, i) => (\r\n              <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 14, padding: '11px 16px', background: 'rgba(0,0,0,0.2)', borderRadius: 10, border: '1px solid rgba(255,255,255,0.04)' }}>\r\n                <kbd style={{ background: 'rgba(255,255,255,0.08)', border: '1px solid rgba(255,255,255,0.12)', borderRadius: 7, padding: '4px 10px', fontSize: '0.82rem', fontFamily: 'monospace', color: '#f59e0b', fontWeight: 700, whiteSpace: 'nowrap', boxShadow: '0 2px 0 rgba(0,0,0,0.4)' }}>{s.key}</kbd>\r\n                <span style={{ color: '#94a3b8', fontSize: '0.88rem' }}>{s.desc}</span>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </Card>\r\n      )}\r\n\r\n      {tab === 'repair' && (\r\n        <VeriOnarim db={db} save={save} showToast={showToast} showConfirm={showConfirm as (title: string, msg: string, onOk: () => void, danger?: boolean) => void} />\r\n      )}\r\n\r\n      {tab === 'excel' && (\r\n        <ExcelImport db={db} save={save} />\r\n      )}\r\n\r\n      {tab === 'categories' && (\r\n        <KategoriYonetim db={db} save={save} />\r\n      )}\r\n\r\n      {tab === 'data' && (\r\n        <div style={{ display: 'grid', gap: 14 }}>\r\n          <Card title=\"≡ƒùä∩╕Å Veri ─░statistikleri\">\r\n            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(120px, 1fr))', gap: 10 }}>\r\n              {dataStats.map(d => (\r\n                <div key={d.label} style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '12px 14px', textAlign: 'center' }}>\r\n                  <div style={{ fontSize: '1.4rem', marginBottom: 4 }}>{d.icon}</div>\r\n                  <div style={{ fontSize: '1.3rem', fontWeight: 900, color: d.count > 0 ? '#f1f5f9' : '#334155' }}>{d.count}</div>\r\n                  <div style={{ color: '#334155', fontSize: '0.72rem', marginTop: 2 }}>{d.label}</div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <div style={{ marginTop: 14, textAlign: 'center', color: '#475569', fontSize: '0.85rem' }}>\r\n              Toplam <strong style={{ color: '#f1f5f9' }}>{totalRecords}</strong> kay─▒t ┬╖ localStorage'da saklan─▒yor\r\n            </div>\r\n          </Card>\r\n\r\n          <Card title=\"≡ƒùæ∩╕Å Tehlikeli Alan\">\r\n            <p style={{ color: '#64748b', fontSize: '0.88rem', marginBottom: 16, lineHeight: 1.6 }}>A┼ƒa─ƒ─▒daki i┼ƒlemler <strong style={{ color: '#ef4444' }}>geri al─▒namaz</strong>. ├ûnce yedek alman─▒z─▒ ┼ƒiddetle tavsiye ederiz.</p>\r\n            <div style={{ display: 'grid', gap: 10 }}>\r\n              <DangerAction label=\"Sat─▒┼ƒ Ge├ºmi┼ƒini Temizle\" desc={`${db.sales.length} sat─▒┼ƒ kayd─▒ silinecek`} onConfirm={() => { save(prev => ({ ...prev, sales: [] })); showToast('Sat─▒┼ƒ ge├ºmi┼ƒi temizlendi!'); }} />\r\n              <DangerAction label=\"Kasa ─░┼ƒlemlerini Temizle\" desc={`${db.kasa.length} kasa kayd─▒ silinecek`} onConfirm={() => { save(prev => ({ ...prev, kasa: [] })); showToast('Kasa temizlendi!'); }} />\r\n              <DangerAction label=\"Aktivite G├╝nl├╝─ƒ├╝n├╝ Temizle\" desc={`${db._activityLog.length} kay─▒t silinecek`} onConfirm={() => { save(prev => ({ ...prev, _activityLog: [] })); showToast('Aktivite g├╝nl├╝─ƒ├╝ temizlendi!'); }} />\r\n              <button onClick={clearData} style={{ width: '100%', padding: '14px 0', background: 'linear-gradient(135deg, rgba(220,38,38,0.15), rgba(239,68,68,0.08))', border: '1px solid rgba(239,68,68,0.3)', borderRadius: 12, color: '#ef4444', fontWeight: 800, cursor: 'pointer', fontSize: '0.95rem' }}>\r\n                Γÿá∩╕Å T├£M VER─░LER─░ S─░L ve S─▒f─▒rla\r\n              </button>\r\n            </div>\r\n          </Card>\r\n        </div>\r\n      )}\r\n\r\n      {tab === 'security' && (\r\n        <SecurityPanel showToast={showToast} />\r\n      )}\r\n\r\n      {tab === 'sysmap' && (\r\n        <div style={{ display: 'grid', gap: 14 }}>\r\n          <Card title=\"≡ƒù║∩╕Å Sistem Haritas─▒ ΓÇö Mod├╝ller Aras─▒ ─░li┼ƒkiler\">\r\n            <p style={{ color: '#64748b', fontSize: '0.85rem', marginBottom: 14, lineHeight: 1.6 }}>\r\n              Her mod├╝l├╝n di─ƒer mod├╝lleri nas─▒l etkiledi─ƒini g├╢steren ak─▒┼ƒ diyagram─▒.\r\n              D├╝z ├ºizgi = do─ƒrudan veri etkisi, kesik ├ºizgi = veri sa─ƒlar.\r\n            </p>\r\n            <SystemMap />\r\n          </Card>\r\n        </div>\r\n      )}\r\n\r\n      {tab === 'about' && (\r\n        <AboutPanel db={db} />\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction SecurityPanel({ showToast }: { showToast: (msg: string, type?: 'success' | 'error' | 'info') => void }) {\r\n  const [oldPass, setOldPass] = useState('');\r\n  const [newPass, setNewPass] = useState('');\r\n  const [newPass2, setNewPass2] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [showOld, setShowOld] = useState(false);\r\n  const [showNew, setShowNew] = useState(false);\r\n  const session = getUserSession();\r\n\r\n  const handleChange = async () => {\r\n    if (!oldPass) { showToast('Mevcut parolay─▒ girin!', 'error'); return; }\r\n    if (newPass.length < 4) { showToast('Yeni parola en az 4 karakter olmal─▒!', 'error'); return; }\r\n    if (newPass !== newPass2) { showToast('Yeni parolalar e┼ƒle┼ƒmiyor!', 'error'); return; }\r\n    if (!session) { showToast('Oturum bulunamad─▒!', 'error'); return; }\r\n    setLoading(true);\r\n    const users = await loadUsers();\r\n    const me = users.find(u => u.id === session.userId);\r\n    if (!me) { showToast('Kullan─▒c─▒ bulunamad─▒!', 'error'); setLoading(false); return; }\r\n    const oldHash = await hashPass(oldPass);\r\n    if (oldHash !== me.passwordHash) {\r\n      showToast('Mevcut parola yanl─▒┼ƒ!', 'error');\r\n      setOldPass(''); setLoading(false); return;\r\n    }\r\n    const ok = await updateUserPassword(session.userId, newPass);\r\n    if (ok) {\r\n      setOldPass(''); setNewPass(''); setNewPass2('');\r\n      showToast('Parola ba┼ƒar─▒yla g├╝ncellendi!', 'success');\r\n    } else {\r\n      showToast('Firebase kay─▒t hatas─▒!', 'error');\r\n    }\r\n    setLoading(false);\r\n  };\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 14 }}>\r\n      <Card title=\"≡ƒöÉ ┼₧ifremi De─ƒi┼ƒtir\">\r\n        <div style={{ display: 'grid', gap: 14, maxWidth: 380 }}>\r\n          {session && <div style={{ padding: '8px 12px', background: 'rgba(99,102,241,0.08)', border: '1px solid rgba(99,102,241,0.2)', borderRadius: 10, fontSize: '0.82rem', color: '#a5b4fc' }}>\r\n            ≡ƒæñ Giri┼ƒ yapan: <strong>{session.username}</strong> ({session.role === 'admin' ? 'Y├╢netici' : 'Kullan─▒c─▒'})\r\n          </div>}\r\n          <div>\r\n            <label style={lbl}>Mevcut Parola</label>\r\n            <div style={{ position: 'relative' }}>\r\n              <input type={showOld ? 'text' : 'password'} value={oldPass} onChange={e => setOldPass(e.target.value)} placeholder=\"Mevcut parolan─▒z\" style={{ ...inp, paddingRight: 44 }} />\r\n              <button onClick={() => setShowOld(p => !p)} style={{ position: 'absolute', right: 12, top: '50%', transform: 'translateY(-50%)', background: 'none', border: 'none', cursor: 'pointer', color: '#64748b', fontSize: '0.9rem' }}>{showOld ? '≡ƒÖê' : '≡ƒæü∩╕Å'}</button>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>Yeni Parola</label>\r\n            <div style={{ position: 'relative' }}>\r\n              <input type={showNew ? 'text' : 'password'} value={newPass} onChange={e => setNewPass(e.target.value)} placeholder=\"En az 4 karakter\" style={{ ...inp, paddingRight: 44 }} />\r\n              <button onClick={() => setShowNew(p => !p)} style={{ position: 'absolute', right: 12, top: '50%', transform: 'translateY(-50%)', background: 'none', border: 'none', cursor: 'pointer', color: '#64748b', fontSize: '0.9rem' }}>{showNew ? '≡ƒÖê' : '≡ƒæü∩╕Å'}</button>\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>Yeni Parola (Tekrar)</label>\r\n            <input type={showNew ? 'text' : 'password'} value={newPass2} onChange={e => setNewPass2(e.target.value)} placeholder=\"Yeni parolay─▒ tekrar girin\" style={inp} onKeyDown={e => e.key === 'Enter' && handleChange()} />\r\n          </div>\r\n          <button onClick={handleChange} disabled={loading} style={btnPrimary}>\r\n            {loading ? 'ΓÅ│ De─ƒi┼ƒtiriliyor...' : '≡ƒöÉ Parolay─▒ De─ƒi┼ƒtir'}\r\n          </button>\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Y├╢netici Paneli ΓÇö sadece admin g├╢r├╝r */}\r\n      {session?.role === 'admin' && <AdminPanel showToast={showToast} />}\r\n    </div>\r\n  );\r\n}\r\n\r\n// ΓöÇΓöÇ Y├╢netici Paneli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction AdminPanel({ showToast }: { showToast: (msg: string, type?: 'success' | 'error' | 'info') => void }) {\r\n  const [users, setUsers] = useState<AppUser[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [newUsername, setNewUsername] = useState('');\r\n  const [newPass, setNewPass] = useState('');\r\n  const [newRole, setNewRole] = useState<UserRole>('user');\r\n  const [resetPassId, setResetPassId] = useState<string | null>(null);\r\n  const [resetPassVal, setResetPassVal] = useState('');\r\n  const [saving, setSaving] = useState(false);\r\n\r\n  const refresh = async () => {\r\n    setLoading(true);\r\n    setUsers(await loadUsers());\r\n    setLoading(false);\r\n  };\r\n\r\n  useEffect(() => { refresh(); }, []);\r\n\r\n  const handleCreate = async () => {\r\n    if (!newUsername.trim()) { showToast('Kullan─▒c─▒ ad─▒ gerekli!', 'error'); return; }\r\n    if (newPass.length < 4) { showToast('┼₧ifre en az 4 karakter!', 'error'); return; }\r\n    setSaving(true);\r\n    const result = await createUser(newUsername.trim(), newPass, newRole);\r\n    if (result.ok) {\r\n      showToast(`Γ£à ${newUsername} olu┼ƒturuldu`, 'success');\r\n      setNewUsername(''); setNewPass('');\r\n      await refresh();\r\n    } else {\r\n      showToast(result.msg, 'error');\r\n    }\r\n    setSaving(false);\r\n  };\r\n\r\n  const handleToggle = async (userId: string, username: string, active: boolean) => {\r\n    await toggleUserActive(userId);\r\n    showToast(`${username} ${active ? 'devre d─▒┼ƒ─▒ b─▒rak─▒ld─▒' : 'aktif edildi'}`, 'info');\r\n    await refresh();\r\n  };\r\n\r\n  const handleDelete = async (userId: string, username: string) => {\r\n    if (!confirm(`\"${username}\" kullan─▒c─▒s─▒n─▒ silmek istedi─ƒinizden emin misiniz?`)) return;\r\n    await deleteUser(userId);\r\n    showToast(`${username} silindi`, 'info');\r\n    await refresh();\r\n  };\r\n\r\n  const handleRoleChange = async (userId: string, role: UserRole) => {\r\n    await updateUserRole(userId, role);\r\n    showToast('Rol g├╝ncellendi', 'success');\r\n    await refresh();\r\n  };\r\n\r\n  const handleResetPass = async (userId: string) => {\r\n    if (resetPassVal.length < 4) { showToast('┼₧ifre en az 4 karakter!', 'error'); return; }\r\n    await updateUserPassword(userId, resetPassVal);\r\n    showToast('┼₧ifre s─▒f─▒rland─▒', 'success');\r\n    setResetPassId(null); setResetPassVal('');\r\n    await refresh();\r\n  };\r\n\r\n  const roleColors: Record<UserRole, string> = { admin: '#f59e0b', user: '#60a5fa' };\r\n\r\n  return (\r\n    <Card title=\"≡ƒæÑ Kullan─▒c─▒ Y├╢netimi\">\r\n      {/* Yeni kullan─▒c─▒ ekle */}\r\n      <div style={{ background: 'rgba(0,0,0,0.2)', borderRadius: 12, padding: '16px', marginBottom: 18 }}>\r\n        <div style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.88rem', marginBottom: 12 }}>Γ₧ò Yeni Kullan─▒c─▒ Ekle</div>\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10, marginBottom: 10 }}>\r\n          <div>\r\n            <label style={lbl}>Kullan─▒c─▒ Ad─▒ *</label>\r\n            <input value={newUsername} onChange={e => setNewUsername(e.target.value)} placeholder=\"kullanici_adi\" style={inp} />\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>┼₧ifre *</label>\r\n            <input type=\"password\" value={newPass} onChange={e => setNewPass(e.target.value)} placeholder=\"Min. 4 karakter\" style={inp} />\r\n          </div>\r\n        </div>\r\n        <div style={{ display: 'flex', gap: 10, alignItems: 'flex-end' }}>\r\n          <div style={{ flex: 1 }}>\r\n            <label style={lbl}>Rol</label>\r\n            <select value={newRole} onChange={e => setNewRole(e.target.value as UserRole)} style={inp}>\r\n              <option value=\"user\">≡ƒæñ Kullan─▒c─▒</option>\r\n              <option value=\"admin\">Γ¡É Y├╢netici</option>\r\n            </select>\r\n          </div>\r\n          <button onClick={handleCreate} disabled={saving} style={{ ...btnPrimary, flex: 1 }}>\r\n            {saving ? '...' : 'Γ₧ò Ekle'}\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Kullan─▒c─▒ listesi */}\r\n      {loading ? (\r\n        <div style={{ color: '#475569', fontSize: '0.85rem', textAlign: 'center', padding: '20px 0' }}>Y├╝kleniyor...</div>\r\n      ) : users.length === 0 ? (\r\n        <div style={{ color: '#475569', fontSize: '0.85rem', textAlign: 'center', padding: '20px 0' }}>Kullan─▒c─▒ bulunamad─▒</div>\r\n      ) : (\r\n        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>\r\n          {users.map(u => (\r\n            <div key={u.id} style={{ background: 'rgba(0,0,0,0.2)', borderRadius: 12, padding: '12px 14px', border: `1px solid ${u.active ? 'rgba(255,255,255,0.06)' : 'rgba(239,68,68,0.15)'}`, opacity: u.active ? 1 : 0.6 }}>\r\n              <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: resetPassId === u.id ? 10 : 0 }}>\r\n                {/* Avatar */}\r\n                <div style={{ width: 36, height: 36, borderRadius: '50%', background: `${roleColors[u.role]}20`, border: `2px solid ${roleColors[u.role]}40`, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '1rem', flexShrink: 0 }}>\r\n                  {u.role === 'admin' ? 'Γ¡É' : '≡ƒæñ'}\r\n                </div>\r\n                <div style={{ flex: 1, minWidth: 0 }}>\r\n                  <div style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.88rem' }}>{u.username}</div>\r\n                  <div style={{ fontSize: '0.72rem', color: '#475569' }}>\r\n                    {u.lastLogin ? `Son giri┼ƒ: ${new Date(u.lastLogin).toLocaleString('tr-TR')}` : 'Hi├º giri┼ƒ yap─▒lmad─▒'}\r\n                  </div>\r\n                </div>\r\n                {/* Rol se├ºici */}\r\n                <select\r\n                  value={u.role}\r\n                  onChange={e => handleRoleChange(u.id, e.target.value as UserRole)}\r\n                  style={{ padding: '4px 8px', background: `${roleColors[u.role]}15`, border: `1px solid ${roleColors[u.role]}30`, borderRadius: 7, color: roleColors[u.role], fontSize: '0.75rem', fontWeight: 700, cursor: 'pointer' }}\r\n                >\r\n                  <option value=\"user\">Kullan─▒c─▒</option>\r\n                  <option value=\"admin\">Y├╢netici</option>\r\n                </select>\r\n                {/* ┼₧ifre s─▒f─▒rla */}\r\n                <button\r\n                  onClick={() => { setResetPassId(resetPassId === u.id ? null : u.id); setResetPassVal(''); }}\r\n                  title=\"┼₧ifre S─▒f─▒rla\"\r\n                  style={{ padding: '5px 9px', background: 'rgba(245,158,11,0.1)', border: '1px solid rgba(245,158,11,0.2)', borderRadius: 8, color: '#f59e0b', cursor: 'pointer', fontSize: '0.8rem' }}\r\n                >≡ƒöæ</button>\r\n                {/* Aktif/Pasif */}\r\n                <button\r\n                  onClick={() => handleToggle(u.id, u.username, u.active)}\r\n                  title={u.active ? 'Devre D─▒┼ƒ─▒ B─▒rak' : 'Aktif Et'}\r\n                  style={{ padding: '5px 9px', background: u.active ? 'rgba(16,185,129,0.1)' : 'rgba(239,68,68,0.1)', border: `1px solid ${u.active ? 'rgba(16,185,129,0.2)' : 'rgba(239,68,68,0.2)'}`, borderRadius: 8, color: u.active ? '#10b981' : '#ef4444', cursor: 'pointer', fontSize: '0.8rem' }}\r\n                >{u.active ? 'Γ£ô' : 'Γ£ò'}</button>\r\n                {/* Sil */}\r\n                <button\r\n                  onClick={() => handleDelete(u.id, u.username)}\r\n                  title=\"Kullan─▒c─▒y─▒ Sil\"\r\n                  style={{ padding: '5px 9px', background: 'rgba(239,68,68,0.08)', border: '1px solid rgba(239,68,68,0.15)', borderRadius: 8, color: '#ef4444', cursor: 'pointer', fontSize: '0.8rem' }}\r\n                >≡ƒùæ∩╕Å</button>\r\n              </div>\r\n              {/* ┼₧ifre s─▒f─▒rlama alan─▒ */}\r\n              {resetPassId === u.id && (\r\n                <div style={{ display: 'flex', gap: 8, marginTop: 8 }}>\r\n                  <input\r\n                    type=\"password\"\r\n                    value={resetPassVal}\r\n                    onChange={e => setResetPassVal(e.target.value)}\r\n                    placeholder=\"Yeni ┼ƒifre (min 4 karakter)\"\r\n                    style={{ ...inp, flex: 1 }}\r\n                    autoFocus\r\n                  />\r\n                  <button onClick={() => handleResetPass(u.id)} style={{ padding: '8px 14px', background: 'rgba(245,158,11,0.15)', border: '1px solid rgba(245,158,11,0.3)', borderRadius: 10, color: '#f59e0b', fontWeight: 700, cursor: 'pointer', fontSize: '0.82rem' }}>\r\n                    Kaydet\r\n                  </button>\r\n                </div>\r\n              )}\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n    </Card>\r\n  );\r\n}\r\n\r\nfunction SoundSettingsPanel({ playSound }: { playSound: (type: SoundType) => void }) {\r\n  const [settings, setSettings] = useState<SoundSettings>(loadSoundSettings);\r\n  const [speechEnabled, setSpeechEnabled] = useState<boolean>(() => {\r\n    try {\r\n      const d = JSON.parse(localStorage.getItem('sobaYonetim') || '{}');\r\n      return d.soundSettings?.speechEnabled !== false;\r\n    } catch { return true; }\r\n  });\r\n\r\n  const updateSettings = (patch: Partial<SoundSettings>) => {\r\n    const next = { ...settings, ...patch };\r\n    setSettings(next);\r\n    saveSoundSettingsToStorage(next);\r\n  };\r\n\r\n  const toggleSpeech = () => {\r\n    const next = !speechEnabled;\r\n    setSpeechEnabled(next);\r\n    const key = 'sobaYonetim';\r\n    const raw = localStorage.getItem(key);\r\n    const data = raw ? JSON.parse(raw) : {};\r\n    data.soundSettings = { ...(data.soundSettings || {}), speechEnabled: next };\r\n    localStorage.setItem(key, JSON.stringify(data));\r\n    if (next && 'speechSynthesis' in window) {\r\n      const u = new SpeechSynthesisUtterance('Sesli bildirim aktif edildi');\r\n      u.lang = 'tr-TR';\r\n      u.rate = 1.05;\r\n      window.speechSynthesis.speak(u);\r\n    }\r\n  };\r\n\r\n  const themes: { id: SoundTheme; label: string; desc: string }[] = [\r\n    { id: 'standart', label: '≡ƒÄ╡ Standart', desc: 'Dengeli ve sade sesler' },\r\n    { id: 'minimal', label: '≡ƒöç Minimal', desc: 'K─▒sa ve hafif sesler' },\r\n    { id: 'yogun', label: '≡ƒöè Yo─ƒun', desc: 'Belirgin ve g├╝├ºl├╝ sesler' },\r\n  ];\r\n\r\n  const soundTypes: { type: SoundType; label: string }[] = [\r\n    { type: 'success', label: 'Γ£à Ba┼ƒar─▒' },\r\n    { type: 'error', label: 'Γ¥î Hata' },\r\n    { type: 'warning', label: 'ΓÜá∩╕Å Uyar─▒' },\r\n    { type: 'sale', label: '≡ƒ¢Æ Sat─▒┼ƒ' },\r\n    { type: 'notification', label: '≡ƒöö Bildirim' },\r\n  ];\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 14 }}>\r\n      <Card title=\"≡ƒöè Ses Ayarlar─▒\">\r\n        <div style={{ display: 'grid', gap: 20 }}>\r\n          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>\r\n            <div>\r\n              <div style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.95rem' }}>Sesli Geri Bildirim</div>\r\n              <div style={{ color: '#64748b', fontSize: '0.82rem', marginTop: 2 }}>─░┼ƒlem seslerini a├º─▒n veya kapat─▒n</div>\r\n            </div>\r\n            <button\r\n              onClick={() => updateSettings({ enabled: !settings.enabled })}\r\n              style={{ width: 52, height: 28, borderRadius: 14, border: 'none', cursor: 'pointer', position: 'relative', background: settings.enabled ? '#10b981' : '#334155', transition: 'background 0.2s' }}\r\n            >\r\n              <div style={{ width: 20, height: 20, borderRadius: '50%', background: '#fff', position: 'absolute', top: 4, left: settings.enabled ? 28 : 4, transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n            </button>\r\n          </div>\r\n\r\n          <div>\r\n            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 8 }}>\r\n              <label style={lbl}>Ses Seviyesi</label>\r\n              <span style={{ color: '#ff7043', fontWeight: 700, fontSize: '0.85rem' }}>{Math.round(settings.volume * 100)}%</span>\r\n            </div>\r\n            <input\r\n              type=\"range\" min={0} max={1} step={0.05}\r\n              value={settings.volume}\r\n              onChange={e => updateSettings({ volume: parseFloat(e.target.value) })}\r\n              style={{ width: '100%', accentColor: '#ff5722' }}\r\n              disabled={!settings.enabled}\r\n            />\r\n          </div>\r\n\r\n          <div>\r\n            <label style={lbl}>Ses Temas─▒</label>\r\n            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(140px, 1fr))', gap: 10 }}>\r\n              {themes.map(t => (\r\n                <button\r\n                  key={t.id}\r\n                  onClick={() => updateSettings({ theme: t.id })}\r\n                  disabled={!settings.enabled}\r\n                  style={{ padding: '12px 10px', border: `2px solid ${settings.theme === t.id ? '#ff5722' : 'rgba(255,255,255,0.08)'}`, borderRadius: 10, cursor: 'pointer', background: settings.theme === t.id ? 'rgba(255,87,34,0.1)' : 'rgba(0,0,0,0.2)', color: settings.theme === t.id ? '#ff7043' : '#64748b', textAlign: 'center', transition: 'all 0.15s', opacity: settings.enabled ? 1 : 0.5 }}\r\n                >\r\n                  <div style={{ fontWeight: 700, fontSize: '0.88rem' }}>{t.label}</div>\r\n                  <div style={{ fontSize: '0.72rem', marginTop: 4, color: settings.theme === t.id ? '#ff7043' : '#475569' }}>{t.desc}</div>\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </Card>\r\n\r\n      <Card title=\"≡ƒùú∩╕Å Sesli Konu┼ƒma (TTS)\">\r\n        <div style={{ display: 'grid', gap: 16 }}>\r\n          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>\r\n            <div>\r\n              <div style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.95rem' }}>Sesli Bildirim</div>\r\n              <div style={{ color: '#64748b', fontSize: '0.82rem', marginTop: 2 }}>Hata ve uyar─▒larda sesli konu┼ƒma</div>\r\n            </div>\r\n            <button\r\n              onClick={toggleSpeech}\r\n              style={{ width: 52, height: 28, borderRadius: 14, border: 'none', cursor: 'pointer', position: 'relative', background: speechEnabled ? '#10b981' : '#334155', transition: 'background 0.2s' }}\r\n            >\r\n              <div style={{ width: 20, height: 20, borderRadius: '50%', background: '#fff', position: 'absolute', top: 4, left: speechEnabled ? 28 : 4, transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n            </button>\r\n          </div>\r\n          <button\r\n            onClick={() => {\r\n              if ('speechSynthesis' in window) {\r\n                const u = new SpeechSynthesisUtterance('Merhaba! Bu bir test konu┼ƒmas─▒d─▒r. ├ûnemli bildirimlerde sesli uyar─▒ alacaks─▒n─▒z.');\r\n                u.lang = 'tr-TR';\r\n                u.rate = 1.05;\r\n                window.speechSynthesis.speak(u);\r\n              }\r\n            }}\r\n            style={{ padding: '10px 14px', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, cursor: 'pointer', background: 'rgba(0,0,0,0.3)', color: '#94a3b8', fontWeight: 600, fontSize: '0.85rem' }}\r\n          >\r\n            ≡ƒùú∩╕Å Test Konu┼ƒma\r\n          </button>\r\n        </div>\r\n      </Card>\r\n\r\n      <Card title=\"≡ƒÄº Sesleri Dinle\">\r\n        <p style={{ color: '#64748b', fontSize: '0.85rem', marginBottom: 14 }}>Her ses tipini a┼ƒa─ƒ─▒dan test edebilirsiniz.</p>\r\n        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(140px, 1fr))', gap: 10 }}>\r\n          {soundTypes.map(s => (\r\n            <button\r\n              key={s.type}\r\n              onClick={() => playSound(s.type)}\r\n              disabled={!settings.enabled}\r\n              style={{ padding: '10px 14px', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, cursor: 'pointer', background: 'rgba(0,0,0,0.3)', color: '#94a3b8', fontWeight: 600, fontSize: '0.85rem', transition: 'all 0.15s', opacity: settings.enabled ? 1 : 0.5 }}\r\n              onMouseEnter={e => { if (settings.enabled) (e.currentTarget as HTMLButtonElement).style.background = 'rgba(255,87,34,0.1)'; }}\r\n              onMouseLeave={e => (e.currentTarget as HTMLButtonElement).style.background = 'rgba(0,0,0,0.3)'}\r\n            >\r\n              {s.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction ExcelExportPanel({ db }: { db: DB }) {\r\n  const { showToast } = useToast();\r\n  const [dateFrom, setDateFrom] = useState('');\r\n  const [dateTo, setDateTo] = useState('');\r\n  const [sheets, setSheets] = useState({ stok: true, satislar: true, cari: true, kasa: true });\r\n\r\n  type SheetKey = keyof typeof sheets;\r\n\r\n  const toggleSheet = (key: SheetKey) => setSheets(s => ({ ...s, [key]: !s[key] }));\r\n\r\n  const handleExport = () => {\r\n    const selectedSheets = (Object.keys(sheets) as SheetKey[]).filter(k => sheets[k]) as ('stok' | 'satislar' | 'cari' | 'kasa')[];\r\n    if (selectedSheets.length === 0) { showToast('En az bir sekme se├ºin!', 'warning'); return; }\r\n    try {\r\n      exportToExcel(db, { dateFrom: dateFrom || undefined, dateTo: dateTo || undefined, sheets: selectedSheets });\r\n      showToast(`Excel dosyas─▒ olu┼ƒturuldu! (${selectedSheets.length} sekme)`, 'success');\r\n    } catch (e) {\r\n      showToast('Excel olu┼ƒturulamad─▒!', 'error');\r\n    }\r\n  };\r\n\r\n  const sheetDefs: { key: SheetKey; label: string; icon: string; count: number }[] = [\r\n    { key: 'stok', label: 'Stok / ├£r├╝nler', icon: '≡ƒôª', count: db.products.length },\r\n    { key: 'satislar', label: 'Sat─▒┼ƒlar', icon: '≡ƒ¢Æ', count: db.sales.length },\r\n    { key: 'cari', label: 'Cari Hesaplar', icon: '≡ƒæñ', count: db.cari.length },\r\n    { key: 'kasa', label: 'Kasa ─░┼ƒlemleri', icon: '≡ƒÆ░', count: db.kasa.length },\r\n  ];\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 14 }}>\r\n      <Card title=\"≡ƒôè Excel D─▒┼ƒa Aktarma\">\r\n        <p style={{ color: '#64748b', fontSize: '0.88rem', marginBottom: 16, lineHeight: 1.6 }}>\r\n          Se├ºti─ƒiniz veri gruplar─▒n─▒ T├╝rk├ºe ba┼ƒl─▒kl─▒, tarih ve para birimi formatlar─▒yla <strong style={{ color: '#10b981' }}>.xlsx</strong> dosyas─▒na aktar─▒n.\r\n        </p>\r\n\r\n        <div style={{ marginBottom: 16 }}>\r\n          <label style={lbl}>Tarih Aral─▒─ƒ─▒ (Sat─▒┼ƒ ve Kasa i├ºin)</label>\r\n          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>\r\n            <div>\r\n              <label style={{ ...lbl, fontSize: '0.78rem' }}>Ba┼ƒlang─▒├º</label>\r\n              <input type=\"date\" value={dateFrom} onChange={e => setDateFrom(e.target.value)} style={inp} />\r\n            </div>\r\n            <div>\r\n              <label style={{ ...lbl, fontSize: '0.78rem' }}>Biti┼ƒ</label>\r\n              <input type=\"date\" value={dateTo} onChange={e => setDateTo(e.target.value)} style={inp} />\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div style={{ marginBottom: 20 }}>\r\n          <label style={lbl}>Dahil Edilecek Sayfalar</label>\r\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2,1fr)', gap: 10 }}>\r\n            {sheetDefs.map(s => (\r\n              <div\r\n                key={s.key}\r\n                onClick={() => toggleSheet(s.key)}\r\n                style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 16px', background: sheets[s.key] ? 'rgba(16,185,129,0.08)' : 'rgba(0,0,0,0.2)', border: `2px solid ${sheets[s.key] ? '#10b981' : 'rgba(255,255,255,0.06)'}`, borderRadius: 10, cursor: 'pointer', transition: 'all 0.15s' }}\r\n              >\r\n                <span style={{ fontSize: '1.2rem' }}>{s.icon}</span>\r\n                <div style={{ flex: 1 }}>\r\n                  <div style={{ fontWeight: 600, color: sheets[s.key] ? '#f1f5f9' : '#64748b', fontSize: '0.88rem' }}>{s.label}</div>\r\n                  <div style={{ color: '#475569', fontSize: '0.75rem' }}>{s.count} kay─▒t</div>\r\n                </div>\r\n                <div style={{ width: 20, height: 20, borderRadius: 5, background: sheets[s.key] ? '#10b981' : 'rgba(255,255,255,0.06)', display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#fff', fontSize: '0.75rem', fontWeight: 800 }}>\r\n                  {sheets[s.key] ? 'Γ£ô' : ''}\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n\r\n        <button onClick={handleExport} style={{ ...btnPrimary, background: 'linear-gradient(135deg, #059669, #10b981)' }}>\r\n          ≡ƒôè Excel Dosyas─▒n─▒ ─░ndir (.xlsx)\r\n        </button>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction ActivityPanel({ db, save, showToast, showConfirm }: {\r\n  db: DB;\r\n  save: (fn: (prev: DB) => DB) => void;\r\n  showToast: (m: string, t?: string) => void;\r\n  showConfirm: (t: string, m: string, ok: () => void, d?: boolean) => void;\r\n}) {\r\n  const [typeFilter, setTypeFilter] = useState('all');\r\n  const [dateFilter, setDateFilter] = useState('');\r\n\r\n  const activityLog = [...(db._activityLog || [])].sort((a, b) => new Date(b.time).getTime() - new Date(a.time).getTime());\r\n\r\n  const actionTypes = Array.from(new Set(activityLog.map(a => {\r\n    const parts = a.action.split(':');\r\n    return parts[0].trim();\r\n  }))).slice(0, 15);\r\n\r\n  let filtered = activityLog;\r\n  if (typeFilter !== 'all') filtered = filtered.filter(a => a.action.startsWith(typeFilter));\r\n  if (dateFilter) filtered = filtered.filter(a => a.time.startsWith(dateFilter));\r\n\r\n  const getIcon = (action: string) => {\r\n    const a = action.toLowerCase();\r\n    if (a.includes('sat─▒┼ƒ') || a.includes('satis')) return '≡ƒ¢Æ';\r\n    if (a.includes('├╝r├╝n') || a.includes('urun') || a.includes('stok')) return '≡ƒôª';\r\n    if (a.includes('kasa') || a.includes('gelir') || a.includes('gider')) return '≡ƒÆ░';\r\n    if (a.includes('cari') || a.includes('m├╝┼ƒteri')) return '≡ƒæñ';\r\n    if (a.includes('fatura')) return '≡ƒº╛';\r\n    if (a.includes('sipari┼ƒ')) return '≡ƒôï';\r\n    if (a.includes('sil') || a.includes('iptal')) return '≡ƒùæ∩╕Å';\r\n    return '≡ƒô¥';\r\n  };\r\n\r\n  const clearLog = () => {\r\n    showConfirm('Aktivite G├╝nl├╝─ƒ├╝n├╝ Temizle', `${db._activityLog.length} kay─▒t silinecek. Devam edilsin mi?`, () => {\r\n      save(prev => ({ ...prev, _activityLog: [] }));\r\n      showToast('Aktivite g├╝nl├╝─ƒ├╝ temizlendi!');\r\n    }, true);\r\n  };\r\n\r\n  return (\r\n    <Card title=\"≡ƒôï Aktivite G├╝nl├╝─ƒ├╝\">\r\n      <div style={{ display: 'flex', gap: 10, marginBottom: 14, flexWrap: 'wrap', alignItems: 'center' }}>\r\n        <input type=\"date\" value={dateFilter} onChange={e => setDateFilter(e.target.value)} style={{ ...inp, width: 160 }} placeholder=\"Tarih filtrele\" />\r\n        <select value={typeFilter} onChange={e => setTypeFilter(e.target.value)} style={{ ...inp, flex: 1 }}>\r\n          <option value=\"all\">T├╝m ─░┼ƒlemler</option>\r\n          {actionTypes.map(t => <option key={t} value={t}>{t}</option>)}\r\n        </select>\r\n        {dateFilter && <button onClick={() => setDateFilter('')} style={{ padding: '9px 12px', background: '#334155', border: 'none', borderRadius: 8, color: '#94a3b8', cursor: 'pointer', fontSize: '0.82rem' }}>Γ£ò Tarih</button>}\r\n        <button onClick={clearLog} style={{ padding: '9px 14px', background: 'rgba(239,68,68,0.1)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 8, color: '#f87171', cursor: 'pointer', fontWeight: 600, fontSize: '0.82rem' }}>≡ƒùæ∩╕Å Temizle</button>\r\n      </div>\r\n\r\n      <div style={{ color: '#475569', fontSize: '0.8rem', marginBottom: 10 }}>{filtered.length} kay─▒t (toplam {activityLog.length})</div>\r\n\r\n      <div style={{ display: 'grid', gap: 6, maxHeight: 500, overflowY: 'auto' }}>\r\n        {filtered.length === 0 ? (\r\n          <div style={{ textAlign: 'center', padding: '32px 0', color: '#334155' }}>\r\n            <div style={{ fontSize: '2rem', marginBottom: 8 }}>≡ƒôï</div>\r\n            <p>Aktivite bulunamad─▒</p>\r\n          </div>\r\n        ) : filtered.map(a => (\r\n          <div key={a.id} style={{ display: 'flex', gap: 12, alignItems: 'flex-start', padding: '10px 14px', background: 'rgba(0,0,0,0.2)', borderRadius: 10, border: '1px solid rgba(255,255,255,0.04)' }}>\r\n            <div style={{ width: 32, height: 32, borderRadius: 8, background: 'rgba(255,87,34,0.1)', display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0, fontSize: '0.9rem' }}>\r\n              {getIcon(a.action)}\r\n            </div>\r\n            <div style={{ flex: 1 }}>\r\n              <div style={{ color: '#e2e8f0', fontWeight: 600, fontSize: '0.85rem' }}>{a.action}</div>\r\n              {a.detail && <div style={{ color: '#64748b', fontSize: '0.78rem', marginTop: 2 }}>{a.detail}</div>}\r\n            </div>\r\n            <div style={{ color: '#334155', fontSize: '0.75rem', whiteSpace: 'nowrap', flexShrink: 0 }}>\r\n              {formatDate(a.time)}\r\n            </div>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </Card>\r\n  );\r\n}\r\n\r\nconst RESTORE_SECTIONS = [\r\n  { key: 'products', label: '├£r├╝nler', icon: '≡ƒôª' },\r\n  { key: 'sales', label: 'Sat─▒┼ƒlar', icon: '≡ƒ¢Æ' },\r\n  { key: 'suppliers', label: 'Tedarik├ºiler', icon: '≡ƒÅ¡' },\r\n  { key: 'cari', label: 'Cari Hesaplar', icon: '≡ƒæñ' },\r\n  { key: 'kasa', label: 'Kasa ─░┼ƒlemleri', icon: '≡ƒÆ░' },\r\n  { key: 'bankTransactions', label: 'Banka ─░┼ƒlemleri', icon: '≡ƒÅª' },\r\n  { key: 'invoices', label: 'Faturalar', icon: '≡ƒº╛' },\r\n  { key: 'orders', label: 'Sipari┼ƒler', icon: '≡ƒôï' },\r\n  { key: 'stockMovements', label: 'Stok Hareketleri', icon: '≡ƒôè' },\r\n  { key: 'peletSuppliers', label: 'Pelet Tedarik├ºi', icon: '≡ƒ¬╡' },\r\n  { key: 'peletOrders', label: 'Pelet Sipari┼ƒ', icon: '≡ƒ¬╡' },\r\n  { key: 'boruSuppliers', label: 'Boru Tedarik├ºi', icon: '≡ƒö⌐' },\r\n  { key: 'boruOrders', label: 'Boru Sipari┼ƒ', icon: '≡ƒö⌐' },\r\n  { key: 'budgets', label: 'B├╝t├ºe', icon: '≡ƒôè' },\r\n  { key: 'returns', label: '─░adeler', icon: 'Γå⌐∩╕Å' },\r\n  { key: 'company', label: '┼₧irket Bilgileri', icon: '≡ƒÅó', isObject: true },\r\n  { key: 'pelletSettings', label: 'Pelet Ayarlar─▒', icon: 'ΓÜÖ∩╕Å', isObject: true },\r\n] as const;\r\n\r\n// ΓöÇΓöÇ Tam Geri Y├╝kleme Paneli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction FullRestorePanel({ showToast, showConfirm, save, db }: {\r\n  showToast: (m: string, t?: string) => void;\r\n  showConfirm: (t: string, m: string, ok: () => void, d?: boolean) => void;\r\n  save: (fn: (prev: DB) => DB) => void;\r\n  db: DB;\r\n}) {\r\n  const fileRef = useRef<HTMLInputElement>(null);\r\n  const [lastReport, setLastReport] = useState<RestoreReport | null>(null);\r\n\r\n  const handleFile = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    const file = e.target.files?.[0];\r\n    if (!file) return;\r\n    if (fileRef.current) fileRef.current.value = '';\r\n\r\n    showConfirm(\r\n      'ΓÜá∩╕Å Tam Geri Y├╝kleme',\r\n      `\"${file.name}\" dosyas─▒ndaki veriler y├╝kleniyor. Mevcut t├╝m veriler bu yedekle de─ƒi┼ƒtirilecek. ├ûnceki veri otomatik yedeklenir. Devam edilsin mi?`,\r\n      () => {\r\n        // ├ûnce mevcut veriyi yedekle\r\n        saveBackupToFirebase(db, `onceki_${new Date().toISOString().slice(0, 16).replace('T', '_').replace(':', '-')}`).catch(() => {});\r\n\r\n        const reader = new FileReader();\r\n        reader.onload = (ev) => {\r\n          try {\r\n            const raw = JSON.parse(ev.target?.result as string) as DB;\r\n            // fullRestoreDB'yi do─ƒrudan import etmek yerine save i├ºinde ├ºa─ƒ─▒r─▒yoruz\r\n            save(prev => {\r\n              // makeDefaultDB'ye eri┼ƒim yok burada ΓÇö prev'i default olarak kullan\r\n              const def = { ...prev };\r\n              // Temel yap─▒y─▒ koru, yedekteki veriyi ├╝zerine yaz\r\n              const merged: DB = { ...def, ...raw };\r\n              // Zorunlu array alanlar─▒\r\n              const arrayKeys = ['products','sales','suppliers','orders','cari','kasa','bankTransactions',\r\n                'matchRules','monitorRules','monitorLog','stockMovements','peletSuppliers','peletOrders',\r\n                'boruSuppliers','boruOrders','invoices','budgets','returns','_activityLog',\r\n                'ortakEmanetler','installments','partners','notes'] as const;\r\n              for (const key of arrayKeys) {\r\n                if (!Array.isArray(merged[key])) (merged as unknown as Record<string, unknown>)[key] = [];\r\n              }\r\n              if (!merged.kasalar || merged.kasalar.length === 0) merged.kasalar = def.kasalar;\r\n              if (!merged.company || typeof merged.company !== 'object') merged.company = def.company;\r\n              if (!merged.pelletSettings) merged.pelletSettings = def.pelletSettings;\r\n              if (!Array.isArray(merged.productCategories) || merged.productCategories.length === 0) merged.productCategories = def.productCategories;\r\n              return merged;\r\n            });\r\n\r\n            const report: RestoreReport = { added: 0, skippedDuplicate: 0, skippedInvalidName: 0, skippedMissingField: 0, warnings: [] };\r\n            // Ad kalite kontrol├╝ raporu\r\n            (raw.cari || []).forEach((c: { name?: unknown }) => {\r\n              if (typeof c.name !== 'string' || c.name.trim().length < 2 || /^\\d+$/.test(c.name.trim())) {\r\n                report.skippedInvalidName++;\r\n                report.warnings.push(`Cari gizlendi: \"${c.name}\" ΓÇö ge├ºersiz ad`);\r\n              }\r\n            });\r\n            (raw.products || []).forEach((p: { name?: unknown }) => {\r\n              if (typeof p.name !== 'string' || p.name.trim().length < 2 || /^\\d+$/.test(p.name.trim())) {\r\n                report.skippedInvalidName++;\r\n                report.warnings.push(`├£r├╝n gizlendi: \"${p.name}\" ΓÇö ge├ºersiz ad`);\r\n              }\r\n            });\r\n            setLastReport(report);\r\n\r\n            const msg = report.skippedInvalidName > 0\r\n              ? `Γ£à Geri y├╝kleme tamamland─▒. ${report.skippedInvalidName} ge├ºersiz kay─▒t gizlendi.`\r\n              : 'Γ£à Tam geri y├╝kleme ba┼ƒar─▒l─▒! ├ûnceki veri yedeklendi.';\r\n            showToast(msg, 'success');\r\n            setTimeout(() => window.location.reload(), 1800);\r\n          } catch {\r\n            showToast('Dosya okunamad─▒ veya ge├ºersiz format!', 'error');\r\n          }\r\n        };\r\n        reader.readAsText(file);\r\n      },\r\n      true\r\n    );\r\n  };\r\n\r\n  return (\r\n    <Card title=\"≡ƒöä Tam Geri Y├╝kleme\">\r\n      <div style={{ background: 'rgba(239,68,68,0.06)', border: '1px solid rgba(239,68,68,0.15)', borderRadius: 10, padding: '10px 16px', marginBottom: 14, color: '#fca5a5', fontSize: '0.83rem', lineHeight: 1.6 }}>\r\n        <strong>Dikkat:</strong> Mevcut t├╝m veriler yedekteki verilerle de─ƒi┼ƒtirilir. ─░┼ƒlem ├╢ncesi otomatik yedek al─▒n─▒r.\r\n        Yedekten gelen ge├ºersiz adl─▒ kay─▒tlar (bo┼ƒ, tek haneli, sadece say─▒) gizlenir.\r\n      </div>\r\n      <input ref={fileRef} type=\"file\" accept=\".json\" onChange={handleFile} style={{ display: 'none' }} />\r\n      <button\r\n        onClick={() => fileRef.current?.click()}\r\n        style={{ width: '100%', padding: '14px 0', background: 'rgba(239,68,68,0.08)', border: '2px dashed rgba(239,68,68,0.3)', borderRadius: 12, color: '#f87171', cursor: 'pointer', fontWeight: 700, fontSize: '0.95rem', transition: 'all 0.2s' }}\r\n        onMouseEnter={e => { (e.currentTarget as HTMLButtonElement).style.background = 'rgba(239,68,68,0.15)'; }}\r\n        onMouseLeave={e => { (e.currentTarget as HTMLButtonElement).style.background = 'rgba(239,68,68,0.08)'; }}\r\n      >\r\n        ≡ƒôé JSON Yedek Dosyas─▒ Se├º ΓÇö Tam Geri Y├╝kle\r\n      </button>\r\n\r\n      {lastReport && lastReport.warnings.length > 0 && (\r\n        <div style={{ marginTop: 12, background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.2)', borderRadius: 10, padding: '10px 14px' }}>\r\n          <div style={{ color: '#fbbf24', fontWeight: 700, fontSize: '0.82rem', marginBottom: 6 }}>ΓÜá∩╕Å Gizlenen Kay─▒tlar</div>\r\n          {lastReport.warnings.map((w, i) => (\r\n            <div key={i} style={{ color: '#94a3b8', fontSize: '0.75rem', padding: '2px 0' }}>ΓÇó {w}</div>\r\n          ))}\r\n        </div>\r\n      )}\r\n    </Card>\r\n  );\r\n}\r\n\r\nfunction SelectiveRestore({ showToast, showConfirm, save, db }: {\r\n  showToast: (m: string, t?: string) => void;\r\n  showConfirm: (t: string, m: string, ok: () => void, d?: boolean) => void;\r\n  save: (fn: (prev: DB) => DB) => void;\r\n  db: DB;\r\n}) {\r\n  const fileRef = useRef<HTMLInputElement>(null);\r\n  const [fileData, setFileData] = useState<Record<string, unknown> | null>(null);\r\n  const [fileName, setFileName] = useState('');\r\n  const [selected, setSelected] = useState<Set<string>>(new Set());\r\n  const [available, setAvailable] = useState<{ key: string; label: string; icon: string; count: number; isObject?: boolean }[]>([]);\r\n  const [lastReport, setLastReport] = useState<RestoreReport | null>(null);\r\n\r\n  const handleFile = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    const file = e.target.files?.[0];\r\n    if (!file) return;\r\n    setFileName(file.name);\r\n    const reader = new FileReader();\r\n    reader.onload = (ev) => {\r\n      try {\r\n        const data = JSON.parse(ev.target?.result as string);\r\n        if (typeof data !== 'object' || Array.isArray(data)) {\r\n          showToast('Ge├ºersiz JSON format─▒!', 'error');\r\n          return;\r\n        }\r\n        setFileData(data);\r\n        const avail: typeof available = [];\r\n        RESTORE_SECTIONS.forEach(s => {\r\n          const val = data[s.key];\r\n          if (s.key === 'company' || s.key === 'pelletSettings') {\r\n            if (val && typeof val === 'object' && !Array.isArray(val)) {\r\n              avail.push({ key: s.key, label: s.label, icon: s.icon, count: 1, isObject: true });\r\n            }\r\n          } else if (Array.isArray(val) && val.length > 0) {\r\n            avail.push({ key: s.key, label: s.label, icon: s.icon, count: val.length });\r\n          }\r\n        });\r\n        setAvailable(avail);\r\n        setSelected(new Set(avail.map(a => a.key)));\r\n      } catch {\r\n        showToast('JSON ayr─▒┼ƒt─▒r─▒lamad─▒!', 'error');\r\n      }\r\n    };\r\n    reader.readAsText(file);\r\n    if (fileRef.current) fileRef.current.value = '';\r\n  };\r\n\r\n  const toggleSection = (key: string) => {\r\n    setSelected(prev => {\r\n      const next = new Set(prev);\r\n      if (next.has(key)) next.delete(key); else next.add(key);\r\n      return next;\r\n    });\r\n  };\r\n\r\n  const selectAll = () => setSelected(new Set(available.map(a => a.key)));\r\n  const selectNone = () => setSelected(new Set());\r\n\r\n  const doRestore = () => {\r\n    if (!fileData || selected.size === 0) return;\r\n    const selCount = available.filter(a => selected.has(a.key)).reduce((s, a) => s + a.count, 0);\r\n    showConfirm(\r\n      'Se├ºimli Geri Y├╝kleme',\r\n      `${selected.size} b├╢l├╝m (${selCount} kay─▒t) i┼ƒlenecek. Mevcut ID'ler korunur, ge├ºersiz adlar atlan─▒r. Devam edilsin mi?`,\r\n      () => {\r\n        try {\r\n          // Geri y├╝kleme ├╢ncesi mevcut veriyi otomatik yedekle\r\n          const preLabel = `onceki_${new Date().toISOString().slice(0, 16).replace('T', '_').replace(':', '-')}`;\r\n          saveBackupToFirebase(db, preLabel).catch(() => {});\r\n\r\n          // Ak─▒ll─▒ birle┼ƒtirme ΓÇö ID kontrol├╝ + ad kalite kontrol├╝\r\n          const { db: mergedDb, report } = mergeRestoreDB(db, fileData as Partial<DB>, selected);\r\n          setLastReport(report);\r\n\r\n          save(() => mergedDb);\r\n\r\n          const msg = [\r\n            `Γ£à ${report.added} kay─▒t eklendi.`,\r\n            report.skippedDuplicate > 0 ? `${report.skippedDuplicate} tekrar (ID ├ºak─▒┼ƒmas─▒) atland─▒.` : '',\r\n            report.skippedInvalidName > 0 ? `${report.skippedInvalidName} ge├ºersiz adl─▒ kay─▒t atland─▒.` : '',\r\n            report.skippedMissingField > 0 ? `${report.skippedMissingField} eksik alanl─▒ kay─▒t atland─▒.` : '',\r\n          ].filter(Boolean).join(' ');\r\n\r\n          showToast(msg, report.skippedInvalidName > 0 || report.skippedMissingField > 0 ? 'info' : 'success');\r\n          setTimeout(() => window.location.reload(), 2000);\r\n        } catch {\r\n          showToast('Geri y├╝kleme s─▒ras─▒nda hata olu┼ƒtu!', 'error');\r\n        }\r\n      },\r\n      true\r\n    );\r\n  };\r\n\r\n  const reset = () => { setFileData(null); setFileName(''); setSelected(new Set()); setAvailable([]); setLastReport(null); };\r\n\r\n  return (\r\n    <Card title=\"≡ƒôé Se├ºimli Geri Y├╝kleme\">\r\n      <p style={{ color: '#64748b', fontSize: '0.88rem', marginBottom: 14, lineHeight: 1.6 }}>\r\n        Yedek dosyan─▒zdan <strong style={{ color: '#f59e0b' }}>istedi─ƒiniz b├╢l├╝mleri se├ºerek</strong> geri y├╝kleyin. T├╝m veriyi de─ƒi┼ƒtirmek zorunda de─ƒilsiniz.\r\n      </p>\r\n\r\n      {!fileData ? (\r\n        <>\r\n          <input ref={fileRef} type=\"file\" accept=\".json\" onChange={handleFile} style={{ display: 'none' }} />\r\n          <button onClick={() => fileRef.current?.click()} style={{ width: '100%', padding: '16px 0', background: 'rgba(59,130,246,0.08)', border: '2px dashed rgba(59,130,246,0.3)', borderRadius: 12, color: '#60a5fa', cursor: 'pointer', fontWeight: 700, fontSize: '0.95rem', transition: 'all 0.2s' }}\r\n            onMouseEnter={e => { (e.currentTarget as HTMLButtonElement).style.background = 'rgba(59,130,246,0.15)'; }}\r\n            onMouseLeave={e => { (e.currentTarget as HTMLButtonElement).style.background = 'rgba(59,130,246,0.08)'; }}>\r\n            JSON Yedek Dosyas─▒ Se├º\r\n          </button>\r\n        </>\r\n      ) : (\r\n        <div style={{ display: 'grid', gap: 12 }}>\r\n          <div style={{ display: 'flex', alignItems: 'center', gap: 10, padding: '10px 14px', background: 'rgba(16,185,129,0.06)', border: '1px solid rgba(16,185,129,0.15)', borderRadius: 10 }}>\r\n            <span style={{ color: '#10b981', fontSize: '1.1rem' }}>≡ƒôä</span>\r\n            <span style={{ color: '#10b981', fontWeight: 700, fontSize: '0.88rem', flex: 1 }}>{fileName}</span>\r\n            <span style={{ color: '#64748b', fontSize: '0.78rem' }}>{available.length} b├╢l├╝m bulundu</span>\r\n          </div>\r\n\r\n          <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>\r\n            <span style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.9rem' }}>Geri Y├╝klenecek B├╢l├╝mler:</span>\r\n            <button onClick={selectAll} style={{ padding: '4px 10px', background: 'rgba(16,185,129,0.1)', border: '1px solid rgba(16,185,129,0.2)', borderRadius: 6, color: '#10b981', cursor: 'pointer', fontWeight: 600, fontSize: '0.75rem' }}>T├╝m├╝n├╝ Se├º</button>\r\n            <button onClick={selectNone} style={{ padding: '4px 10px', background: 'rgba(239,68,68,0.1)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 6, color: '#ef4444', cursor: 'pointer', fontWeight: 600, fontSize: '0.75rem' }}>Hi├ºbirini Se├ºme</button>\r\n          </div>\r\n\r\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 8 }}>\r\n            {available.map(section => {\r\n              const isSelected = selected.has(section.key);\r\n              return (\r\n                <div key={section.key} onClick={() => toggleSection(section.key)} style={{\r\n                  display: 'flex', alignItems: 'center', gap: 10, padding: '10px 14px',\r\n                  background: isSelected ? 'rgba(59,130,246,0.08)' : 'rgba(0,0,0,0.2)',\r\n                  border: `1px solid ${isSelected ? 'rgba(59,130,246,0.3)' : 'rgba(255,255,255,0.04)'}`,\r\n                  borderRadius: 10, cursor: 'pointer', transition: 'all 0.15s',\r\n                }}>\r\n                  <div style={{\r\n                    width: 22, height: 22, borderRadius: 6, display: 'flex', alignItems: 'center', justifyContent: 'center',\r\n                    background: isSelected ? '#3b82f6' : 'rgba(255,255,255,0.06)',\r\n                    border: `1px solid ${isSelected ? '#3b82f6' : 'rgba(255,255,255,0.12)'}`,\r\n                    color: '#fff', fontSize: '0.7rem', fontWeight: 700, flexShrink: 0,\r\n                  }}>\r\n                    {isSelected ? 'Γ£ô' : ''}\r\n                  </div>\r\n                  <span style={{ fontSize: '0.95rem' }}>{section.icon}</span>\r\n                  <div style={{ flex: 1 }}>\r\n                    <div style={{ color: isSelected ? '#f1f5f9' : '#64748b', fontWeight: 600, fontSize: '0.82rem' }}>{section.label}</div>\r\n                    <div style={{ color: '#334155', fontSize: '0.72rem' }}>\r\n                      {section.isObject ? 'Ayarlar' : `${section.count} kay─▒t`}\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n\r\n          {selected.size > 0 && (\r\n            <div style={{ background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.15)', borderRadius: 10, padding: '10px 16px', color: '#fde68a', fontSize: '0.83rem' }}>\r\n              Mevcut ID'ler korunur. Ge├ºersiz adlar (bo┼ƒ, tek haneli, sadece say─▒) ve zorunlu alan─▒ eksik kay─▒tlar atlan─▒r.\r\n            </div>\r\n          )}\r\n\r\n          {lastReport && lastReport.warnings.length > 0 && (\r\n            <div style={{ background: 'rgba(239,68,68,0.06)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#f87171', fontWeight: 700, fontSize: '0.83rem', marginBottom: 8 }}>\r\n                ΓÜá∩╕Å Atlanan Kay─▒tlar ({lastReport.skippedDuplicate + lastReport.skippedInvalidName + lastReport.skippedMissingField})\r\n              </div>\r\n              <div style={{ display: 'flex', gap: 12, flexWrap: 'wrap', marginBottom: 8 }}>\r\n                {lastReport.skippedDuplicate > 0 && <span style={{ background: 'rgba(99,102,241,0.15)', color: '#818cf8', borderRadius: 6, padding: '2px 8px', fontSize: '0.75rem', fontWeight: 600 }}>≡ƒöü {lastReport.skippedDuplicate} tekrar ID</span>}\r\n                {lastReport.skippedInvalidName > 0 && <span style={{ background: 'rgba(239,68,68,0.15)', color: '#f87171', borderRadius: 6, padding: '2px 8px', fontSize: '0.75rem', fontWeight: 600 }}>Γ£ù {lastReport.skippedInvalidName} ge├ºersiz ad</span>}\r\n                {lastReport.skippedMissingField > 0 && <span style={{ background: 'rgba(245,158,11,0.15)', color: '#fbbf24', borderRadius: 6, padding: '2px 8px', fontSize: '0.75rem', fontWeight: 600 }}>ΓÜá {lastReport.skippedMissingField} eksik alan</span>}\r\n              </div>\r\n              <div style={{ maxHeight: 120, overflowY: 'auto', display: 'flex', flexDirection: 'column', gap: 3 }}>\r\n                {lastReport.warnings.map((w, i) => (\r\n                  <div key={i} style={{ color: '#94a3b8', fontSize: '0.75rem', padding: '2px 0', borderBottom: '1px solid rgba(255,255,255,0.04)' }}>ΓÇó {w}</div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          <div style={{ display: 'flex', gap: 10 }}>\r\n            {selected.size > 0 && (\r\n              <button onClick={doRestore} style={{ flex: 1, padding: '12px 0', background: 'linear-gradient(135deg, #2563eb, #3b82f6)', border: 'none', borderRadius: 10, color: '#fff', fontWeight: 700, cursor: 'pointer', fontSize: '0.9rem' }}>\r\n                {selected.size} B├╢l├╝m├╝ Geri Y├╝kle\r\n              </button>\r\n            )}\r\n            <button onClick={reset} style={{ padding: '12px 18px', background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', cursor: 'pointer', fontWeight: 600 }}>S─▒f─▒rla</button>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </Card>\r\n  );\r\n}\r\n\r\nconst KNOWN_ARRAYS: Record<string, string> = {\r\n  products: '├£r├╝nler', sales: 'Sat─▒┼ƒlar', suppliers: 'Tedarik├ºiler', cari: 'Cari M├╝┼ƒteriler',\r\n  kasa: 'Kasa Hareketleri', bankTransactions: 'Banka ─░┼ƒlemleri', orders: 'Sipari┼ƒler',\r\n  invoices: 'Faturalar', stockMovements: 'Stok Hareketleri', peletSuppliers: 'Pelet Tedarik├ºi',\r\n  peletOrders: 'Pelet Sipari┼ƒ', boruSuppliers: 'Boru Tedarik├ºi', boruOrders: 'Boru Sipari┼ƒ',\r\n  budgets: 'B├╝t├ºe', returns: '─░adeler', ortakEmanetler: 'Ortak Emanet', installments: 'Taksitler',\r\n};\r\n\r\nconst LEGACY_FIELD_MAP: Record<string, string> = {\r\n  urunler: 'products', satislar: 'sales', tedarikci: 'suppliers', musteriler: 'cari',\r\n  kasaHareketleri: 'kasa', bankHareketleri: 'bankTransactions', siparisler: 'orders',\r\n  faturalar: 'invoices', stokHareketleri: 'stockMovements', stoklar: 'products',\r\n  musteri: 'cari', tedarikcilar: 'suppliers', kasaIslemleri: 'kasa',\r\n};\r\n\r\ntype ConflictResolution = 'overwrite' | 'skip' | 'merge';\r\n\r\ninterface ConflictInfo {\r\n  entity: string;\r\n  label: string;\r\n  byId: number;\r\n  byName: number;\r\n  total: number;\r\n}\r\n\r\nconst CSV_COLUMN_MAP: Record<string, { target: string; field: string }> = {\r\n  'm├╝┼ƒteri': { target: 'cari', field: 'name' },\r\n  'musteri': { target: 'cari', field: 'name' },\r\n  'm├╝┼ƒteri ad─▒': { target: 'cari', field: 'name' },\r\n  'ad': { target: 'cari', field: 'name' },\r\n  'isim': { target: 'cari', field: 'name' },\r\n  'ad soyad': { target: 'cari', field: 'name' },\r\n  'telefon': { target: 'cari', field: 'phone' },\r\n  'tel': { target: 'cari', field: 'phone' },\r\n  'adres': { target: 'cari', field: 'address' },\r\n  'bakiye': { target: 'cari', field: 'balance' },\r\n  'bor├º': { target: 'cari', field: 'balance' },\r\n  'borc': { target: 'cari', field: 'balance' },\r\n  'tarih': { target: '_date', field: 'createdAt' },\r\n  'date': { target: '_date', field: 'createdAt' },\r\n  'tutar': { target: '_amount', field: 'amount' },\r\n  'toplam': { target: '_amount', field: 'total' },\r\n  'fiyat': { target: '_amount', field: 'price' },\r\n  '├╝r├╝n': { target: 'products', field: 'name' },\r\n  'urun': { target: 'products', field: 'name' },\r\n  '├╝r├╝n ad─▒': { target: 'products', field: 'name' },\r\n  'stok': { target: 'products', field: 'stock' },\r\n  'maliyet': { target: 'products', field: 'cost' },\r\n  'sat─▒┼ƒ fiyat─▒': { target: 'products', field: 'price' },\r\n  'kategori': { target: '_category', field: 'category' },\r\n  'a├º─▒klama': { target: '_desc', field: 'description' },\r\n  'aciklama': { target: '_desc', field: 'description' },\r\n  'not': { target: '_desc', field: 'note' },\r\n  'e-posta': { target: 'cari', field: 'email' },\r\n  'email': { target: 'cari', field: 'email' },\r\n};\r\n\r\nfunction parseCSV(text: string): Record<string, string>[] {\r\n  const lines = text.split(/\\r?\\n/).filter(l => l.trim());\r\n  if (lines.length < 2) return [];\r\n  const headers = lines[0].split(/[,;\\t]/).map(h => h.trim().replace(/^[\"']|[\"']$/g, ''));\r\n  return lines.slice(1).map(line => {\r\n    const values = line.split(/[,;\\t]/).map(v => v.trim().replace(/^[\"']|[\"']$/g, ''));\r\n    const row: Record<string, string> = {};\r\n    headers.forEach((h, i) => { row[h] = values[i] || ''; });\r\n    return row;\r\n  }).filter(row => Object.values(row).some(v => v !== ''));\r\n}\r\n\r\ninterface CsvColumnMapping {\r\n  csvColumn: string;\r\n  targetEntity: string;\r\n  targetField: string;\r\n  autoDetected: boolean;\r\n}\r\n\r\nfunction detectCsvColumns(headers: string[]): CsvColumnMapping[] {\r\n  return headers.map(h => {\r\n    const lower = h.toLowerCase().trim();\r\n    const match = CSV_COLUMN_MAP[lower];\r\n    if (match) {\r\n      return { csvColumn: h, targetEntity: match.target, targetField: match.field, autoDetected: true };\r\n    }\r\n    for (const [key, val] of Object.entries(CSV_COLUMN_MAP)) {\r\n      if (lower.includes(key)) {\r\n        return { csvColumn: h, targetEntity: val.target, targetField: val.field, autoDetected: true };\r\n      }\r\n    }\r\n    return { csvColumn: h, targetEntity: '', targetField: '', autoDetected: false };\r\n  });\r\n}\r\n\r\nfunction SmartImportManager({ db, save: _save, showToast, showConfirm }: {\r\n  db: DB;\r\n  save: (fn: (prev: DB) => DB) => void;\r\n  showToast: (m: string, t?: string) => void;\r\n  showConfirm: (t: string, m: string, ok: () => void, d?: boolean) => void;\r\n}) {\r\n  const fileRef = useRef<HTMLInputElement>(null);\r\n  const [stage, setStage] = useState<'idle' | 'mapping' | 'csvMapping' | 'preview' | 'done'>('idle');\r\n  const [rawData, setRawData] = useState<Record<string, unknown> | null>(null);\r\n  const [mapped, setMapped] = useState<Record<string, unknown> | null>(null);\r\n  const [errors, setErrors] = useState<string[]>([]);\r\n  const [warnings, setWarnings] = useState<string[]>([]);\r\n  const [stats, setStats] = useState<Record<string, number>>({});\r\n  const [conflicts, setConflicts] = useState<ConflictInfo[]>([]);\r\n  const [resolutions, setResolutions] = useState<Record<string, ConflictResolution>>({});\r\n  const [fieldMappings, setFieldMappings] = useState<Record<string, string>>({});\r\n  const [unknownFields, setUnknownFields] = useState<string[]>([]);\r\n  const [legacyMapped, setLegacyMapped] = useState<Record<string, string>>({});\r\n  const [csvRows, setCsvRows] = useState<Record<string, string>[]>([]);\r\n  const [csvMappings, setCsvMappings] = useState<CsvColumnMapping[]>([]);\r\n  const [csvTarget, setCsvTarget] = useState<string>('cari');\r\n\r\n  const detectFieldMappings = (data: Record<string, unknown>) => {\r\n    const unknown: string[] = [];\r\n    const autoMapped: Record<string, string> = {};\r\n    const knownAll = new Set([...Object.keys(KNOWN_ARRAYS), '_version', 'company', 'settings', 'pelletSettings', 'kasalar', 'matchRules', 'monitorRules', 'monitorLog', '_activityLog', 'soundSettings']);\r\n\r\n    Object.keys(data).forEach(key => {\r\n      if (!knownAll.has(key)) {\r\n        if (LEGACY_FIELD_MAP[key]) {\r\n          autoMapped[key] = LEGACY_FIELD_MAP[key];\r\n        } else {\r\n          unknown.push(key);\r\n        }\r\n      }\r\n    });\r\n    return { unknown, autoMapped };\r\n  };\r\n\r\n  const applyMappings = (data: Record<string, unknown>, mappings: Record<string, string>): Record<string, unknown> => {\r\n    const result: Record<string, unknown> = { ...data };\r\n    Object.entries(mappings).forEach(([src, dst]) => {\r\n      if (dst && dst !== '' && result[src] !== undefined) {\r\n        if (!result[dst] || !Array.isArray(result[dst])) {\r\n          result[dst] = result[src];\r\n        } else if (Array.isArray(result[dst]) && Array.isArray(result[src])) {\r\n          result[dst] = [...(result[dst] as unknown[]), ...(result[src] as unknown[])];\r\n        }\r\n        delete result[src];\r\n      }\r\n    });\r\n    return result;\r\n  };\r\n\r\n  const detectConflicts = (data: Record<string, unknown>): ConflictInfo[] => {\r\n    const checks: Array<{ entity: string; label: string; dbItems: { id?: string; name?: string; code?: string }[]; importKey: string }> = [\r\n      { entity: 'products', label: '├£r├╝n', dbItems: db.products, importKey: 'products' },\r\n      { entity: 'sales', label: 'Sat─▒┼ƒ', dbItems: db.sales, importKey: 'sales' },\r\n      { entity: 'cari', label: 'Cari M├╝┼ƒteri', dbItems: db.cari, importKey: 'cari' },\r\n      { entity: 'suppliers', label: 'Tedarik├ºi', dbItems: db.suppliers || [], importKey: 'suppliers' },\r\n    ];\r\n\r\n    return checks.map(({ entity, label, dbItems, importKey }) => {\r\n      const incoming = (data[importKey] as { id?: string; name?: string; code?: string }[]) || [];\r\n      const existingIds = new Set(dbItems.map(d => d.id).filter(Boolean));\r\n      const existingNames = new Set(dbItems.map(d => (d.name || '').toLowerCase().trim()).filter(Boolean));\r\n      const byId = incoming.filter(item => item.id && existingIds.has(item.id)).length;\r\n      const byName = incoming.filter(item => !item.id && item.name && existingNames.has(item.name.toLowerCase().trim())).length;\r\n      return { entity, label, byId, byName, total: byId + byName };\r\n    }).filter(c => c.total > 0);\r\n  };\r\n\r\n  const analyzeData = (data: Record<string, unknown>) => {\r\n    const errs: string[] = [];\r\n    const warns: string[] = [];\r\n    const st: Record<string, number> = {};\r\n\r\n    Object.entries(KNOWN_ARRAYS).forEach(([key]) => {\r\n      const val = data[key];\r\n      if (Array.isArray(val)) {\r\n        if (val.length > 0) st[key] = val.length;\r\n        if (val.length === 0) warns.push(`\"${KNOWN_ARRAYS[key]}\" alan─▒ bo┼ƒ`);\r\n      } else if (val !== undefined) {\r\n        errs.push(`\"${key}\" alan─▒ ge├ºersiz format ΓÇö dizi bekleniyor`);\r\n      }\r\n    });\r\n\r\n    if (!data.company || typeof data.company !== 'object') warns.push('┼₧irket bilgisi bulunamad─▒ ΓÇö varsay─▒lan olu┼ƒturulacak');\r\n    if (!data.pelletSettings) warns.push('Pelet ayarlar─▒ bulunamad─▒ ΓÇö varsay─▒lan kullan─▒lacak');\r\n    if (!data._version) warns.push('Versiyon bilgisi yok ΓÇö eski format olabilir, l├╝tfen kontrol edin');\r\n    else if ((data._version as number) < 1) warns.push(`Eski versiyon (${data._version}) ΓÇö baz─▒ alanlar eksik olabilir`);\r\n\r\n    return { errs, warns, st };\r\n  };\r\n\r\n  const handleFile = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    const file = e.target.files?.[0];\r\n    if (!file) return;\r\n    const ext = file.name.split('.').pop()?.toLowerCase() || '';\r\n    const reader = new FileReader();\r\n    reader.onload = (ev) => {\r\n      const text = ev.target?.result as string;\r\n\r\n      if (ext === 'csv' || ext === 'tsv' || ext === 'txt') {\r\n        const rows = parseCSV(text);\r\n        if (rows.length === 0) {\r\n          setErrors(['CSV dosyas─▒ bo┼ƒ veya ge├ºersiz format']);\r\n          setStage('preview');\r\n          return;\r\n        }\r\n        setCsvRows(rows);\r\n        const headers = Object.keys(rows[0]);\r\n        const mappings = detectCsvColumns(headers);\r\n        setCsvMappings(mappings);\r\n        const hasCariCols = mappings.some(m => m.targetEntity === 'cari');\r\n        const hasProductCols = mappings.some(m => m.targetEntity === 'products');\r\n        setCsvTarget(hasCariCols ? 'cari' : hasProductCols ? 'products' : 'cari');\r\n        setStage('csvMapping');\r\n        return;\r\n      }\r\n\r\n      try {\r\n        const data = JSON.parse(text);\r\n        if (typeof data !== 'object' || Array.isArray(data)) {\r\n          setErrors(['Ge├ºersiz JSON format─▒ ΓÇö nesne bekleniyor']);\r\n          setStage('preview');\r\n          setRawData(null);\r\n          return;\r\n        }\r\n        setRawData(data);\r\n        const { unknown, autoMapped } = detectFieldMappings(data);\r\n        setLegacyMapped(autoMapped);\r\n        setUnknownFields(unknown);\r\n        const initMappings: Record<string, string> = {};\r\n        unknown.forEach(f => { initMappings[f] = ''; });\r\n        setFieldMappings(initMappings);\r\n\r\n        if (unknown.length > 0 || Object.keys(autoMapped).length > 0) {\r\n          setStage('mapping');\r\n        } else {\r\n          proceedToPreview(data, {});\r\n        }\r\n      } catch {\r\n        setErrors(['Dosya ayr─▒┼ƒt─▒r─▒lamad─▒ ΓÇö JSON veya CSV format─▒n─▒ kontrol edin']);\r\n        setStage('preview');\r\n        setRawData(null);\r\n      }\r\n    };\r\n    reader.readAsText(file);\r\n    if (fileRef.current) fileRef.current.value = '';\r\n  };\r\n\r\n  const applyCsvImport = () => {\r\n    if (csvRows.length === 0) return;\r\n    const items: Record<string, unknown>[] = csvRows.map(row => {\r\n      const item: Record<string, unknown> = { id: crypto.randomUUID(), createdAt: new Date().toISOString(), updatedAt: new Date().toISOString() };\r\n      csvMappings.forEach(m => {\r\n        if (!m.targetField || m.targetField === '') return;\r\n        const val = row[m.csvColumn];\r\n        if (!val) return;\r\n        const numFields = ['balance', 'amount', 'total', 'price', 'stock', 'cost', 'quantity'];\r\n        if (numFields.includes(m.targetField)) {\r\n          item[m.targetField] = parseFloat(val.replace(/[^\\d.,-]/g, '').replace(',', '.')) || 0;\r\n        } else if (m.targetField === 'createdAt') {\r\n          try { item.createdAt = new Date(val).toISOString(); } catch { /* keep default */ }\r\n        } else {\r\n          item[m.targetField] = val;\r\n        }\r\n      });\r\n      if (csvTarget === 'cari') {\r\n        if (!item.type) item.type = 'musteri';\r\n        if (!item.balance) item.balance = 0;\r\n        if (!item.totalPurchases) item.totalPurchases = 0;\r\n      }\r\n      if (csvTarget === 'products') {\r\n        if (!item.stock) item.stock = 0;\r\n        if (!item.cost) item.cost = 0;\r\n        if (!item.price) item.price = 0;\r\n        if (!item.minStock) item.minStock = 5;\r\n        if (!item.category) item.category = '';\r\n      }\r\n      if (csvTarget === 'kasa') {\r\n        if (!item.type) item.type = 'gider';\r\n        if (!item.kasa) item.kasa = 'nakit';\r\n        if (!item.amount) item.amount = 0;\r\n        if (!item.description) item.description = (item.name as string) || 'CSV ─░├ºe Aktarma';\r\n        if (!item.category) item.category = 'diger';\r\n      }\r\n      return item;\r\n    });\r\n\r\n    const data: Record<string, unknown> = {};\r\n    data[csvTarget] = items;\r\n    setRawData(data);\r\n    proceedToPreview(data, {});\r\n  };\r\n\r\n  const proceedToPreview = (data: Record<string, unknown>, userMappings: Record<string, string>) => {\r\n    const allMappings = { ...legacyMapped, ...userMappings };\r\n    const resolved = applyMappings(data, allMappings);\r\n    const { errs, warns, st } = analyzeData(resolved);\r\n    const detectedConflicts = detectConflicts(resolved);\r\n    const initRes: Record<string, ConflictResolution> = {};\r\n    detectedConflicts.forEach(c => { initRes[c.entity] = 'overwrite'; });\r\n    setMapped(resolved);\r\n    setErrors(errs);\r\n    setWarnings(warns);\r\n    setStats(st);\r\n    setConflicts(detectedConflicts);\r\n    setResolutions(initRes);\r\n    setStage('preview');\r\n  };\r\n\r\n  const doImport = () => {\r\n    if (!mapped) return;\r\n    showConfirm('Veri Aktar─▒m─▒n─▒ Onayla', 'Se├ºilen ├ºak─▒┼ƒma ├º├╢z├╝mleri uygulanacak ve veriler i├ºe aktar─▒lacak. Mevcut veriler etkilenebilir. Onayl─▒yor musunuz?', () => {\r\n      try {\r\n        const raw = localStorage.getItem('sobaYonetim');\r\n        const current = raw ? JSON.parse(raw) : {};\r\n        const def = {\r\n          _version: 1, products: [], sales: [], suppliers: [], orders: [], cari: [], kasa: [],\r\n          kasalar: [{ id: 'nakit', name: 'Nakit', icon: '≡ƒÆ╡' }, { id: 'banka', name: 'Banka', icon: '≡ƒÅª' }],\r\n          bankTransactions: [], matchRules: [], monitorRules: [], monitorLog: [], stockMovements: [],\r\n          peletSuppliers: [], peletOrders: [], boruSuppliers: [], boruOrders: [],\r\n          invoices: [], budgets: [], returns: [], _activityLog: [],\r\n          company: current.company || {}, settings: {}, pelletSettings: { gramaj: 14, kgFiyat: 6.5, cuvalKg: 15, critDays: 3 },\r\n          ortakEmanetler: [], installments: [],\r\n        };\r\n        const finalData: Record<string, unknown> = { ...def, ...mapped };\r\n\r\n        const conflictEntities = ['products', 'cari', 'suppliers', 'sales'] as const;\r\n        conflictEntities.forEach(entity => {\r\n          const resolution = resolutions[entity] || 'overwrite';\r\n          const incoming = (mapped[entity] as { id?: string; name?: string }[]) || [];\r\n          const existing = (current[entity] as { id?: string; name?: string }[]) || [];\r\n\r\n          if (resolution === 'skip') {\r\n            const existingIds = new Set(existing.map((x: { id?: string }) => x.id).filter(Boolean));\r\n            const existingNames = new Set(existing.map((x: { name?: string }) => (x.name || '').toLowerCase()).filter(Boolean));\r\n            finalData[entity] = [\r\n              ...existing,\r\n              ...incoming.filter(item =>\r\n                item.name && // name bo┼ƒ/undefined olanlar─▒ filtrele\r\n                !existingIds.has(item.id) &&\r\n                !existingNames.has((item.name || '').toLowerCase())\r\n              ),\r\n            ];\r\n          } else if (resolution === 'merge') {\r\n            const existingMap = new Map(existing.map((x: { id?: string }) => [x.id, x]));\r\n            incoming.forEach(item => {\r\n              if (item.id && existingMap.has(item.id)) {\r\n                existingMap.set(item.id, { ...existingMap.get(item.id)!, ...item });\r\n              } else {\r\n                existingMap.set(item.id || Math.random().toString(), item);\r\n              }\r\n            });\r\n            finalData[entity] = Array.from(existingMap.values());\r\n          }\r\n        });\r\n\r\n        if (!finalData.kasalar || (finalData.kasalar as unknown[]).length === 0) finalData.kasalar = def.kasalar;\r\n        if (!finalData.pelletSettings) finalData.pelletSettings = def.pelletSettings;\r\n        if (!finalData.company || typeof finalData.company !== 'object') finalData.company = def.company;\r\n\r\n        localStorage.setItem('sobaYonetim', JSON.stringify(finalData));\r\n        setStage('done');\r\n        showToast('Veriler ba┼ƒar─▒yla aktar─▒ld─▒! Sayfa yenilenecek...', 'success');\r\n        setTimeout(() => window.location.reload(), 1200);\r\n      } catch {\r\n        showToast('─░├ºe aktarma s─▒ras─▒nda hata olu┼ƒtu!', 'error');\r\n      }\r\n    }, true);\r\n  };\r\n\r\n  const reset = () => {\r\n    setStage('idle'); setRawData(null); setMapped(null); setErrors([]); setWarnings([]);\r\n    setStats({}); setConflicts([]); setResolutions({}); setFieldMappings({}); setUnknownFields([]); setLegacyMapped({});\r\n    setCsvRows([]); setCsvMappings([]); setCsvTarget('cari');\r\n  };\r\n\r\n  const btnStyle = (active: boolean, color: string) => ({\r\n    padding: '6px 14px', border: `1px solid ${active ? color : '#334155'}`, borderRadius: 8,\r\n    background: active ? `${color}20` : 'transparent', color: active ? color : '#64748b',\r\n    cursor: 'pointer', fontWeight: 600, fontSize: '0.8rem',\r\n  });\r\n\r\n  return (\r\n    <Card title=\"≡ƒºá Ak─▒ll─▒ Veri ─░├ºe Aktarma\">\r\n      <p style={{ color: '#64748b', fontSize: '0.88rem', marginBottom: 14, lineHeight: 1.6 }}>\r\n        JSON, CSV veya TXT dosyan─▒z─▒ analiz eder; kolonlar─▒ otomatik e┼ƒler (m├╝┼ƒteri, tarih, tutar vb.), manuel d├╝zeltme imkan─▒ sunar ve ├ºak─▒┼ƒmalar─▒ ├º├╢zerek g├╝venli aktar─▒m yapar.\r\n      </p>\r\n\r\n      {stage === 'idle' && (\r\n        <>\r\n          <input ref={fileRef} type=\"file\" accept=\".json,.csv,.tsv,.txt\" onChange={handleFile} style={{ display: 'none' }} />\r\n          <button onClick={() => fileRef.current?.click()} style={{ width: '100%', padding: '16px 0', background: 'rgba(139,92,246,0.08)', border: '2px dashed rgba(139,92,246,0.3)', borderRadius: 12, color: '#a78bfa', cursor: 'pointer', fontWeight: 700, fontSize: '0.95rem' }}>\r\n            Dosya Se├º & Ak─▒ll─▒ Analiz Ba┼ƒlat\r\n          </button>\r\n          <div style={{ display: 'flex', gap: 8, marginTop: 10, justifyContent: 'center' }}>\r\n            {['JSON', 'CSV', 'TSV', 'TXT'].map(f => (\r\n              <span key={f} style={{ padding: '3px 10px', background: 'rgba(139,92,246,0.06)', border: '1px solid rgba(139,92,246,0.15)', borderRadius: 6, color: '#a78bfa', fontSize: '0.72rem', fontWeight: 600 }}>.{f.toLowerCase()}</span>\r\n            ))}\r\n          </div>\r\n        </>\r\n      )}\r\n\r\n      {stage === 'csvMapping' && csvRows.length > 0 && (\r\n        <div style={{ display: 'grid', gap: 14 }}>\r\n          <div style={{ background: 'rgba(16,185,129,0.06)', border: '1px solid rgba(16,185,129,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n            <div style={{ color: '#10b981', fontWeight: 700, marginBottom: 4 }}>{csvRows.length} sat─▒r okundu</div>\r\n            <div style={{ color: '#64748b', fontSize: '0.82rem' }}>Kolon e┼ƒle┼ƒmelerini kontrol edin ve gerekirse d├╝zeltin</div>\r\n          </div>\r\n\r\n          <div>\r\n            <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 12 }}>\r\n              <span style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.9rem' }}>Hedef Veri T├╝r├╝:</span>\r\n              {[\r\n                { id: 'cari', label: 'Cari M├╝┼ƒteri', icon: '≡ƒæñ' },\r\n                { id: 'products', label: '├£r├╝n', icon: '≡ƒôª' },\r\n                { id: 'kasa', label: 'Kasa', icon: '≡ƒÆ░' },\r\n              ].map(t => (\r\n                <button key={t.id} onClick={() => setCsvTarget(t.id)} style={{\r\n                  padding: '6px 14px', border: `1px solid ${csvTarget === t.id ? '#ff5722' : '#334155'}`,\r\n                  borderRadius: 8, background: csvTarget === t.id ? 'rgba(255,87,34,0.15)' : 'transparent',\r\n                  color: csvTarget === t.id ? '#ff7043' : '#64748b', cursor: 'pointer', fontWeight: 600, fontSize: '0.8rem',\r\n                }}>{t.icon} {t.label}</button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          <div style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.9rem' }}>Kolon E┼ƒle┼ƒmeleri</div>\r\n          {csvMappings.map((m, i) => (\r\n            <div key={m.csvColumn} style={{ display: 'flex', gap: 10, alignItems: 'center' }}>\r\n              <div style={{ minWidth: 140, padding: '6px 10px', background: 'rgba(0,0,0,0.3)', borderRadius: 6, color: m.autoDetected ? '#10b981' : '#f59e0b', fontFamily: 'monospace', fontSize: '0.82rem', fontWeight: 600 }}>\r\n                {m.csvColumn}\r\n                {m.autoDetected && <span style={{ fontSize: '0.65rem', marginLeft: 4, color: '#10b981' }}>otomatik</span>}\r\n              </div>\r\n              <span style={{ color: '#475569' }}>ΓåÆ</span>\r\n              <select\r\n                value={m.targetField}\r\n                onChange={e => {\r\n                  const next = [...csvMappings];\r\n                  next[i] = { ...next[i], targetField: e.target.value, autoDetected: false };\r\n                  setCsvMappings(next);\r\n                }}\r\n                style={{ flex: 1, padding: '7px 10px', background: '#1e293b', border: '1px solid #334155', borderRadius: 8, color: '#f1f5f9', fontSize: '0.82rem' }}\r\n              >\r\n                <option value=\"\">ΓÇö Yoksay ΓÇö</option>\r\n                <option value=\"name\">Ad / ─░sim</option>\r\n                <option value=\"phone\">Telefon</option>\r\n                <option value=\"email\">E-posta</option>\r\n                <option value=\"address\">Adres</option>\r\n                <option value=\"balance\">Bakiye / Bor├º</option>\r\n                <option value=\"amount\">Tutar</option>\r\n                <option value=\"total\">Toplam</option>\r\n                <option value=\"price\">Fiyat</option>\r\n                <option value=\"cost\">Maliyet</option>\r\n                <option value=\"stock\">Stok</option>\r\n                <option value=\"category\">Kategori</option>\r\n                <option value=\"description\">A├º─▒klama</option>\r\n                <option value=\"note\">Not</option>\r\n                <option value=\"createdAt\">Tarih</option>\r\n              </select>\r\n            </div>\r\n          ))}\r\n\r\n          {csvRows.length > 0 && (\r\n            <div style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '12px 16px', overflowX: 'auto' }}>\r\n              <div style={{ color: '#64748b', fontWeight: 700, fontSize: '0.78rem', marginBottom: 8 }}>├ûnizleme (ilk 3 sat─▒r):</div>\r\n              <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '0.78rem' }}>\r\n                <thead>\r\n                  <tr>\r\n                    {Object.keys(csvRows[0]).map(h => (\r\n                      <th key={h} style={{ padding: '4px 8px', textAlign: 'left', color: '#94a3b8', borderBottom: '1px solid rgba(255,255,255,0.06)', whiteSpace: 'nowrap' }}>{h}</th>\r\n                    ))}\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  {csvRows.slice(0, 3).map((row, ri) => (\r\n                    <tr key={ri}>\r\n                      {Object.values(row).map((v, ci) => (\r\n                        <td key={ci} style={{ padding: '4px 8px', color: '#e2e8f0', borderBottom: '1px solid rgba(255,255,255,0.03)', whiteSpace: 'nowrap', maxWidth: 150, overflow: 'hidden', textOverflow: 'ellipsis' }}>{v}</td>\r\n                      ))}\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          )}\r\n\r\n          <div style={{ display: 'flex', gap: 10 }}>\r\n            <button onClick={applyCsvImport} style={{ flex: 1, padding: '11px 0', background: 'linear-gradient(135deg, #7c3aed, #8b5cf6)', border: 'none', borderRadius: 10, color: '#fff', fontWeight: 700, cursor: 'pointer' }}>\r\n              Devam ΓåÆ ├ûnizleme & ├çak─▒┼ƒma ├ç├╢z├╝m├╝\r\n            </button>\r\n            <button onClick={reset} style={{ padding: '11px 18px', background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', cursor: 'pointer' }}>S─▒f─▒rla</button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {stage === 'mapping' && rawData && (\r\n        <div style={{ display: 'grid', gap: 14 }}>\r\n          <div style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.95rem' }}>≡ƒù║∩╕Å Alan E┼ƒleme (Field Mapping)</div>\r\n          {Object.keys(legacyMapped).length > 0 && (\r\n            <div style={{ background: 'rgba(16,185,129,0.06)', border: '1px solid rgba(16,185,129,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#10b981', fontWeight: 700, marginBottom: 8 }}>Γ£à Otomatik Alg─▒lanan Eski Alanlar</div>\r\n              {Object.entries(legacyMapped).map(([src, dst]) => (\r\n                <div key={src} style={{ display: 'flex', gap: 8, alignItems: 'center', marginBottom: 6, fontSize: '0.85rem' }}>\r\n                  <span style={{ color: '#f59e0b', fontFamily: 'monospace', background: 'rgba(0,0,0,0.3)', padding: '2px 8px', borderRadius: 4 }}>{src}</span>\r\n                  <span style={{ color: '#475569' }}>ΓåÆ</span>\r\n                  <span style={{ color: '#10b981', fontFamily: 'monospace', background: 'rgba(0,0,0,0.3)', padding: '2px 8px', borderRadius: 4 }}>{dst}</span>\r\n                  <span style={{ color: '#64748b', fontSize: '0.75rem' }}>({KNOWN_ARRAYS[dst] || dst})</span>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          )}\r\n          {unknownFields.length > 0 && (\r\n            <div style={{ background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#fbbf24', fontWeight: 700, marginBottom: 10 }}>ΓÜá∩╕Å Tan─▒nmayan Alanlar ΓÇö E┼ƒleme Se├ºin</div>\r\n              {unknownFields.map(field => (\r\n                <div key={field} style={{ display: 'flex', gap: 10, alignItems: 'center', marginBottom: 10 }}>\r\n                  <span style={{ color: '#f59e0b', fontFamily: 'monospace', background: 'rgba(0,0,0,0.3)', padding: '3px 10px', borderRadius: 6, minWidth: 120, textAlign: 'center' }}>{field}</span>\r\n                  <span style={{ color: '#475569', fontSize: '0.9rem' }}>ΓåÆ</span>\r\n                  <select\r\n                    value={fieldMappings[field] || ''}\r\n                    onChange={e => setFieldMappings(prev => ({ ...prev, [field]: e.target.value }))}\r\n                    style={{ flex: 1, padding: '7px 10px', background: '#1e293b', border: '1px solid #334155', borderRadius: 8, color: '#f1f5f9', fontSize: '0.85rem' }}\r\n                  >\r\n                    <option value=\"\">ΓÇö Yoksay (aktarma)</option>\r\n                    {Object.entries(KNOWN_ARRAYS).map(([k, label]) => (\r\n                      <option key={k} value={k}>{label} ({k})</option>\r\n                    ))}\r\n                  </select>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          )}\r\n          <div style={{ display: 'flex', gap: 10 }}>\r\n            <button onClick={() => proceedToPreview(rawData, fieldMappings)} style={{ flex: 1, padding: '11px 0', background: 'linear-gradient(135deg, #7c3aed, #8b5cf6)', border: 'none', borderRadius: 10, color: '#fff', fontWeight: 700, cursor: 'pointer' }}>\r\n              Devam ΓåÆ ├ûnizleme & ├çak─▒┼ƒma ├ç├╢z├╝m├╝\r\n            </button>\r\n            <button onClick={reset} style={{ padding: '11px 18px', background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', cursor: 'pointer' }}>S─▒f─▒rla</button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {stage === 'preview' && (\r\n        <div style={{ display: 'grid', gap: 12 }}>\r\n          {errors.length > 0 && (\r\n            <div style={{ background: 'rgba(239,68,68,0.06)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#f87171', fontWeight: 700, marginBottom: 8 }}>Γ¥î Hatalar</div>\r\n              {errors.map((e, i) => <div key={i} style={{ color: '#fca5a5', fontSize: '0.85rem', marginBottom: 4 }}>ΓÇó {e}</div>)}\r\n            </div>\r\n          )}\r\n          {warnings.length > 0 && (\r\n            <div style={{ background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.15)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#fbbf24', fontWeight: 700, marginBottom: 8 }}>ΓÜá∩╕Å Uyar─▒lar</div>\r\n              {warnings.map((w, i) => <div key={i} style={{ color: '#fde68a', fontSize: '0.85rem', marginBottom: 4 }}>ΓÇó {w}</div>)}\r\n            </div>\r\n          )}\r\n          {Object.keys(stats).length > 0 && (\r\n            <div style={{ background: 'rgba(59,130,246,0.06)', border: '1px solid rgba(59,130,246,0.15)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#60a5fa', fontWeight: 700, marginBottom: 8 }}>≡ƒôè ─░├ºe Aktar─▒lacak Kay─▒tlar</div>\r\n              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(140px, 1fr))', gap: 8 }}>\r\n                {Object.entries(stats).map(([k, v]) => (\r\n                  <div key={k} style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 8, padding: '8px 10px', textAlign: 'center' }}>\r\n                    <div style={{ color: '#f1f5f9', fontWeight: 700 }}>{v}</div>\r\n                    <div style={{ color: '#475569', fontSize: '0.72rem' }}>{KNOWN_ARRAYS[k] || k}</div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          )}\r\n          {conflicts.length > 0 && (\r\n            <div style={{ background: 'rgba(239,68,68,0.06)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 10, padding: '12px 16px' }}>\r\n              <div style={{ color: '#f87171', fontWeight: 700, marginBottom: 12 }}>ΓÜí ├çak─▒┼ƒma ├ç├╢z├╝m├╝</div>\r\n              {conflicts.map(c => (\r\n                <div key={c.entity} style={{ marginBottom: 14, paddingBottom: 12, borderBottom: '1px solid rgba(255,255,255,0.05)' }}>\r\n                  <div style={{ color: '#fca5a5', fontSize: '0.85rem', marginBottom: 8 }}>\r\n                    <strong>{c.label}</strong>: {c.byId > 0 && `${c.byId} ayn─▒ ID`}{c.byId > 0 && c.byName > 0 && ', '}{c.byName > 0 && `${c.byName} ayn─▒ isim`} ├ºak─▒┼ƒmas─▒\r\n                  </div>\r\n                  <div style={{ display: 'flex', gap: 8 }}>\r\n                    <button onClick={() => setResolutions(r => ({ ...r, [c.entity]: 'overwrite' }))} style={btnStyle(resolutions[c.entity] === 'overwrite', '#ef4444')}>\r\n                      ≡ƒöä ├£zerine Yaz\r\n                    </button>\r\n                    <button onClick={() => setResolutions(r => ({ ...r, [c.entity]: 'skip' }))} style={btnStyle(resolutions[c.entity] === 'skip', '#f59e0b')}>\r\n                      ΓÅ¡∩╕Å ├çak─▒┼ƒanlar─▒ Atla\r\n                    </button>\r\n                    <button onClick={() => setResolutions(r => ({ ...r, [c.entity]: 'merge' }))} style={btnStyle(resolutions[c.entity] === 'merge', '#10b981')}>\r\n                      ≡ƒöÇ Birle┼ƒtir\r\n                    </button>\r\n                  </div>\r\n                  <div style={{ fontSize: '0.75rem', color: '#475569', marginTop: 6 }}>\r\n                    {resolutions[c.entity] === 'overwrite' && 'Mevcut kay─▒tlar yeni verilerle tamamen de─ƒi┼ƒtirilir.'}\r\n                    {resolutions[c.entity] === 'skip' && '├çak─▒┼ƒan kay─▒tlar atlan─▒r; mevcut veriler korunur, yeni olanlar eklenir.'}\r\n                    {resolutions[c.entity] === 'merge' && 'Mevcut kay─▒tlar yeni alanlarla g├╝ncellenir; hi├º kay─▒p olmaz.'}\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          )}\r\n          <div style={{ display: 'flex', gap: 10 }}>\r\n            {mapped && errors.length === 0 && (\r\n              <button onClick={doImport} style={{ flex: 1, padding: '11px 0', background: 'linear-gradient(135deg, #7c3aed, #8b5cf6)', border: 'none', borderRadius: 10, color: '#fff', fontWeight: 700, cursor: 'pointer' }}>\r\n                Γ£à Aktar─▒m─▒ Onayla & Ba┼ƒlat\r\n              </button>\r\n            )}\r\n            <button onClick={reset} style={{ padding: '11px 18px', background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', cursor: 'pointer' }}>S─▒f─▒rla</button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {stage === 'done' && (\r\n        <div style={{ textAlign: 'center', padding: '24px 0' }}>\r\n          <div style={{ fontSize: '3rem', marginBottom: 12 }}>Γ£à</div>\r\n          <div style={{ color: '#10b981', fontWeight: 700, fontSize: '1.1rem' }}>Veriler ba┼ƒar─▒yla aktar─▒ld─▒!</div>\r\n          <div style={{ color: '#64748b', fontSize: '0.85rem', marginTop: 6 }}>Sayfa yenileniyor...</div>\r\n        </div>\r\n      )}\r\n    </Card>\r\n  );\r\n}\r\n\r\nfunction VeriOnarim({ db, save, showToast, showConfirm }: { db: DB; save: (fn: (prev: DB) => DB) => void; showToast: (m: string, t?: string) => void; showConfirm: (title: string, msg: string, onOk: () => void, danger?: boolean) => void }) {\r\n  const [results, setResults] = useState<string[]>([]);\r\n\r\n  const diagnose = () => {\r\n    const issues: string[] = [];\r\n    const saleIds = db.sales.map(s => s.id);\r\n    const dupSales = saleIds.length - new Set(saleIds).size;\r\n    if (dupSales > 0) issues.push(`ΓÜá∩╕Å ${dupSales} tekrarlanan sat─▒┼ƒ kayd─▒`);\r\n    const negStock = db.products.filter(p => p.stock < 0).length;\r\n    if (negStock > 0) issues.push(`ΓÜá∩╕Å ${negStock} ├╝r├╝n├╝n stok de─ƒeri negatif`);\r\n    const cariIds = new Set(db.cari.map(c => c.id));\r\n    const orphanKasa = db.kasa.filter(k => k.cariId && !cariIds.has(k.cariId)).length;\r\n    if (orphanKasa > 0) issues.push(`ΓÜá∩╕Å ${orphanKasa} kasa kayd─▒ silinmi┼ƒ cariye ba─ƒl─▒`);\r\n    const soldProductIds = new Set(db.sales.flatMap(s => s.items?.map((i: { productId: string }) => i.productId) || [s.productId]).filter(Boolean));\r\n    const stocklessProducts = db.products.filter(p => soldProductIds.has(p.id) && p.stock === 0).length;\r\n    if (stocklessProducts > 0) issues.push(`Γä╣∩╕Å ${stocklessProducts} ├╝r├╝n sat─▒ld─▒ ama stok s─▒f─▒r`);\r\n    if (!db.company.name) issues.push('Γä╣∩╕Å ┼₧irket ad─▒ girilmemi┼ƒ');\r\n    const lsSize = new Blob([localStorage.getItem('sobaYonetim') || '']).size;\r\n    const lsKB = Math.round(lsSize / 1024);\r\n    issues.push(`≡ƒôè localStorage boyutu: ${lsKB} KB (limit ~5MB)`);\r\n    const orphanInvoices = (db.invoices || []).filter(inv => inv.cariId && !cariIds.has(inv.cariId)).length;\r\n    if (orphanInvoices > 0) issues.push(`ΓÜá∩╕Å ${orphanInvoices} fatura silinmi┼ƒ cariye ba─ƒl─▒`);\r\n    setResults(issues.length === 0 ? ['Γ£à Veri tutarl─▒l─▒k kontrol├╝ tamam. Sorun bulunamad─▒!'] : issues);\r\n  };\r\n\r\n  const fixNegativeStock = () => {\r\n    showConfirm('Stok D├╝zelt', 'Negatif stoklar s─▒f─▒ra ├ºekilecek. Devam edilsin mi?', () => {\r\n      save(prev => ({ ...prev, products: prev.products.map(p => p.stock < 0 ? { ...p, stock: 0 } : p) }));\r\n      showToast('Negatif stoklar d├╝zeltildi!');\r\n      diagnose();\r\n    });\r\n  };\r\n\r\n  const fixOrphanKasa = () => {\r\n    showConfirm('Orphan Temizle', 'Silinmi┼ƒ cariye ait kasa kay─▒tlar─▒ndaki cari ba─ƒlant─▒s─▒ kald─▒r─▒lacak. Devam?', () => {\r\n      const cariIds = new Set(db.cari.map(c => c.id));\r\n      save(prev => ({ ...prev, kasa: prev.kasa.map(k => k.cariId && !cariIds.has(k.cariId) ? { ...k, cariId: undefined } : k) }));\r\n      showToast('Orphan kasa kay─▒tlar─▒ d├╝zeltildi!');\r\n      diagnose();\r\n    });\r\n  };\r\n\r\n  const recalcCariBalance = () => {\r\n    showConfirm('Bakiye Yeniden Hesapla', 'T├╝m cari bakiyeleri kasa i┼ƒlemlerine g├╢re s─▒f─▒rdan hesaplanacak. Mevcut bakiyeler SIFIRLANACAK!', () => {\r\n      save(prev => {\r\n        const cari = prev.cari.map(c => {\r\n          const kasaEntries = prev.kasa.filter(k => k.cariId === c.id);\r\n          const newBalance = kasaEntries.reduce((s, k) => s + (k.type === 'gelir' ? k.amount : -k.amount), 0);\r\n          return { ...c, balance: newBalance };\r\n        });\r\n        return { ...prev, cari };\r\n      });\r\n      showToast('Cari bakiyeler yeniden hesapland─▒!');\r\n      diagnose();\r\n    }, true);\r\n  };\r\n\r\n  const removeDupSales = () => {\r\n    showConfirm('Tekrarlar─▒ Temizle', 'Ayn─▒ ID\\'li tekrarlanan sat─▒┼ƒ kay─▒tlar─▒ silinecek. Devam edilsin mi?', () => {\r\n      save(prev => {\r\n        const seen = new Set<string>();\r\n        return { ...prev, sales: prev.sales.filter(s => { if (seen.has(s.id)) return false; seen.add(s.id); return true; }) };\r\n      });\r\n      showToast('Tekrarlanan sat─▒┼ƒlar temizlendi!');\r\n      diagnose();\r\n    });\r\n  };\r\n\r\n  const mergeduplicateCari = () => {\r\n    const nameCounts: Record<string, string[]> = {};\r\n    db.cari.forEach(c => { const n = c.name.trim().toLowerCase(); if (!nameCounts[n]) nameCounts[n] = []; nameCounts[n].push(c.id); });\r\n    const dups = Object.entries(nameCounts).filter(([, ids]) => ids.length > 1);\r\n    if (dups.length === 0) { showToast('Tekrarlanan cari bulunamad─▒!'); return; }\r\n    showConfirm('Cari Birle┼ƒtir', `${dups.length} isimde tekrar var. ─░lk kay─▒t korunacak. Devam?`, () => {\r\n      save(prev => {\r\n        const toRemove = new Set<string>();\r\n        dups.forEach(([, ids]) => ids.slice(1).forEach(id => toRemove.add(id)));\r\n        return { ...prev, cari: prev.cari.filter(c => !toRemove.has(c.id)) };\r\n      });\r\n      showToast(`${dups.length} grup birle┼ƒtirildi!`);\r\n      diagnose();\r\n    }, true);\r\n  };\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 14 }}>\r\n      <Card title=\"≡ƒöº Veri Tutarl─▒l─▒k Kontrol├╝\">\r\n        <p style={{ color: '#64748b', fontSize: '0.85rem', marginBottom: 16, lineHeight: 1.6 }}>Veritaban─▒n─▒z─▒ analiz ederek tutars─▒z, eksik veya hatal─▒ kay─▒tlar─▒ tespit edin.</p>\r\n        <button onClick={diagnose} style={{ width: '100%', padding: '13px 0', background: 'linear-gradient(135deg,#3b82f6,#2563eb)', border: 'none', borderRadius: 12, color: '#fff', fontWeight: 800, cursor: 'pointer', fontSize: '0.95rem', marginBottom: 14 }}>\r\n          ≡ƒöì Veriyi Analiz Et\r\n        </button>\r\n        {results.length > 0 && (\r\n          <div style={{ display: 'grid', gap: 6 }}>\r\n            {results.map((r, i) => (\r\n              <div key={i} style={{ padding: '10px 14px', background: r.startsWith('Γ£à') ? 'rgba(16,185,129,0.08)' : r.startsWith('≡ƒôè') ? 'rgba(59,130,246,0.08)' : 'rgba(245,158,11,0.08)', border: `1px solid ${r.startsWith('Γ£à') ? 'rgba(16,185,129,0.2)' : r.startsWith('≡ƒôè') ? 'rgba(59,130,246,0.2)' : 'rgba(245,158,11,0.2)'}`, borderRadius: 9, color: '#e2e8f0', fontSize: '0.85rem' }}>\r\n                {r}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        )}\r\n      </Card>\r\n\r\n      <Card title=\"≡ƒ¢á∩╕Å Onar─▒m Ara├ºlar─▒\">\r\n        <div style={{ display: 'grid', gap: 10 }}>\r\n          {[\r\n            { label: '≡ƒôª Negatif Stoklar─▒ S─▒f─▒rla', desc: 'Stok de─ƒeri 0\\'─▒n alt─▒na d├╝┼ƒm├╝┼ƒ ├╝r├╝nleri s─▒f─▒ra ├ºeker', action: fixNegativeStock, color: '#f59e0b' },\r\n            { label: '≡ƒöù Orphan Kasa Ba─ƒlant─▒lar─▒n─▒ Temizle', desc: 'Silinmi┼ƒ cariye ba─ƒl─▒ kasa kay─▒tlar─▒ndaki ba─ƒlant─▒y─▒ kald─▒r─▒r', action: fixOrphanKasa, color: '#3b82f6' },\r\n            { label: 'ΓÜû∩╕Å Cari Bakiyeleri Yeniden Hesapla', desc: 'T├╝m bakiyeleri kasa i┼ƒlemlerine g├╢re ba┼ƒtan hesaplar', action: recalcCariBalance, color: '#8b5cf6' },\r\n            { label: '≡ƒùæ∩╕Å Tekrarlayan Sat─▒┼ƒ Kay─▒tlar─▒n─▒ Temizle', desc: 'Ayn─▒ ID ile ├ºift kaydedilmi┼ƒ sat─▒┼ƒlar─▒ siler', action: removeDupSales, color: '#10b981' },\r\n            { label: '≡ƒñ¥ Ayn─▒ ─░simli Cari Hesaplar─▒ Birle┼ƒtir', desc: 'Ayn─▒ isimde birden fazla cari varsa tek kay─▒t b─▒rak─▒r', action: mergeduplicateCari, color: '#ef4444' },\r\n          ].map(t => (\r\n            <div key={t.label} style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 16px', background: 'rgba(0,0,0,0.2)', borderRadius: 10, border: `1px solid ${t.color}15` }}>\r\n              <div style={{ flex: 1 }}>\r\n                <div style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.88rem' }}>{t.label}</div>\r\n                <div style={{ color: '#475569', fontSize: '0.78rem', marginTop: 2 }}>{t.desc}</div>\r\n              </div>\r\n              <button onClick={t.action} style={{ background: `${t.color}15`, border: `1px solid ${t.color}30`, borderRadius: 8, color: t.color, padding: '7px 14px', cursor: 'pointer', fontWeight: 700, fontSize: '0.8rem', whiteSpace: 'nowrap' }}>\r\n                Uygula\r\n              </button>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n\r\n      <Card title=\"≡ƒôï Sistem Bilgileri\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>\r\n          {[\r\n            { label: 'Toplam Kay─▒t', value: `${[db.products, db.sales, db.cari, db.kasa, db.invoices || [], db.budgets || []].reduce((s, a) => s + a.length, 0)} kay─▒t` },\r\n            { label: 'localStorage Boyutu', value: `${Math.round(new Blob([localStorage.getItem('sobaYonetim') || '']).size / 1024)} KB` },\r\n            { label: 'Uygulama Versiyonu', value: `v${db._version || 1}` },\r\n            { label: 'Son Veri G├╝ncellemesi', value: db.kasa.length > 0 ? new Date(Math.max(...db.kasa.map(k => new Date(k.updatedAt || k.createdAt).getTime()))).toLocaleDateString('tr-TR') : '-' },\r\n          ].map(s => (\r\n            <div key={s.label} style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '10px 14px' }}>\r\n              <div style={{ color: '#475569', fontSize: '0.72rem', fontWeight: 600, textTransform: 'uppercase', letterSpacing: '0.04em', marginBottom: 4 }}>{s.label}</div>\r\n              <div style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.9rem' }}>{s.value}</div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction DangerAction({ label, desc, onConfirm }: { label: string; desc: string; onConfirm: () => void }) {\r\n  const { showConfirm } = useConfirm();\r\n  return (\r\n    <div style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 16px', background: 'rgba(0,0,0,0.3)', borderRadius: 10, border: '1px solid rgba(255,255,255,0.04)' }}>\r\n      <div style={{ flex: 1 }}>\r\n        <div style={{ fontWeight: 600, color: '#f1f5f9', fontSize: '0.88rem' }}>{label}</div>\r\n        <div style={{ color: '#475569', fontSize: '0.78rem', marginTop: 2 }}>{desc}</div>\r\n      </div>\r\n      <button onClick={() => showConfirm(label, `${desc}. Bu i┼ƒlem geri al─▒namaz!`, onConfirm, true)} style={{ background: 'rgba(239,68,68,0.1)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: 8, color: '#f87171', padding: '6px 14px', cursor: 'pointer', fontWeight: 700, fontSize: '0.8rem', whiteSpace: 'nowrap' }}>\r\n        Temizle\r\n      </button>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction Card({ title, children }: { title: string; children: React.ReactNode }) {\r\n  return (\r\n    <div style={{ background: 'linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01))', borderRadius: 16, border: '1px solid rgba(255,255,255,0.07)', overflow: 'hidden' }}>\r\n      <div style={{ padding: '16px 22px', borderBottom: '1px solid rgba(255,255,255,0.05)' }}>\r\n        <h3 style={{ fontWeight: 700, color: '#f1f5f9', fontSize: '0.95rem' }}>{title}</h3>\r\n      </div>\r\n      <div style={{ padding: '20px 22px' }}>{children}</div>\r\n    </div>\r\n  );\r\n}\r\n\r\nconst lbl: React.CSSProperties = { display: 'block', marginBottom: 6, color: '#64748b', fontSize: '0.82rem', fontWeight: 600 };\r\nconst inp: React.CSSProperties = { width: '100%', padding: '10px 14px', background: 'rgba(0,0,0,0.4)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, color: '#f1f5f9', fontSize: '0.9rem', boxSizing: 'border-box' };\r\nconst btnPrimary: React.CSSProperties = { width: '100%', padding: '13px 0', background: 'linear-gradient(135deg, #ff5722, #ff7043)', border: 'none', borderRadius: 12, color: '#fff', fontWeight: 800, cursor: 'pointer', fontSize: '0.95rem' };\r\n\r\n// ΓöÇΓöÇ Ba─ƒlant─▒ Ayarlar─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction BaglantiAyarlari({ cfg, onChange, showToast }: {\r\n  cfg: ConnConfig;\r\n  onChange: (c: ConnConfig) => void;\r\n  showToast: (m: string, t?: string) => void;\r\n}) {\r\n  const [fbTest, setFbTest] = useState<{ ok: boolean; msg: string } | null>(null);\r\n  const [fbTesting, setFbTesting] = useState(false);\r\n  const [sbTest, setSbTest] = useState<{ ok: boolean; msg: string } | null>(null);\r\n  const [sbTesting, setSbTesting] = useState(false);\r\n\r\n  const setFb = (patch: Partial<typeof cfg.firebase>) =>\r\n    onChange({ ...cfg, firebase: { ...cfg.firebase, ...patch } });\r\n  const setSb = (patch: Partial<typeof cfg.supabase>) =>\r\n    onChange({ ...cfg, supabase: { ...cfg.supabase, ...patch } });\r\n\r\n  const handleFbTest = async () => {\r\n    setFbTesting(true); setFbTest(null);\r\n    const r = await testFirebase(cfg.firebase);\r\n    setFbTest(r);\r\n    setFbTesting(false);\r\n    showToast(r.ok ? 'Firebase ba─ƒlant─▒s─▒ ba┼ƒar─▒l─▒!' : 'Firebase ba─ƒlant─▒s─▒ ba┼ƒar─▒s─▒z!', r.ok ? 'success' : 'error');\r\n  };\r\n\r\n  const handleSbTest = async () => {\r\n    setSbTesting(true); setSbTest(null);\r\n    const r = await testSupabase(cfg.supabase);\r\n    setSbTest(r);\r\n    setSbTesting(false);\r\n    showToast(r.ok ? 'Supabase ba─ƒlant─▒s─▒ ba┼ƒar─▒l─▒!' : 'Supabase ba─ƒlant─▒s─▒ ba┼ƒar─▒s─▒z!', r.ok ? 'success' : 'error');\r\n  };\r\n\r\n  const handleSave = () => {\r\n    saveConnConfig(cfg);\r\n    showToast('Ba─ƒlant─▒ ayarlar─▒ kaydedildi! Sayfa yenilendi─ƒinde aktif olur.', 'success');\r\n  };\r\n\r\n  const handleReset = () => {\r\n    onChange(DEFAULT_CONN);\r\n    saveConnConfig(DEFAULT_CONN);\r\n    showToast('Varsay─▒lan ba─ƒlant─▒ ayarlar─▒ geri y├╝klendi!', 'success');\r\n  };\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 16 }}>\r\n\r\n      {/* Aktif Sa─ƒlay─▒c─▒ */}\r\n      <Card title=\"≡ƒöî Aktif Senkronizasyon Sa─ƒlay─▒c─▒s─▒\">\r\n        <p style={{ color: '#64748b', fontSize: '0.85rem', marginBottom: 14, lineHeight: 1.6 }}>\r\n          Verileriniz hangi bulut servisiyle senkronize edilsin? Sadece bir sa─ƒlay─▒c─▒ aktif olabilir.\r\n        </p>\r\n        <div style={{ display: 'flex', gap: 10 }}>\r\n          {([\r\n            { id: 'firebase', label: '≡ƒöÑ Firebase', desc: 'Google Firestore' },\r\n            { id: 'supabase', label: 'ΓÜí Supabase', desc: 'PostgreSQL tabanl─▒' },\r\n            { id: 'none',     label: '≡ƒÜ½ Yok',      desc: 'Sadece yerel' },\r\n          ] as const).map(p => (\r\n            <button\r\n              key={p.id}\r\n              onClick={() => onChange({ ...cfg, activeProvider: p.id })}\r\n              style={{\r\n                flex: 1, padding: '14px 10px', borderRadius: 12, cursor: 'pointer', textAlign: 'center',\r\n                background: cfg.activeProvider === p.id ? 'rgba(255,87,34,0.12)' : 'rgba(0,0,0,0.25)',\r\n                border: `2px solid ${cfg.activeProvider === p.id ? 'rgba(255,87,34,0.5)' : 'rgba(255,255,255,0.07)'}`,\r\n                transition: 'all 0.15s',\r\n              }}\r\n            >\r\n              <div style={{ fontWeight: 700, color: cfg.activeProvider === p.id ? '#ff7043' : '#f1f5f9', fontSize: '0.9rem' }}>{p.label}</div>\r\n              <div style={{ color: '#475569', fontSize: '0.72rem', marginTop: 4 }}>{p.desc}</div>\r\n              {cfg.activeProvider === p.id && (\r\n                <div style={{ marginTop: 6, fontSize: '0.68rem', color: '#10b981', fontWeight: 700 }}>Γ£ô Aktif</div>\r\n              )}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Firebase */}\r\n      <Card title=\"≡ƒöÑ Firebase Firestore\">\r\n        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 16 }}>\r\n          <div style={{ flex: 1, color: '#94a3b8', fontSize: '0.82rem' }}>\r\n            Firebase Firestore REST API ile senkronizasyon\r\n          </div>\r\n          <button\r\n            onClick={() => setFb({ enabled: !cfg.firebase.enabled })}\r\n            style={{ width: 48, height: 26, borderRadius: 13, border: 'none', cursor: 'pointer', position: 'relative', background: cfg.firebase.enabled ? '#10b981' : '#334155', transition: 'background 0.2s', flexShrink: 0 }}\r\n          >\r\n            <div style={{ width: 18, height: 18, borderRadius: '50%', background: '#fff', position: 'absolute', top: 4, left: cfg.firebase.enabled ? 26 : 4, transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n          </button>\r\n        </div>\r\n\r\n        {/* JSON Dosyas─▒ Y├╝kleme */}\r\n        <div style={{ marginBottom: 16, padding: '12px 14px', background: 'rgba(255,87,34,0.06)', border: '1px dashed rgba(255,87,34,0.3)', borderRadius: 10 }}>\r\n          <div style={{ color: '#ff7043', fontWeight: 700, fontSize: '0.82rem', marginBottom: 6 }}>≡ƒôü Firebase Config Dosyas─▒ Y├╝kle</div>\r\n          <div style={{ color: '#64748b', fontSize: '0.75rem', marginBottom: 10 }}>\r\n            Firebase Console'dan indirilen <code style={{ color: '#ff7043' }}>google-services.json</code> veya web config JSON dosyas─▒n─▒ y├╝kleyin ΓÇö alanlar otomatik dolar.\r\n          </div>\r\n          <label style={{ display: 'block', cursor: 'pointer' }}>\r\n            <div style={{ padding: '10px 14px', background: 'rgba(255,87,34,0.1)', border: '1px solid rgba(255,87,34,0.25)', borderRadius: 8, color: '#ff7043', fontWeight: 700, fontSize: '0.82rem', textAlign: 'center', cursor: 'pointer' }}>\r\n              ≡ƒôé JSON Dosyas─▒ Se├º\r\n            </div>\r\n            <input\r\n              type=\"file\"\r\n              accept=\".json\"\r\n              style={{ display: 'none' }}\r\n              onChange={e => {\r\n                const file = e.target.files?.[0];\r\n                if (!file) return;\r\n                const reader = new FileReader();\r\n                reader.onload = ev => {\r\n                  try {\r\n                    const json = JSON.parse(ev.target?.result as string);\r\n                    // google-services.json format─▒\r\n                    if (json.project_info && json.client) {\r\n                      const projectId = json.project_info.project_id;\r\n                      const apiKey = json.client?.[0]?.api_key?.[0]?.current_key || '';\r\n                      if (projectId) { setFb({ projectId, apiKey }); showToast('Γ£à google-services.json okundu!', 'success'); return; }\r\n                    }\r\n                    // Firebase web config format─▒: { apiKey, projectId, ... }\r\n                    if (json.apiKey && json.projectId) {\r\n                      setFb({ projectId: json.projectId, apiKey: json.apiKey });\r\n                      showToast('Γ£à Firebase config okundu!', 'success');\r\n                      return;\r\n                    }\r\n                    // firebaseConfig objesi i├ºinde\r\n                    if (json.firebaseConfig) {\r\n                      setFb({ projectId: json.firebaseConfig.projectId || '', apiKey: json.firebaseConfig.apiKey || '' });\r\n                      showToast('Γ£à Firebase config okundu!', 'success');\r\n                      return;\r\n                    }\r\n                    showToast('ΓÜá∩╕Å Tan─▒nan bir Firebase JSON format─▒ de─ƒil. Manuel girin.', 'warning');\r\n                  } catch {\r\n                    showToast('Γ¥î JSON dosyas─▒ okunamad─▒!', 'error');\r\n                  }\r\n                };\r\n                reader.readAsText(file);\r\n                e.target.value = '';\r\n              }}\r\n            />\r\n          </label>\r\n        </div>\r\n\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, opacity: cfg.firebase.enabled ? 1 : 0.5, pointerEvents: cfg.firebase.enabled ? 'auto' : 'none' }}>\r\n          <div>\r\n            <label style={lbl}>Project ID</label>\r\n            <input value={cfg.firebase.projectId} onChange={e => setFb({ projectId: e.target.value })} style={inp} placeholder=\"├╢rn: my-project-12345\" />\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>API Key</label>\r\n            <input type=\"password\" value={cfg.firebase.apiKey} onChange={e => setFb({ apiKey: e.target.value })} style={inp} placeholder=\"AIza...\" />\r\n          </div>\r\n          <div style={{ gridColumn: '1/-1' }}>\r\n            <label style={lbl}>Dok├╝man Yolu</label>\r\n            <input value={cfg.firebase.docPath} onChange={e => setFb({ docPath: e.target.value })} style={inp} placeholder=\"sync/main\" />\r\n            <div style={{ color: '#334155', fontSize: '0.72rem', marginTop: 4 }}>\r\n              Firestore'daki koleksiyon/dok├╝man yolu. ├ûrn: <code style={{ color: '#ff7043' }}>sync/main</code>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Olu┼ƒturulan URL ├╢nizleme */}\r\n        {cfg.firebase.projectId && cfg.firebase.apiKey && (\r\n          <div style={{ marginTop: 12, background: 'rgba(0,0,0,0.3)', borderRadius: 8, padding: '8px 12px', fontSize: '0.7rem', color: '#334155', fontFamily: 'monospace', wordBreak: 'break-all' }}>\r\n            {`https://firestore.googleapis.com/v1/projects/${cfg.firebase.projectId}/databases/(default)/documents/${cfg.firebase.docPath}?key=${cfg.firebase.apiKey.slice(0, 8)}...`}\r\n          </div>\r\n        )}\r\n\r\n        <div style={{ display: 'flex', gap: 10, marginTop: 14, alignItems: 'center' }}>\r\n          <button\r\n            onClick={handleFbTest}\r\n            disabled={fbTesting || !cfg.firebase.projectId || !cfg.firebase.apiKey}\r\n            style={{ padding: '9px 18px', background: 'rgba(255,87,34,0.12)', border: '1px solid rgba(255,87,34,0.25)', borderRadius: 9, color: '#ff7043', fontWeight: 700, cursor: 'pointer', fontSize: '0.85rem', opacity: (!cfg.firebase.projectId || !cfg.firebase.apiKey) ? 0.4 : 1 }}\r\n          >\r\n            {fbTesting ? 'Γƒ│ Test ediliyor...' : '≡ƒöì Ba─ƒlant─▒y─▒ Test Et'}\r\n          </button>\r\n          {fbTest && (\r\n            <div style={{ display: 'flex', alignItems: 'center', gap: 6, fontSize: '0.82rem', color: fbTest.ok ? '#10b981' : '#ef4444', fontWeight: 600 }}>\r\n              {fbTest.ok ? 'Γ£à' : 'Γ¥î'} {fbTest.msg}\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        {/* Nas─▒l al─▒n─▒r? */}\r\n        <details style={{ marginTop: 14 }}>\r\n          <summary style={{ color: '#475569', fontSize: '0.8rem', cursor: 'pointer', fontWeight: 600 }}>≡ƒôû Firebase bilgilerini nereden al─▒r─▒m?</summary>\r\n          <div style={{ marginTop: 10, background: 'rgba(0,0,0,0.2)', borderRadius: 10, padding: '12px 14px', fontSize: '0.8rem', color: '#64748b', lineHeight: 1.8 }}>\r\n            <div>1. <a href=\"https://console.firebase.google.com\" target=\"_blank\" rel=\"noreferrer\" style={{ color: '#ff7043' }}>console.firebase.google.com</a> ΓåÆ Projenizi se├ºin</div>\r\n            <div>2. Proje Ayarlar─▒ (ΓÜÖ∩╕Å) ΓåÆ Genel ΓåÆ Proje kimli─ƒi = <strong style={{ color: '#f1f5f9' }}>Project ID</strong></div>\r\n            <div>3. Proje Ayarlar─▒ ΓåÆ Web API anahtar─▒ = <strong style={{ color: '#f1f5f9' }}>API Key</strong></div>\r\n            <div>4. Firestore Database ΓåÆ Koleksiyon ve dok├╝man ad─▒ = <strong style={{ color: '#f1f5f9' }}>Dok├╝man Yolu</strong></div>\r\n            <div style={{ marginTop: 8, color: '#f59e0b' }}>ΓÜá∩╕Å Firestore g├╝venlik kurallar─▒n─▒ ayarlamay─▒ unutmay─▒n!</div>\r\n          </div>\r\n        </details>\r\n      </Card>\r\n\r\n      {/* Supabase */}\r\n      <Card title=\"ΓÜí Supabase\">\r\n        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 16 }}>\r\n          <div style={{ flex: 1, color: '#94a3b8', fontSize: '0.82rem' }}>\r\n            Supabase PostgreSQL ile senkronizasyon (REST API)\r\n          </div>\r\n          <button\r\n            onClick={() => setSb({ enabled: !cfg.supabase.enabled })}\r\n            style={{ width: 48, height: 26, borderRadius: 13, border: 'none', cursor: 'pointer', position: 'relative', background: cfg.supabase.enabled ? '#10b981' : '#334155', transition: 'background 0.2s', flexShrink: 0 }}\r\n          >\r\n            <div style={{ width: 18, height: 18, borderRadius: '50%', background: '#fff', position: 'absolute', top: 4, left: cfg.supabase.enabled ? 26 : 4, transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n          </button>\r\n        </div>\r\n\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, opacity: cfg.supabase.enabled ? 1 : 0.5, pointerEvents: cfg.supabase.enabled ? 'auto' : 'none' }}>\r\n          <div style={{ gridColumn: '1/-1' }}>\r\n            <label style={lbl}>Supabase URL</label>\r\n            <input value={cfg.supabase.url} onChange={e => setSb({ url: e.target.value })} style={inp} placeholder=\"https://xxxxxxxxxxxx.supabase.co\" />\r\n          </div>\r\n          <div style={{ gridColumn: '1/-1' }}>\r\n            <label style={lbl}>Anon Key (public)</label>\r\n            <input type=\"password\" value={cfg.supabase.anonKey} onChange={e => setSb({ anonKey: e.target.value })} style={inp} placeholder=\"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\" />\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>Tablo Ad─▒</label>\r\n            <input value={cfg.supabase.tableName} onChange={e => setSb({ tableName: e.target.value })} style={inp} placeholder=\"soba_sync\" />\r\n          </div>\r\n        </div>\r\n\r\n        {/* SQL ┼ƒemas─▒ */}\r\n        <details style={{ marginTop: 12 }}>\r\n          <summary style={{ color: '#475569', fontSize: '0.8rem', cursor: 'pointer', fontWeight: 600 }}>≡ƒôï Gerekli SQL ┼ƒemas─▒</summary>\r\n          <pre style={{ marginTop: 10, background: 'rgba(0,0,0,0.4)', borderRadius: 10, padding: '12px 14px', fontSize: '0.75rem', color: '#10b981', overflowX: 'auto', lineHeight: 1.6 }}>{`CREATE TABLE soba_sync (\r\n  id TEXT PRIMARY KEY DEFAULT 'main',\r\n  data JSONB NOT NULL,\r\n  version INTEGER DEFAULT 0,\r\n  updated_at TIMESTAMPTZ DEFAULT NOW()\r\n);\r\n\r\n-- RLS politikas─▒ (opsiyonel)\r\nALTER TABLE soba_sync ENABLE ROW LEVEL SECURITY;\r\nCREATE POLICY \"allow_all\" ON soba_sync FOR ALL USING (true);`}</pre>\r\n        </details>\r\n\r\n        <div style={{ display: 'flex', gap: 10, marginTop: 14, alignItems: 'center' }}>\r\n          <button\r\n            onClick={handleSbTest}\r\n            disabled={sbTesting || !cfg.supabase.url || !cfg.supabase.anonKey}\r\n            style={{ padding: '9px 18px', background: 'rgba(16,185,129,0.12)', border: '1px solid rgba(16,185,129,0.25)', borderRadius: 9, color: '#10b981', fontWeight: 700, cursor: 'pointer', fontSize: '0.85rem', opacity: (!cfg.supabase.url || !cfg.supabase.anonKey) ? 0.4 : 1 }}\r\n          >\r\n            {sbTesting ? 'Γƒ│ Test ediliyor...' : '≡ƒöì Ba─ƒlant─▒y─▒ Test Et'}\r\n          </button>\r\n          {sbTest && (\r\n            <div style={{ display: 'flex', alignItems: 'center', gap: 6, fontSize: '0.82rem', color: sbTest.ok ? '#10b981' : '#ef4444', fontWeight: 600 }}>\r\n              {sbTest.ok ? 'Γ£à' : 'Γ¥î'} {sbTest.msg}\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        <details style={{ marginTop: 14 }}>\r\n          <summary style={{ color: '#475569', fontSize: '0.8rem', cursor: 'pointer', fontWeight: 600 }}>≡ƒôû Supabase bilgilerini nereden al─▒r─▒m?</summary>\r\n          <div style={{ marginTop: 10, background: 'rgba(0,0,0,0.2)', borderRadius: 10, padding: '12px 14px', fontSize: '0.8rem', color: '#64748b', lineHeight: 1.8 }}>\r\n            <div>1. <a href=\"https://supabase.com/dashboard\" target=\"_blank\" rel=\"noreferrer\" style={{ color: '#10b981' }}>supabase.com/dashboard</a> ΓåÆ Projenizi se├ºin</div>\r\n            <div>2. Settings ΓåÆ API ΓåÆ Project URL = <strong style={{ color: '#f1f5f9' }}>Supabase URL</strong></div>\r\n            <div>3. Settings ΓåÆ API ΓåÆ anon public = <strong style={{ color: '#f1f5f9' }}>Anon Key</strong></div>\r\n            <div>4. SQL Editor'da yukar─▒daki ┼ƒemay─▒ ├ºal─▒┼ƒt─▒r─▒n</div>\r\n          </div>\r\n        </details>\r\n      </Card>\r\n\r\n      {/* Kaydet / S─▒f─▒rla */}\r\n      <div style={{ display: 'flex', gap: 10 }}>\r\n        <button onClick={handleReset} style={{ padding: '11px 18px', background: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, color: '#64748b', fontWeight: 700, cursor: 'pointer', fontSize: '0.88rem' }}>\r\n          Γå║ Varsay─▒lana S─▒f─▒rla\r\n        </button>\r\n        <button onClick={handleSave} style={{ flex: 1, padding: '11px 0', background: 'linear-gradient(135deg, #ff5722, #ff7043)', border: 'none', borderRadius: 10, color: '#fff', fontWeight: 800, cursor: 'pointer', fontSize: '0.88rem' }}>\r\n          ≡ƒÆ╛ Ba─ƒlant─▒ Ayarlar─▒n─▒ Kaydet\r\n        </button>\r\n      </div>\r\n\r\n      <div style={{ background: 'rgba(245,158,11,0.06)', border: '1px solid rgba(245,158,11,0.15)', borderRadius: 10, padding: '12px 16px', fontSize: '0.8rem', color: '#94a3b8', lineHeight: 1.7 }}>\r\n        ΓÜá∩╕Å Ba─ƒlant─▒ ayarlar─▒ de─ƒi┼ƒtirildikten sonra <strong style={{ color: '#f1f5f9' }}>sayfay─▒ yenileyin</strong> ΓÇö yeni ayarlar aktif olur.<br />\r\n        ≡ƒöÆ Ba─ƒlant─▒ ayarlar─▒ Firebase'e kaydedilir ΓÇö t├╝m cihazlarda ge├ºerlidir.\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\n// ΓöÇΓöÇ Aray├╝z Ayarlar─▒ ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction ArayuzAyarlari({ prefs, onChange, showToast }: {\r\n  prefs: UIPrefs;\r\n  onChange: (p: UIPrefs) => void;\r\n  showToast: (m: string, t?: string) => void;\r\n}) {\r\n  const set = (patch: Partial<UIPrefs>) => onChange({ ...prefs, ...patch });\r\n\r\n  const fontLabels: Record<number, string> = { 0.85: 'K├╝├º├╝k', 1: 'Normal', 1.1: 'B├╝y├╝k', 1.2: '├çok B├╝y├╝k' };\r\n  const animLabels: Record<string, string> = { hizli: 'ΓÜí H─▒zl─▒', normal: 'Γ£¿ Normal', yavas: '≡ƒÉó Yava┼ƒ', yok: '≡ƒÜ½ Yok' };\r\n  const radiusLabels: Record<number, string> = { 6: 'Keskin', 10: 'Az', 14: 'Normal', 20: 'Yuvarlak' };\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 16 }}>\r\n\r\n      {/* Haz─▒r Temalar */}\r\n      <Card title=\"≡ƒÄ¿ Temalar\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(150px, 1fr))', gap: 8 }}>\r\n          {THEMES.map(t => {\r\n            const isActive = prefs.accent === t.accent && prefs.bgBase === t.bg;\r\n            return (\r\n              <button\r\n                key={t.id}\r\n                onClick={() => { set({ accent: t.accent, bgBase: t.bg }); showToast(`${t.label} temas─▒ uyguland─▒!`, 'success'); }}\r\n                style={{ padding: '12px 10px', borderRadius: 12, cursor: 'pointer', textAlign: 'left', background: isActive ? `${t.accent}18` : 'rgba(0,0,0,0.3)', border: `2px solid ${isActive ? t.accent : 'rgba(255,255,255,0.07)'}`, transition: 'all 0.15s', position: 'relative', overflow: 'hidden' }}\r\n              >\r\n                <div style={{ display: 'flex', gap: 5, marginBottom: 7 }}>\r\n                  <div style={{ width: 18, height: 18, borderRadius: 5, background: t.accent, boxShadow: `0 0 8px ${t.accent}60` }} />\r\n                  <div style={{ width: 18, height: 18, borderRadius: 5, background: t.bg, border: '1px solid rgba(255,255,255,0.1)' }} />\r\n                </div>\r\n                <div style={{ fontWeight: 700, color: isActive ? t.accent : '#f1f5f9', fontSize: '0.82rem' }}>{t.label}</div>\r\n                <div style={{ color: '#475569', fontSize: '0.7rem', marginTop: 2 }}>{t.desc}</div>\r\n                {isActive && <div style={{ position: 'absolute', top: 7, right: 7, width: 16, height: 16, borderRadius: '50%', background: t.accent, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '0.6rem', color: '#fff', fontWeight: 900 }}>Γ£ô</div>}\r\n              </button>\r\n            );\r\n          })}\r\n        </div>\r\n      </Card>\r\n\r\n      {/* ├ûzel Renk */}\r\n      <Card title=\"≡ƒûî∩╕Å ├ûzel Renk Se├ºimi\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>\r\n          <div>\r\n            <label style={lbl}>Ana Renk (Accent)</label>\r\n            <div style={{ display: 'flex', gap: 10, alignItems: 'center' }}>\r\n              <input\r\n                type=\"color\" value={prefs.accent}\r\n                onChange={e => set({ accent: e.target.value })}\r\n                style={{ width: 48, height: 40, borderRadius: 8, border: 'none', cursor: 'pointer', background: 'none', padding: 2 }}\r\n              />\r\n              <input\r\n                type=\"text\" value={prefs.accent}\r\n                onChange={e => { if (/^#[0-9a-fA-F]{0,6}$/.test(e.target.value)) set({ accent: e.target.value }); }}\r\n                style={{ ...inp, flex: 1, fontFamily: 'monospace', fontSize: '0.88rem' }}\r\n                placeholder=\"#ff5722\"\r\n              />\r\n            </div>\r\n            {/* H─▒zl─▒ renk paleti */}\r\n            <div style={{ display: 'flex', gap: 6, marginTop: 10, flexWrap: 'wrap' }}>\r\n              {['#ff5722','#ef4444','#f59e0b','#10b981','#0ea5e9','#6366f1','#8b5cf6','#ec4899','#14b8a6','#84cc16'].map(c => (\r\n                <button key={c} onClick={() => set({ accent: c })}\r\n                  style={{ width: 26, height: 26, borderRadius: 7, background: c, border: prefs.accent === c ? '2px solid #fff' : '2px solid transparent', cursor: 'pointer', boxShadow: prefs.accent === c ? `0 0 8px ${c}` : 'none', transition: 'all 0.15s' }} />\r\n              ))}\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>Arka Plan Rengi</label>\r\n            <div style={{ display: 'flex', gap: 10, alignItems: 'center' }}>\r\n              <input\r\n                type=\"color\" value={prefs.bgBase}\r\n                onChange={e => set({ bgBase: e.target.value })}\r\n                style={{ width: 48, height: 40, borderRadius: 8, border: 'none', cursor: 'pointer', background: 'none', padding: 2 }}\r\n              />\r\n              <input\r\n                type=\"text\" value={prefs.bgBase}\r\n                onChange={e => { if (/^#[0-9a-fA-F]{0,6}$/.test(e.target.value)) set({ bgBase: e.target.value }); }}\r\n                style={{ ...inp, flex: 1, fontFamily: 'monospace', fontSize: '0.88rem' }}\r\n                placeholder=\"#070e1c\"\r\n              />\r\n            </div>\r\n            <div style={{ display: 'flex', gap: 6, marginTop: 10, flexWrap: 'wrap' }}>\r\n              {['#070e1c','#050f1a','#0a0714','#061410','#0f0c04','#0a0f18','#0f0505','#111827'].map(c => (\r\n                <button key={c} onClick={() => set({ bgBase: c })}\r\n                  style={{ width: 26, height: 26, borderRadius: 7, background: c, border: prefs.bgBase === c ? '2px solid #fff' : '2px solid rgba(255,255,255,0.2)', cursor: 'pointer', transition: 'all 0.15s' }} />\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n        {/* Canl─▒ ├╢nizleme */}\r\n        <div style={{ marginTop: 14, borderRadius: 12, overflow: 'hidden', border: '1px solid rgba(255,255,255,0.08)' }}>\r\n          <div style={{ background: prefs.bgBase, padding: '14px 16px', display: 'flex', gap: 10, alignItems: 'center' }}>\r\n            <div style={{ width: 32, height: 32, borderRadius: 9, background: `linear-gradient(135deg, ${prefs.accent}, ${prefs.accent}cc)`, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '0.9rem' }}>≡ƒöÑ</div>\r\n            <div>\r\n              <div style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.88rem' }}>├ûnizleme</div>\r\n              <div style={{ color: '#475569', fontSize: '0.72rem' }}>Se├ºilen tema g├╢r├╝n├╝m├╝</div>\r\n            </div>\r\n            <button style={{ marginLeft: 'auto', background: `linear-gradient(135deg, ${prefs.accent}, ${prefs.accent}cc)`, border: 'none', borderRadius: 8, color: '#fff', padding: '6px 14px', fontWeight: 700, fontSize: '0.8rem', cursor: 'pointer' }}>\r\n              Buton\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Yaz─▒ & Boyut */}\r\n      <Card title=\"≡ƒöñ Yaz─▒ & Boyut\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>\r\n          <div>\r\n            <label style={lbl}>Yaz─▒ Boyutu</label>\r\n            <div style={{ display: 'flex', gap: 6 }}>\r\n              {([0.85, 1, 1.1, 1.2] as const).map(s => (\r\n                <button key={s} onClick={() => set({ fontScale: s })}\r\n                  style={{ flex: 1, padding: '9px 4px', border: 'none', borderRadius: 8, cursor: 'pointer', fontWeight: 600, fontSize: '0.8rem', background: prefs.fontScale === s ? prefs.accent : 'rgba(255,255,255,0.05)', color: prefs.fontScale === s ? '#fff' : '#64748b', transition: 'all 0.15s' }}>\r\n                  {fontLabels[s]}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>K├╢┼ƒe Yuvarlama</label>\r\n            <div style={{ display: 'flex', gap: 6 }}>\r\n              {([6, 10, 14, 20] as const).map(r => (\r\n                <button key={r} onClick={() => set({ cardRadius: r })}\r\n                  style={{ flex: 1, padding: '9px 4px', border: 'none', borderRadius: r, cursor: 'pointer', fontWeight: 600, fontSize: '0.75rem', background: prefs.cardRadius === r ? prefs.accent : 'rgba(255,255,255,0.05)', color: prefs.cardRadius === r ? '#fff' : '#64748b', transition: 'all 0.15s' }}>\r\n                  {radiusLabels[r]}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Animasyon & Mod */}\r\n      <Card title=\"ΓÜí Animasyon & G├╢r├╝n├╝m\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>\r\n          <div>\r\n            <label style={lbl}>Animasyon H─▒z─▒</label>\r\n            <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>\r\n              {(['hizli', 'normal', 'yavas', 'yok'] as const).map(s => (\r\n                <button key={s} onClick={() => set({ animSpeed: s })}\r\n                  style={{ flex: 1, padding: '9px 6px', border: 'none', borderRadius: 8, cursor: 'pointer', fontWeight: 600, fontSize: '0.78rem', background: prefs.animSpeed === s ? prefs.accent : 'rgba(255,255,255,0.05)', color: prefs.animSpeed === s ? '#fff' : '#64748b', transition: 'all 0.15s', whiteSpace: 'nowrap' }}>\r\n                  {animLabels[s]}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n          <div>\r\n            <label style={lbl}>Kompakt Mod</label>\r\n            <div style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '10px 14px', background: 'rgba(0,0,0,0.2)', borderRadius: 10 }}>\r\n              <div style={{ flex: 1 }}>\r\n                <div style={{ color: '#f1f5f9', fontSize: '0.85rem', fontWeight: 600 }}>S─▒k─▒┼ƒ─▒k G├╢r├╝n├╝m</div>\r\n                <div style={{ color: '#475569', fontSize: '0.72rem', marginTop: 2 }}>Tablo ve padding'leri k├╝├º├╝lt├╝r</div>\r\n              </div>\r\n              <button\r\n                onClick={() => set({ compactMode: !prefs.compactMode })}\r\n                style={{ width: 48, height: 26, borderRadius: 13, border: 'none', cursor: 'pointer', position: 'relative', background: prefs.compactMode ? prefs.accent : '#334155', transition: 'background 0.2s', flexShrink: 0 }}\r\n              >\r\n                <div style={{ width: 18, height: 18, borderRadius: '50%', background: '#fff', position: 'absolute', top: 4, left: prefs.compactMode ? 26 : 4, transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </Card>\r\n\r\n      {/* S─▒f─▒rla */}\r\n      <div style={{ display: 'flex', gap: 10 }}>\r\n        <button\r\n          onClick={() => { onChange(DEFAULT_PREFS); showToast('Varsay─▒lan tema geri y├╝klendi!', 'success'); }}\r\n          style={{ flex: 1, padding: '11px 0', background: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 10, color: '#64748b', fontWeight: 700, cursor: 'pointer', fontSize: '0.88rem' }}>\r\n          Γå║ Varsay─▒lana S─▒f─▒rla\r\n        </button>\r\n        <button\r\n          onClick={() => showToast('Tema kaydedildi!', 'success')}\r\n          style={{ flex: 2, padding: '11px 0', background: `linear-gradient(135deg, ${prefs.accent}, ${prefs.accent}cc)`, border: 'none', borderRadius: 10, color: '#fff', fontWeight: 800, cursor: 'pointer', fontSize: '0.88rem' }}>\r\n          ≡ƒÆ╛ Temay─▒ Kaydet\r\n        </button>\r\n      </div>\r\n\r\n      {/* Floating Buton Ayarlar─▒ */}\r\n      <Card title=\"≡ƒöÿ Kayan Buton Ayarlar─▒\">\r\n        <p style={{ color: '#64748b', fontSize: '0.82rem', marginBottom: 14 }}>Ekrandaki kayan butonlar─▒ g├╢ster/gizle. Butonlar─▒ istedi─ƒiniz yere s├╝r├╝kleyebilirsiniz.</p>\r\n        <div style={{ display: 'grid', gap: 10 }}>\r\n          {[\r\n            { key: 'showAIButton' as const, icon: '≡ƒñû', label: 'AI Asistan Butonu', desc: 'Sol alttaki yapay zeka butonu' },\r\n            { key: 'showFABButton' as const, icon: 'Γ₧ò', label: 'H─▒zl─▒ ─░┼ƒlem Butonu', desc: 'Sa─ƒ alttaki h─▒zl─▒ sat─▒┼ƒ/gelir/gider butonu' },\r\n            { key: 'showReportButton' as const, icon: '≡ƒÉ¢', label: 'Hata Bildirme Butonu', desc: 'Hata bildirme, not alma ve takip butonu' },\r\n          ].map(item => (\r\n            <div key={item.key} style={{ display: 'flex', alignItems: 'center', gap: 12, padding: '12px 14px', background: 'rgba(0,0,0,0.2)', borderRadius: 10, border: '1px solid rgba(255,255,255,0.05)' }}>\r\n              <span style={{ fontSize: '1.3rem' }}>{item.icon}</span>\r\n              <div style={{ flex: 1 }}>\r\n                <div style={{ color: '#f1f5f9', fontWeight: 600, fontSize: '0.85rem' }}>{item.label}</div>\r\n                <div style={{ color: '#475569', fontSize: '0.75rem', marginTop: 2 }}>{item.desc}</div>\r\n              </div>\r\n              <div\r\n                onClick={() => onChange({ ...prefs, [item.key]: !prefs[item.key] })}\r\n                style={{ width: 48, height: 26, borderRadius: 13, background: prefs[item.key] ? prefs.accent : '#334155', position: 'relative', cursor: 'pointer', transition: 'background 0.2s', flexShrink: 0 }}\r\n              >\r\n                <div style={{ position: 'absolute', top: 3, left: prefs[item.key] ? 25 : 3, width: 20, height: 20, borderRadius: '50%', background: '#fff', transition: 'left 0.2s', boxShadow: '0 1px 4px rgba(0,0,0,0.3)' }} />\r\n              </div>\r\n            </div>\r\n          ))}\r\n          <button\r\n            onClick={() => {\r\n              localStorage.removeItem('aiBtnPos');\r\n              localStorage.removeItem('fabBtnPos');\r\n              localStorage.removeItem('reportBtnPos');\r\n              showToast('Buton konumlar─▒ s─▒f─▒rland─▒!', 'success');\r\n            }}\r\n            style={{ padding: '9px 0', background: 'rgba(255,255,255,0.04)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: 8, color: '#64748b', cursor: 'pointer', fontWeight: 600, fontSize: '0.82rem' }}>\r\n            ≡ƒôì Buton Konumlar─▒n─▒ S─▒f─▒rla\r\n          </button>\r\n        </div>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction FV({ label, value, onChange, type = 'text', inputMode }: { label: string; value: string; onChange: (v: string) => void; type?: string; inputMode?: React.HTMLAttributes<HTMLInputElement>['inputMode'] }) {\r\n  return (\r\n    <div>\r\n      <label style={lbl}>{label}</label>\r\n      <input type={type} inputMode={inputMode} value={value} onChange={e => onChange(e.target.value)} style={inp} />\r\n    </div>\r\n  );\r\n}\r\n\r\n// ΓöÇΓöÇ Kategori Y├╢netim Component ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction KategoriYonetim({ db, save }: { db: DB; save: (fn: (prev: DB) => DB) => void }) {\r\n  const { showToast } = useToast();\r\n  const { showConfirm } = useConfirm();\r\n  const cats = db.productCategories || [];\r\n  const [yeniAd, setYeniAd] = useState('');\r\n  const [yeniIcon, setYeniIcon] = useState('≡ƒôª');\r\n  const [editId, setEditId] = useState<string | null>(null);\r\n  const [editForm, setEditForm] = useState({ name: '', icon: '' });\r\n\r\n  const addKat = () => {\r\n    const ad = yeniAd.trim();\r\n    if (!ad) { showToast('Kategori ad─▒ gerekli!', 'error'); return; }\r\n    const id = ad.toLowerCase()\r\n      .replace(/─ƒ/g,'g').replace(/├╝/g,'u').replace(/┼ƒ/g,'s')\r\n      .replace(/─▒/g,'i').replace(/├╢/g,'o').replace(/├º/g,'c')\r\n      .replace(/[^a-z0-9]/g,'_').replace(/_+/g,'_');\r\n    if (cats.find(c => c.id === id)) { showToast('Bu ID zaten var!', 'error'); return; }\r\n    const nowIso = new Date().toISOString();\r\n    save(prev => ({\r\n      ...prev,\r\n      productCategories: [...(prev.productCategories || []), { id, name: ad, icon: yeniIcon, createdAt: nowIso }],\r\n    }));\r\n    setYeniAd(''); setYeniIcon('≡ƒôª');\r\n    showToast('Kategori eklendi!', 'success');\r\n  };\r\n\r\n  const saveEdit = (id: string) => {\r\n    if (!editForm.name.trim()) { showToast('Ad gerekli!', 'error'); return; }\r\n    save(prev => ({\r\n      ...prev,\r\n      productCategories: (prev.productCategories || []).map(c =>\r\n        c.id === id ? { ...c, name: editForm.name.trim(), icon: editForm.icon || c.icon } : c\r\n      ),\r\n    }));\r\n    setEditId(null);\r\n    showToast('G├╝ncellendi!', 'success');\r\n  };\r\n\r\n  const deleteKat = (id: string) => {\r\n    const used = db.products.filter(p => !p.deleted && p.category === id).length;\r\n    if (used > 0) { showToast(`${used} ├╝r├╝n bu kategoriyi kullan─▒yor, silemezsiniz!`, 'error'); return; }\r\n    showConfirm('Kategori Sil', 'Bu kategoriyi silmek istiyor musunuz?', () => {\r\n      save(prev => ({ ...prev, productCategories: (prev.productCategories || []).filter(c => c.id !== id) }));\r\n      showToast('Kategori silindi!', 'success');\r\n    });\r\n  };\r\n\r\n  return (\r\n    <Card title=\"≡ƒÅ╖∩╕Å ├£r├╝n Kategorileri\">\r\n      <div style={{ display: 'flex', flexDirection: 'column', gap: 8, marginBottom: 20 }}>\r\n        {cats.length === 0 && (\r\n          <div style={{ color: '#475569', textAlign: 'center', padding: 24, fontSize: '0.88rem' }}>Hen├╝z kategori yok</div>\r\n        )}\r\n        {cats.map(c => (\r\n          <div key={c.id} style={{ display: 'flex', alignItems: 'center', gap: 10, background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '10px 14px', border: '1px solid rgba(255,255,255,0.06)' }}>\r\n            {editId === c.id ? (\r\n              <>\r\n                <input value={editForm.icon} onChange={e => setEditForm(f => ({ ...f, icon: e.target.value }))} style={{ ...inp, width: 48, textAlign: 'center', fontSize: '1.1rem', padding: '6px' }} maxLength={2} />\r\n                <input value={editForm.name} onChange={e => setEditForm(f => ({ ...f, name: e.target.value }))} style={{ ...inp, flex: 1, padding: '7px 10px' }} autoFocus />\r\n                <button onClick={() => saveEdit(c.id)} style={{ background: '#10b981', border: 'none', borderRadius: 8, color: '#fff', padding: '6px 12px', cursor: 'pointer', fontWeight: 700, fontSize: '0.82rem' }}>Γ£ô</button>\r\n                <button onClick={() => setEditId(null)} style={{ background: 'rgba(255,255,255,0.08)', border: 'none', borderRadius: 8, color: '#94a3b8', padding: '6px 10px', cursor: 'pointer' }}>Γ£ò</button>\r\n              </>\r\n            ) : (\r\n              <>\r\n                <span style={{ fontSize: '1.4rem', minWidth: 28, textAlign: 'center' }}>{c.icon}</span>\r\n                <span style={{ flex: 1, color: '#f1f5f9', fontWeight: 600 }}>{c.name}</span>\r\n                <span style={{ color: '#334155', fontSize: '0.75rem', fontFamily: 'monospace' }}>{c.id}</span>\r\n                <span style={{ color: '#475569', fontSize: '0.78rem' }}>{db.products.filter(p => !p.deleted && p.category === c.id).length} ├╝r├╝n</span>\r\n                <button onClick={() => { setEditId(c.id); setEditForm({ name: c.name, icon: c.icon }); }} style={{ background: 'rgba(59,130,246,0.12)', border: 'none', borderRadius: 8, color: '#60a5fa', padding: '5px 10px', cursor: 'pointer', fontSize: '0.8rem' }}>Γ£Å∩╕Å</button>\r\n                <button onClick={() => deleteKat(c.id)} style={{ background: 'rgba(239,68,68,0.1)', border: 'none', borderRadius: 8, color: '#ef4444', padding: '5px 10px', cursor: 'pointer', fontSize: '0.8rem' }}>≡ƒùæ∩╕Å</button>\r\n              </>\r\n            )}\r\n          </div>\r\n        ))}\r\n      </div>\r\n      <div style={{ display: 'flex', gap: 8 }}>\r\n        <input value={yeniIcon} onChange={e => setYeniIcon(e.target.value)} style={{ ...inp, width: 52, textAlign: 'center', fontSize: '1.2rem' }} placeholder=\"≡ƒôª\" maxLength={2} />\r\n        <input value={yeniAd} onChange={e => setYeniAd(e.target.value)} onKeyDown={e => e.key === 'Enter' && addKat()} style={{ ...inp, flex: 1 }} placeholder=\"Yeni kategori ad─▒...\" />\r\n        <button onClick={addKat} style={{ padding: '10px 18px', background: 'linear-gradient(135deg, #ff5722, #ff7043)', border: 'none', borderRadius: 10, color: '#fff', cursor: 'pointer', fontWeight: 700, whiteSpace: 'nowrap' }}>+ Ekle</button>\r\n      </div>\r\n      <p style={{ color: '#334155', fontSize: '0.75rem', marginTop: 10 }}>├£r├╝nleri kullanan kategoriler silinemez.</p>\r\n    </Card>\r\n  );\r\n}\r\n\r\n// ΓöÇΓöÇ Hakk─▒nda Paneli ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ\r\nfunction AboutPanel({ db }: { db: DB }) {\r\n  const totalRecords = [db.products, db.sales, db.cari, db.kasa, db.invoices || [], db.orders, db.suppliers].reduce((s, a) => s + a.length, 0);\r\n  const lsKB = Math.round(new Blob([localStorage.getItem('sobaYonetim') || '']).size / 1024);\r\n\r\n  const [appCfg, setAppCfg] = useState(loadAppConfig);\r\n  const [editVersion, setEditVersion] = useState(false);\r\n  const [versionInput, setVersionInput] = useState(appCfg.version);\r\n  const [versionErr, setVersionErr] = useState('');\r\n  const [expandedVersion, setExpandedVersion] = useState<string | null>(CHANGELOG[0]?.version || null);\r\n\r\n  const saveVersion = () => {\r\n    if (!validateVersion(versionInput)) {\r\n      setVersionErr('Format: 2.1.0 veya 2.1.0-beta');\r\n      return;\r\n    }\r\n    const next = { ...appCfg, version: versionInput.trim() };\r\n    setAppCfg(next);\r\n    saveAppConfig(next);\r\n    setEditVersion(false);\r\n    setVersionErr('');\r\n  };\r\n\r\n  const techStack = [\r\n    { name: 'React 19', color: '#61dafb' },\r\n    { name: 'TypeScript 6', color: '#3178c6' },\r\n    { name: 'Vite 7', color: '#646cff' },\r\n    { name: 'Tailwind CSS v4', color: '#38bdf8' },\r\n    { name: 'Firebase Firestore', color: '#ffa000' },\r\n    { name: 'Capacitor 8', color: '#119eff' },\r\n    { name: 'Recharts', color: '#8884d8' },\r\n    { name: 'Radix UI', color: '#7c3aed' },\r\n  ];\r\n\r\n  return (\r\n    <div style={{ display: 'grid', gap: 16 }}>\r\n      {/* Logo & Ba┼ƒl─▒k */}\r\n      <div style={{ background: 'linear-gradient(135deg, rgba(255,87,34,0.12), rgba(255,87,34,0.04))', borderRadius: 20, border: '1px solid rgba(255,87,34,0.2)', padding: '32px 28px', textAlign: 'center' }}>\r\n        <div style={{ fontSize: '4rem', marginBottom: 12 }}>{appCfg.appIcon}</div>\r\n        <h2 style={{ color: '#f1f5f9', fontWeight: 900, fontSize: '1.8rem', letterSpacing: '-0.03em', margin: 0 }}>{appCfg.appName}</h2>\r\n        <p style={{ color: '#ff7043', fontWeight: 700, fontSize: '0.9rem', marginTop: 4 }}>{APP_SUBTITLE}</p>\r\n        <div style={{ display: 'flex', justifyContent: 'center', gap: 10, marginTop: 16, flexWrap: 'wrap', alignItems: 'center' }}>\r\n          {/* Versiyon ΓÇö t─▒klanabilir */}\r\n          {editVersion ? (\r\n            <div style={{ display: 'flex', gap: 6, alignItems: 'center' }}>\r\n              <input\r\n                value={versionInput}\r\n                onChange={e => { setVersionInput(e.target.value); setVersionErr(''); }}\r\n                style={{ padding: '4px 10px', background: 'rgba(0,0,0,0.4)', border: `1px solid ${versionErr ? '#ef4444' : '#334155'}`, borderRadius: 8, color: '#f1f5f9', fontSize: '0.85rem', width: 120 }}\r\n                placeholder=\"2.1.0-beta\"\r\n                onKeyDown={e => { if (e.key === 'Enter') saveVersion(); if (e.key === 'Escape') { setEditVersion(false); setVersionErr(''); } }}\r\n                autoFocus\r\n              />\r\n              <button onClick={saveVersion} style={{ padding: '4px 10px', background: 'rgba(16,185,129,0.2)', border: '1px solid rgba(16,185,129,0.3)', borderRadius: 7, color: '#10b981', cursor: 'pointer', fontWeight: 700, fontSize: '0.8rem' }}>Γ£ô</button>\r\n              <button onClick={() => { setEditVersion(false); setVersionErr(''); }} style={{ padding: '4px 8px', background: 'rgba(255,255,255,0.05)', border: 'none', borderRadius: 7, color: '#64748b', cursor: 'pointer', fontSize: '0.8rem' }}>Γ£ò</button>\r\n              {versionErr && <span style={{ color: '#ef4444', fontSize: '0.75rem' }}>{versionErr}</span>}\r\n            </div>\r\n          ) : (\r\n            <button onClick={() => { setEditVersion(true); setVersionInput(appCfg.version); }} title=\"Versiyonu d├╝zenle\" style={{ background: 'rgba(255,87,34,0.15)', border: '1px solid rgba(255,87,34,0.3)', borderRadius: 8, padding: '4px 12px', color: '#ff7043', fontSize: '0.85rem', fontWeight: 700, cursor: 'pointer', fontFamily: 'monospace' }}>\r\n              v{appCfg.version} Γ£Å∩╕Å\r\n            </button>\r\n          )}\r\n          <span style={{ background: 'rgba(255,255,255,0.06)', borderRadius: 8, padding: '4px 12px', color: '#94a3b8', fontSize: '0.8rem', fontWeight: 600 }}>\r\n            DB v{db._version || 1}\r\n          </span>\r\n          <span style={{ background: 'rgba(16,185,129,0.12)', borderRadius: 8, padding: '4px 12px', color: '#10b981', fontSize: '0.8rem', fontWeight: 600 }}>\r\n            {totalRecords} kay─▒t ┬╖ {lsKB} KB\r\n          </span>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Teknoloji Stack */}\r\n      <Card title=\"ΓÜÖ∩╕Å Teknoloji\">\r\n        <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>\r\n          {techStack.map(t => (\r\n            <span key={t.name} style={{ background: `${t.color}15`, border: `1px solid ${t.color}30`, borderRadius: 8, padding: '5px 12px', color: t.color, fontSize: '0.82rem', fontWeight: 700 }}>\r\n              {t.name}\r\n            </span>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Veritaban─▒ ├ûzeti */}\r\n      <Card title=\"≡ƒùä∩╕Å Veritaban─▒ ├ûzeti\">\r\n        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(130px, 1fr))', gap: 10 }}>\r\n          {[\r\n            { icon: '≡ƒôª', label: '├£r├╝nler', count: db.products.filter(p => !p.deleted).length },\r\n            { icon: '≡ƒ¢Æ', label: 'Sat─▒┼ƒlar', count: db.sales.filter(s => !s.deleted).length },\r\n            { icon: '≡ƒæñ', label: 'Cari', count: db.cari.filter(c => !c.deleted).length },\r\n            { icon: '≡ƒÆ░', label: 'Kasa Kay─▒tlar─▒', count: db.kasa.filter(k => !k.deleted).length },\r\n            { icon: '≡ƒº╛', label: 'Faturalar', count: (db.invoices || []).filter(i => !i.deleted).length },\r\n            { icon: '≡ƒÅ¡', label: 'Tedarik├ºiler', count: db.suppliers.length },\r\n            { icon: '≡ƒôï', label: 'Sipari┼ƒler', count: db.orders.length },\r\n            { icon: '≡ƒôê', label: 'Stok Hareketleri', count: db.stockMovements.length },\r\n          ].map(s => (\r\n            <div key={s.label} style={{ background: 'rgba(0,0,0,0.3)', borderRadius: 10, padding: '12px 14px', textAlign: 'center' }}>\r\n              <div style={{ fontSize: '1.3rem', marginBottom: 4 }}>{s.icon}</div>\r\n              <div style={{ color: '#f1f5f9', fontWeight: 800, fontSize: '1.1rem' }}>{s.count}</div>\r\n              <div style={{ color: '#475569', fontSize: '0.72rem', marginTop: 2 }}>{s.label}</div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n\r\n      {/* S├╝r├╝m Kitap├º─▒─ƒ─▒ ΓÇö Changelog */}\r\n      <Card title=\"≡ƒôû S├╝r├╝m Ge├ºmi┼ƒi\">\r\n        <div style={{ display: 'grid', gap: 8 }}>\r\n          {CHANGELOG.map(entry => {\r\n            const isExpanded = expandedVersion === entry.version;\r\n            const isLatest = entry.version === CHANGELOG[0]?.version;\r\n            return (\r\n              <div key={entry.version} style={{ background: isExpanded ? 'rgba(255,87,34,0.05)' : 'rgba(0,0,0,0.2)', borderRadius: 12, border: `1px solid ${isExpanded ? 'rgba(255,87,34,0.2)' : 'rgba(255,255,255,0.05)'}`, overflow: 'hidden', transition: 'all 0.2s' }}>\r\n                {/* Ba┼ƒl─▒k sat─▒r─▒ */}\r\n                <button\r\n                  onClick={() => setExpandedVersion(isExpanded ? null : entry.version)}\r\n                  style={{ width: '100%', display: 'flex', alignItems: 'center', gap: 12, padding: '12px 16px', background: 'none', border: 'none', cursor: 'pointer', textAlign: 'left' }}\r\n                >\r\n                  <span style={{ fontFamily: 'monospace', fontWeight: 800, color: isLatest ? '#ff7043' : '#94a3b8', fontSize: '0.88rem', minWidth: 60 }}>v{entry.version}</span>\r\n                  {isLatest && <span style={{ background: 'rgba(255,87,34,0.2)', color: '#ff7043', borderRadius: 5, padding: '1px 7px', fontSize: '0.68rem', fontWeight: 700 }}>SON</span>}\r\n                  <div style={{ flex: 1 }}>\r\n                    <div style={{ color: '#f1f5f9', fontWeight: 700, fontSize: '0.88rem' }}>{entry.title}</div>\r\n                    <div style={{ color: '#475569', fontSize: '0.75rem', marginTop: 1 }}>{entry.date}</div>\r\n                  </div>\r\n                  <span style={{ color: '#334155', fontSize: '0.85rem', transition: 'transform 0.2s', transform: isExpanded ? 'rotate(180deg)' : 'none' }}>Γû╝</span>\r\n                </button>\r\n\r\n                {/* Detay */}\r\n                {isExpanded && (\r\n                  <div style={{ padding: '0 16px 14px' }}>\r\n                    <p style={{ color: '#64748b', fontSize: '0.82rem', marginBottom: 12, lineHeight: 1.6 }}>{entry.summary}</p>\r\n                    <div style={{ display: 'grid', gap: 5 }}>\r\n                      {entry.changes.map((change, i) => {\r\n                        const cfg = CHANGE_TYPE_CONFIG[change.type];\r\n                        return (\r\n                          <div key={i} style={{ display: 'flex', alignItems: 'flex-start', gap: 8 }}>\r\n                            <span style={{ background: cfg.bg, color: cfg.color, borderRadius: 5, padding: '1px 7px', fontSize: '0.68rem', fontWeight: 700, whiteSpace: 'nowrap', marginTop: 1 }}>{cfg.label}</span>\r\n                            <span style={{ color: '#94a3b8', fontSize: '0.82rem', lineHeight: 1.5 }}>{change.text}</span>\r\n                          </div>\r\n                        );\r\n                      })}\r\n                    </div>\r\n                  </div>\r\n                )}\r\n              </div>\r\n            );\r\n          })}\r\n        </div>\r\n      </Card>\r\n\r\n      {/* Lisans */}\r\n      <Card title=\"≡ƒôä Lisans & Geli┼ƒtirici\">\r\n        <div style={{ display: 'grid', gap: 10 }}>\r\n          {[\r\n            { label: 'Uygulama', value: `${appCfg.appName} ΓÇö ${APP_SUBTITLE}` },\r\n            { label: 'Geli┼ƒtirici', value: 'Pars Pelet' },\r\n            { label: 'Lisans', value: '├ûzel Kullan─▒m ΓÇö T├╝m haklar─▒ sakl─▒d─▒r' },\r\n            { label: 'Platform', value: 'Web (PWA) + Android (Capacitor)' },\r\n          ].map(row => (\r\n            <div key={row.label} style={{ padding: '10px 14px', background: 'rgba(0,0,0,0.2)', borderRadius: 10, border: '1px solid rgba(255,255,255,0.05)', display: 'flex', gap: 12 }}>\r\n              <span style={{ color: '#475569', fontSize: '0.78rem', fontWeight: 600, textTransform: 'uppercase', letterSpacing: '0.04em', minWidth: 80 }}>{row.label}</span>\r\n              <span style={{ color: '#f1f5f9', fontWeight: 600, fontSize: '0.85rem' }}>{row.value}</span>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\pages\\Stock.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\PARS PELET\\Desktop\\tap\\vss\\parspel\\src\\pages\\Suppliers.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'useMemo' is defined but never used. Allowed unused vars must match /^_/u.","line":1,"column":20,"messageId":"unusedVar","endLine":1,"endColumn":27,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"useMemo"},"fix":{"range":[17,26],"text":""},"desc":"Remove unused variable \"useMemo\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'normalizeTR' is defined but never used. Allowed unused vars must match /^_/u.","line":6,"column":10,"messageId":"unusedVar","endLine":6,"endColumn":21,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"normalizeTR"},"fix":{"range":[270,282],"text":""},"desc":"Remove unused variable \"normalizeTR\"."}]},{"ruleId":"prefer-const","severity":1,"message":"'cari' is never reassigned. Use 'const' instead.","line":70,"column":11,"messageId":"useConst","endLine":70,"endColumn":15,"fix":{"range":[3176,3202],"text":"const cari = [...prev.cari];"}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":1,"source":"import { useState, useMemo } from 'react';\r\nimport { Modal } from '@/components/Modal';\r\nimport { useToast } from '@/components/Toast';\r\nimport { useConfirm } from '@/components/ConfirmDialog';\r\nimport { genId, formatMoney, formatDate } from '@/lib/utils-tr';\r\nimport { normalizeTR, similarity } from '@/lib/similarity';\r\nimport type { DB, Supplier, Order, OrderItem, Cari } from '@/types';\r\n\r\ninterface Props { db: DB; save: (fn: (prev: DB) => DB) => void; }\r\n\r\nconst emptySupplier: Omit<Supplier, 'id' | 'createdAt' | 'updatedAt'> = { name: '', category: '', taxNo: '', contact: '', phone: '', email: '', address: '', note: '', totalOrders: 0, totalAmount: 0 };\r\n\r\nexport default function Suppliers({ db, save }: Props) {\r\n  const { showToast } = useToast();\r\n  const { showConfirm } = useConfirm();\r\n  const [tab, setTab] = useState<'suppliers' | 'orders'>('suppliers');\r\n  const [catFilter, setCatFilter] = useState<'hepsi' | 'genel' | 'pelet' | 'boru'>('hepsi');\r\n  const [supModal, setSupModal] = useState(false);\r\n  const [orderModal, setOrderModal] = useState(false);\r\n  const [form, setForm] = useState<Partial<Supplier>>(emptySupplier);\r\n  const [editId, setEditId] = useState<string | null>(null);\r\n  const [search, setSearch] = useState('');\r\n  const [selectedSup, setSelectedSup] = useState('');\r\n  const [dupWarning, setDupWarning] = useState<{ name: string; score: number }[]>([]);\r\n  const [forceSave, setForceSave] = useState(false);\r\n\r\n  const [orderItems, setOrderItems] = useState<OrderItem[]>([]);\r\n  const [orderSupplierId, setOrderSupplierId] = useState('');\r\n  const [deliveryDate, setDeliveryDate] = useState('');\r\n  const [orderNote, setOrderNote] = useState('');\r\n  const [nakliye, setNakliye] = useState(0);\r\n  const [orderProductCat, setOrderProductCat] = useState('');\r\n\r\n  const addOrderItem = (productId: string) => {\r\n    const p = db.products.find(x => x.id === productId);\r\n    if (!p) return;\r\n    setOrderItems(prev => {\r\n      const ex = prev.find(i => i.productId === productId);\r\n      if (ex) return prev.map(i => i.productId === productId ? { ...i, qty: i.qty + 1, lineTotal: (i.qty + 1) * i.unitCost } : i);\r\n      return [...prev, { productId, productName: p.name, qty: 1, unitCost: p.cost, lineTotal: p.cost }];\r\n    });\r\n  };\r\n\r\n  const checkDuplicates = (name: string) => {\r\n    if (!name) return;\r\n    const candidates = [\r\n      ...db.suppliers.filter(s => !editId || s.id !== editId),\r\n      ...(db.peletSuppliers || []),\r\n      ...(db.boruSuppliers || []),\r\n    ];\r\n    const found = candidates\r\n      .map(s => ({ name: s.name, score: similarity(name, s.name) }))\r\n      .filter(x => x.score >= 60)\r\n      .sort((a, b) => b.score - a.score)\r\n      .slice(0, 3);\r\n    setDupWarning(found);\r\n    setForceSave(false);\r\n  };\r\n\r\n  const saveSupplier = () => {\r\n    if (!form.name) { showToast('Tedarik├ºi ad─▒ gerekli!', 'error'); return; }\r\n    if (dupWarning.length > 0 && !forceSave) {\r\n      setForceSave(true); // ─░kinci t─▒kta zorla kaydet\r\n      return;\r\n    }\r\n    setDupWarning([]); setForceSave(false);\r\n    const nowIso = new Date().toISOString();\r\n    save(prev => {\r\n      const suppliers = [...prev.suppliers];\r\n      let cari = [...prev.cari];\r\n      if (editId) {\r\n        const i = suppliers.findIndex(s => s.id === editId);\r\n        if (i >= 0) {\r\n          suppliers[i] = { ...suppliers[i], ...form, updatedAt: nowIso } as Supplier;\r\n          // Carini de g├╝ncelle\r\n          const ci = cari.findIndex(c => c.id === editId);\r\n          if (ci >= 0) cari[ci] = { ...cari[ci], name: form.name || cari[ci].name, phone: form.phone || cari[ci].phone, updatedAt: nowIso };\r\n        }\r\n        showToast('Tedarik├ºi g├╝ncellendi!');\r\n      } else {\r\n        const newId = genId();\r\n        suppliers.push({ id: newId, createdAt: nowIso, updatedAt: nowIso, totalOrders: 0, totalAmount: 0, name: '', category: '', phone: '', ...form } as Supplier);\r\n        // Otomatik cari kayd─▒ a├º\r\n        const yeniCari: Cari = {\r\n          id: newId, createdAt: nowIso, updatedAt: nowIso,\r\n          name: form.name || '', type: 'tedarikci',\r\n          phone: form.phone || '', email: form.email || '',\r\n          address: form.address || '', taxNo: form.taxNo || '',\r\n          balance: 0,\r\n        };\r\n        cari.push(yeniCari);\r\n        showToast('Tedarik├ºi eklendi, cari kayd─▒ otomatik a├º─▒ld─▒!', 'success');\r\n      }\r\n      return { ...prev, suppliers, cari };\r\n    });\r\n    setSupModal(false);\r\n  };\r\n\r\n  const saveOrder = () => {\r\n    if (!orderSupplierId) {\r\n      if (db.suppliers.length === 0) {\r\n        showToast('├ûnce tedarik├ºi ekleyin! Tedarik├ºiler sekmesine y├╢nlendiriliyorsunuz...', 'error');\r\n        setTimeout(() => { setOrderModal(false); setTab('suppliers'); }, 1500);\r\n        return;\r\n      }\r\n      showToast('Tedarik├ºi se├ºin!', 'error'); return;\r\n    }\r\n    if (orderItems.length === 0) { showToast('├£r├╝n ekleyin!', 'error'); return; }\r\n    const amount = orderItems.reduce((s, i) => s + i.lineTotal, 0);\r\n    const nowIso = new Date().toISOString();\r\n    const order: Order = {\r\n      id: genId(), supplierId: orderSupplierId, items: orderItems, amount,\r\n      nakliye: nakliye > 0 ? nakliye : undefined,\r\n      paidAmount: 0, remainingAmount: amount,\r\n      payments: [], deliveryDate, note: orderNote, status: 'bekliyor', createdAt: nowIso, updatedAt: nowIso,\r\n    };\r\n    save(prev => {\r\n      const suppliers = prev.suppliers.map(s => s.id === orderSupplierId ? { ...s, totalOrders: (s.totalOrders || 0) + 1, totalAmount: (s.totalAmount || 0) + amount } : s);\r\n      return { ...prev, orders: [...prev.orders, order], suppliers };\r\n    });\r\n    showToast('Sipari┼ƒ olu┼ƒturuldu!');\r\n    setOrderItems([]); setOrderSupplierId(''); setDeliveryDate(''); setOrderNote(''); setNakliye(0); setOrderProductCat('');\r\n    setOrderModal(false);\r\n  };\r\n\r\n  const deleteSupplier = (id: string) => {\r\n    showConfirm('Tedarik├ºi Sil', 'Tedarik├ºi ve ili┼ƒkili cari kayd─▒ gizlenecek. Devam etmek istiyor musunuz?', () => {\r\n      const nowIso = new Date().toISOString();\r\n      save(prev => ({\r\n        ...prev,\r\n        suppliers: prev.suppliers.map(s => s.id === id ? { ...s, deleted: true, updatedAt: nowIso } : s),\r\n        // Ayn─▒ ID ile a├º─▒lm─▒┼ƒ cari kayd─▒n─▒ da soft-delete et\r\n        cari: prev.cari.map(c => c.id === id ? { ...c, deleted: true, updatedAt: nowIso } : c),\r\n      }));\r\n      showToast('Silindi!');\r\n    });\r\n  };\r\n\r\n  const updateOrderStatus = (id: string, status: Order['status']) => {\r\n    save(prev => {\r\n      const order = prev.orders.find(o => o.id === id);\r\n      if (!order) return prev;\r\n      const updatedOrder = { ...order, status, updatedAt: new Date().toISOString() };\r\n      let newState = { ...prev, orders: prev.orders.map(o => o.id === id ? updatedOrder : o) };\r\n\r\n      if (status === 'tamamlandi') {\r\n        // ─░dempotency: zaten tamamland─▒ysa stok tekrar art─▒r─▒lmaz\r\n        if (order.stockCompleted) {\r\n          showToast('Sipari┼ƒ tamamland─▒!');\r\n          return newState;\r\n        }\r\n\r\n        // Nakliye pay─▒n─▒ ├╝r├╝n ba┼ƒ─▒na da─ƒ─▒t (tutara oransal)\r\n        const totalOrderAmount = order.amount || 1;\r\n        const nakliyeToplam = order.nakliye || 0;\r\n        const supplier = prev.suppliers.find(s => s.id === order.supplierId);\r\n        const missingProducts: string[] = [];\r\n\r\n        // Stok g├╝ncelle + a─ƒ─▒rl─▒kl─▒ ortalama maliyet hesapla (nakliye dahil)\r\n        const products = prev.products.map(p => {\r\n          const item = order.items.find(i => i.productId === p.id);\r\n          if (!item) return p;\r\n          const nakliyePay = nakliyeToplam > 0 ? (item.lineTotal / totalOrderAmount) * nakliyeToplam / item.qty : 0;\r\n          const yeniMaliyet = item.unitCost + nakliyePay;\r\n          // A─ƒ─▒rl─▒kl─▒ ortalama: (eski maliyet ├ù eski stok + yeni maliyet ├ù yeni adet) / toplam\r\n          const mevcutStok = p.stock || 0;\r\n          const toplamStok = mevcutStok + item.qty;\r\n          const ortMaliyet = toplamStok > 0\r\n            ? ((p.cost * mevcutStok) + (yeniMaliyet * item.qty)) / toplamStok\r\n            : yeniMaliyet;\r\n          return { ...p, stock: toplamStok, cost: Math.round(ortMaliyet * 100) / 100 };\r\n        });\r\n\r\n        // ├£r├╝n bulunamayanlar─▒ tespit et\r\n        order.items.forEach(i => {\r\n          if (!prev.products.find(p => p.id === i.productId)) missingProducts.push(i.productName);\r\n        });\r\n\r\n        const stockMovements = [...prev.stockMovements, ...order.items\r\n          .filter(i => prev.products.find(p => p.id === i.productId))\r\n          .map(i => ({\r\n            id: genId(), productId: i.productId, productName: i.productName, type: 'giris' as const,\r\n            amount: i.qty, before: prev.products.find(p => p.id === i.productId)?.stock || 0,\r\n            after: (prev.products.find(p => p.id === i.productId)?.stock || 0) + i.qty,\r\n            note: `Sipari┼ƒ #${id.slice(0, 8)}${supplier ? ' ΓÇö ' + supplier.name : ''}`, date: new Date().toISOString(),\r\n          }))];\r\n\r\n        // Cari bor├º ekle ΓÇö nakliye dahil toplam tutar ile\r\n        const cariTutar = order.amount + (order.nakliye || 0);\r\n        const cari = prev.cari.map(c => {\r\n          if (c.id === order.supplierId) {\r\n            return { ...c, balance: (c.balance || 0) + cariTutar, updatedAt: new Date().toISOString() };\r\n          }\r\n          return c;\r\n        });\r\n\r\n        if (missingProducts.length > 0) {\r\n          showToast(`Sipari┼ƒ tamamland─▒! ΓÜá∩╕Å Bulunamayan ├╝r├╝nler atland─▒: ${missingProducts.join(', ')}`);\r\n        } else {\r\n          showToast('Sipari┼ƒ tamamland─▒! Stok ve cari g├╝ncellendi.');\r\n        }\r\n\r\n        // stockCompleted bayra─ƒ─▒n─▒ true yap (idempotency)\r\n        const finalOrders = newState.orders.map(o => o.id === id ? { ...o, stockCompleted: true } : o);\r\n        newState = { ...newState, products, stockMovements, cari, orders: finalOrders };\r\n      }\r\n      return newState;\r\n    });\r\n  };\r\n\r\n  const revertOrder = (id: string) => {\r\n    showConfirm('Sipari┼ƒ Geri Al', 'Bu sipari┼ƒi geri almak istiyor musunuz? Stok ve cari de─ƒi┼ƒiklikleri geri al─▒nacak.', () => {\r\n      save(prev => {\r\n        const order = prev.orders.find(o => o.id === id);\r\n        if (!order || order.status !== 'tamamlandi') return prev;\r\n        const nowIso = new Date().toISOString();\r\n\r\n        // Stoklar─▒ geri d├╝┼ƒ├╝r\r\n        const products = prev.products.map(p => {\r\n          const item = order.items.find(i => i.productId === p.id);\r\n          if (!item) return p;\r\n          return { ...p, stock: Math.max(0, p.stock - item.qty) };\r\n        });\r\n\r\n        // Stok hareketlerini ekle (├º─▒k─▒┼ƒ)\r\n        const stockMovements = [...prev.stockMovements, ...order.items.map(i => ({\r\n          id: genId(), productId: i.productId, productName: i.productName, type: 'cikis' as const,\r\n          amount: i.qty, before: prev.products.find(p => p.id === i.productId)?.stock || 0,\r\n          after: Math.max(0, (prev.products.find(p => p.id === i.productId)?.stock || 0) - i.qty),\r\n          note: 'Sipari┼ƒ geri al─▒nd─▒', date: nowIso,\r\n        }))];\r\n\r\n        // Cari borcu geri al\r\n        const cariTutar = order.amount + (order.nakliye || 0);\r\n        const cari = prev.cari.map(c => {\r\n          if (c.id === order.supplierId) {\r\n            return { ...c, balance: (c.balance || 0) - cariTutar, updatedAt: nowIso };\r\n          }\r\n          return c;\r\n        });\r\n\r\n        const orders = prev.orders.map(o => o.id === id ? { ...o, status: 'bekliyor' as const, updatedAt: nowIso } : o);\r\n\r\n        return { ...prev, orders, products, stockMovements, cari };\r\n      });\r\n      showToast('Sipari┼ƒ geri al─▒nd─▒! Stok ve cari g├╝ncellendi.');\r\n    });\r\n  };\r\n\r\n  // T├╝m tedarik├ºileri birle┼ƒtir (kategori etiketi ile)\r\n  const allSuppliers = [\r\n    ...db.suppliers.filter(s => !s.deleted).map(s => ({ ...s, _kat: 'genel' as const })),\r\n    ...(db.peletSuppliers || []).map(s => ({ id: s.id, name: s.name, phone: s.phone || '', email: s.email || '', address: s.address || '', category: 'Pelet', totalOrders: 0, totalAmount: 0, createdAt: s.createdAt, updatedAt: s.updatedAt, _kat: 'pelet' as const })),\r\n    ...(db.boruSuppliers || []).map(s => ({ id: s.id, name: s.name, phone: s.phone || '', email: s.email || '', address: s.address || '', category: 'Boru', totalOrders: 0, totalAmount: 0, createdAt: s.createdAt, updatedAt: s.updatedAt, _kat: 'boru' as const })),\r\n  ];\r\n\r\n  let filteredSuppliers = allSuppliers;\r\n  if (catFilter !== 'hepsi') filteredSuppliers = filteredSuppliers.filter(s => s._kat === catFilter);\r\n  if (search) filteredSuppliers = filteredSuppliers.filter(s => s.name.toLowerCase().includes(search.toLowerCase()) || (s.phone || '').includes(search));\r\n\r\n  let orders = db.orders;\r\n  if (selectedSup) orders = orders.filter(o => o.supplierId === selectedSup);\r\n  const sortedOrders = [...orders].sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\r\n\r\n  const statusColor: Record<string, string> = { bekliyor: '#f59e0b', yolda: '#3b82f6', tamamlandi: '#10b981', iptal: '#ef4444' };\r\n  const statusLabel: Record<string, string> = { bekliyor: 'ΓÅ│ Bekliyor', yolda: '≡ƒÜÜ Yolda', tamamlandi: 'Γ£ô Tamamland─▒', iptal: 'Γ£ò ─░ptal' };\r\n  const catColors: Record<string, string> = { genel: '#ff5722', pelet: '#f59e0b', boru: '#3b82f6' };\r\n  const catLabels: Record<string, string> = { genel: '≡ƒÅ¡ Genel', pelet: '≡ƒî╛ Pelet', boru: '≡ƒöº Boru' };\r\n\r\n  return (\r\n    <div>\r\n      <div style={{ display: 'flex', gap: 8, marginBottom: 20 }}>\r\n        {(['suppliers', 'orders'] as const).map(t => (\r\n          <button key={t} onClick={() => setTab(t)} style={{ padding: '10px 20px', border: 'none', borderRadius: 10, cursor: 'pointer', fontWeight: 700, background: tab === t ? '#ff5722' : '#273548', color: tab === t ? '#fff' : '#94a3b8' }}>\r\n            {t === 'suppliers' ? '≡ƒÅ¡ Tedarik├ºiler' : '≡ƒôª Sipari┼ƒler'}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {tab === 'suppliers' && (\r\n        <>\r\n          <div style={{ display: 'flex', gap: 10, marginBottom: 16, flexWrap: 'wrap' }}>\r\n            <button onClick={() => { setForm(emptySupplier); setEditId(null); setSupModal(true); }} style={{ background: '#ff5722', border: 'none', borderRadius: 10, color: '#fff', padding: '10px 20px', fontWeight: 700, cursor: 'pointer' }}>+ Yeni Tedarik├ºi</button>\r\n            <button onClick={() => setOrderModal(true)} style={{ background: 'rgba(59,130,246,0.15)', border: '1px solid rgba(59,130,246,0.3)', borderRadius: 10, color: '#60a5fa', padding: '10px 18px', fontWeight: 700, cursor: 'pointer' }}>≡ƒôª Sipari┼ƒ Ver</button>\r\n            <input value={search} onChange={e => setSearch(e.target.value)} placeholder=\"≡ƒöì Ara...\" style={{ flex: 1, padding: '9px 13px', background: '#1e293b', border: '1px solid #334155', borderRadius: 10, color: '#f1f5f9' }} />\r\n          </div>\r\n          {/* Kategori filtresi */}\r\n          <div style={{ display: 'flex', gap: 8, marginBottom: 16 }}>\r\n            {(['hepsi', 'genel', 'pelet', 'boru'] as const).map(f => (\r\n              <button key={f} onClick={() => setCatFilter(f)} style={{ padding: '6px 14px', border: 'none', borderRadius: 8, cursor: 'pointer', fontWeight: 600, fontSize: '0.82rem', background: catFilter === f ? '#ff5722' : '#273548', color: catFilter === f ? '#fff' : '#94a3b8' }}>\r\n                {f === 'hepsi' ? '≡ƒöì Hepsi' : catLabels[f]}\r\n              </button>\r\n            ))}\r\n          </div>\r\n          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(260px, 1fr))', gap: 14 }}>\r\n            {filteredSuppliers.length === 0 ? (\r\n              <div style={{ gridColumn: '1/-1', textAlign: 'center', padding: 48, color: '#64748b' }}>Tedarik├ºi bulunamad─▒</div>\r\n            ) : filteredSuppliers.map(s => (\r\n              <div key={s.id} style={{ background: '#1e293b', borderRadius: 12, border: '1px solid #334155', padding: 18 }}>\r\n                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 4 }}>\r\n                  <h4 style={{ fontWeight: 700, color: '#f1f5f9' }}>{s.name}</h4>\r\n                  <span style={{ background: `${catColors[s._kat]}22`, color: catColors[s._kat], borderRadius: 6, padding: '2px 8px', fontSize: '0.75rem', fontWeight: 700 }}>{catLabels[s._kat]}</span>\r\n                </div>\r\n                <p style={{ color: '#64748b', fontSize: '0.82rem', marginBottom: 10 }}>{s.category || 'Genel'}</p>\r\n                {s.phone && <p style={{ color: '#94a3b8', fontSize: '0.85rem', marginBottom: 4 }}>≡ƒô₧ {s.phone}</p>}\r\n                {s.email && <p style={{ color: '#94a3b8', fontSize: '0.82rem', marginBottom: 4 }}>≡ƒôº {s.email}</p>}\r\n                <div style={{ marginTop: 10, paddingTop: 10, borderTop: '1px solid #334155', display: 'flex', justifyContent: 'space-between' }}>\r\n                  <span style={{ color: '#64748b', fontSize: '0.8rem' }}>{s.totalOrders || 0} sipari┼ƒ</span>\r\n                  <span style={{ color: '#10b981', fontSize: '0.85rem', fontWeight: 700 }}>{formatMoney(s.totalAmount || 0)}</span>\r\n                </div>\r\n                {s._kat === 'genel' && (\r\n                  <div style={{ display: 'flex', gap: 8, marginTop: 10 }}>\r\n                    <button onClick={() => { setSelectedSup(s.id); setTab('orders'); }} style={{ flex: 1, background: 'rgba(59,130,246,0.1)', border: 'none', borderRadius: 8, color: '#60a5fa', padding: '7px 0', cursor: 'pointer', fontSize: '0.82rem', fontWeight: 600 }}>≡ƒôª Sipari┼ƒler</button>\r\n                    <button onClick={() => { setForm({ ...s }); setEditId(s.id); setSupModal(true); }} style={{ background: 'rgba(59,130,246,0.1)', border: 'none', borderRadius: 8, color: '#60a5fa', padding: '7px 10px', cursor: 'pointer' }}>Γ£Å∩╕Å</button>\r\n                    <button onClick={() => deleteSupplier(s.id)} style={{ background: 'rgba(239,68,68,0.1)', border: 'none', borderRadius: 8, color: '#ef4444', padding: '7px 10px', cursor: 'pointer' }}>≡ƒùæ∩╕Å</button>\r\n                  </div>\r\n                )}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </>\r\n      )}\r\n\r\n      {tab === 'orders' && (\r\n        <>\r\n          <div style={{ display: 'flex', gap: 10, marginBottom: 16, flexWrap: 'wrap', alignItems: 'center' }}>\r\n            <button onClick={() => setOrderModal(true)} style={{ background: '#ff5722', border: 'none', borderRadius: 10, color: '#fff', padding: '10px 20px', fontWeight: 700, cursor: 'pointer' }}>+ Sipari┼ƒ Ver</button>\r\n            <select value={selectedSup} onChange={e => setSelectedSup(e.target.value)} style={{ padding: '9px 13px', background: '#1e293b', border: '1px solid #334155', borderRadius: 10, color: '#f1f5f9' }}>\r\n              <option value=\"\">T├╝m Tedarik├ºiler</option>\r\n              {db.suppliers.map(s => <option key={s.id} value={s.id}>{s.name}</option>)}\r\n            </select>\r\n          </div>\r\n          <div style={{ background: '#1e293b', borderRadius: 14, border: '1px solid #334155', overflowX: 'auto' }}>\r\n            <table style={{ width: '100%', borderCollapse: 'collapse', whiteSpace: 'nowrap' }}>\r\n              <thead>\r\n                <tr style={{ background: 'rgba(15,23,42,0.6)' }}>\r\n                  {['Tarih', 'Tedarik├ºi', '├£r├╝nler', 'Tutar', 'Durum', ''].map(h => (\r\n                    <th key={h} style={{ padding: '12px 16px', textAlign: 'left', color: '#64748b', fontSize: '0.78rem', fontWeight: 600, textTransform: 'uppercase' }}>{h}</th>\r\n                  ))}\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                {sortedOrders.length === 0 ? (\r\n                  <tr><td colSpan={6} style={{ textAlign: 'center', padding: 40, color: '#64748b' }}>Sipari┼ƒ bulunamad─▒</td></tr>\r\n                ) : sortedOrders.map(o => (\r\n                  <tr key={o.id} style={{ borderBottom: '1px solid rgba(255,255,255,0.04)' }}>\r\n                    <td style={{ padding: '12px 16px', color: '#64748b', fontSize: '0.82rem' }}>{formatDate(o.createdAt)}</td>\r\n                    <td style={{ padding: '12px 16px', color: '#f1f5f9', fontWeight: 600 }}>{db.suppliers.find(s => s.id === o.supplierId)?.name || '-'}</td>\r\n                    <td style={{ padding: '12px 16px', color: '#94a3b8', fontSize: '0.85rem', maxWidth: 200, overflow: 'hidden', textOverflow: 'ellipsis' }}>\r\n                      {o.items.map(i => `${i.productName}├ù${i.qty}`).join(', ')}\r\n                    </td>\r\n                    <td style={{ padding: '12px 16px', color: '#10b981', fontWeight: 700 }}>{formatMoney(o.amount)}</td>\r\n                    <td style={{ padding: '12px 16px' }}>\r\n                      <span style={{ background: `${statusColor[o.status]}22`, color: statusColor[o.status], borderRadius: 6, padding: '2px 8px', fontSize: '0.8rem', fontWeight: 600 }}>{statusLabel[o.status]}</span>\r\n                    </td>\r\n                    <td style={{ padding: '12px 16px' }}>\r\n                      {o.status === 'bekliyor' && (\r\n                        <div style={{ display: 'flex', gap: 6 }}>\r\n                          <button onClick={() => updateOrderStatus(o.id, 'yolda')} style={{ background: 'rgba(59,130,246,0.1)', border: 'none', borderRadius: 6, color: '#60a5fa', padding: '4px 8px', cursor: 'pointer', fontSize: '0.78rem' }}>≡ƒÜÜ Yolda</button>\r\n                          <button onClick={() => updateOrderStatus(o.id, 'tamamlandi')} style={{ background: 'rgba(16,185,129,0.1)', border: 'none', borderRadius: 6, color: '#10b981', padding: '4px 8px', cursor: 'pointer', fontSize: '0.78rem' }}>Γ£ô Tamamla</button>\r\n                        </div>\r\n                      )}\r\n                      {o.status === 'yolda' && (\r\n                        <button onClick={() => updateOrderStatus(o.id, 'tamamlandi')} style={{ background: 'rgba(16,185,129,0.1)', border: 'none', borderRadius: 6, color: '#10b981', padding: '4px 8px', cursor: 'pointer', fontSize: '0.78rem' }}>Γ£ô Tamamla</button>\r\n                      )}\r\n                      {o.status === 'tamamlandi' && (\r\n                        <button onClick={() => revertOrder(o.id)} style={{ background: 'rgba(245,158,11,0.1)', border: 'none', borderRadius: 6, color: '#f59e0b', padding: '4px 8px', cursor: 'pointer', fontSize: '0.78rem' }}>Γå⌐ Geri Al</button>\r\n                      )}\r\n                    </td>\r\n                  </tr>\r\n                ))}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </>\r\n      )}\r\n\r\n      <Modal open={supModal} onClose={() => setSupModal(false)} title={editId ? 'Γ£Å∩╕Å Tedarik├ºi D├╝zenle' : 'Γ₧ò Yeni Tedarik├ºi'}>\r\n        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 14 }}>\r\n          <div style={{ gridColumn: '1/-1' }}>\r\n            <label style={lbl}>Ad *</label>\r\n            <input value={form.name || ''} onChange={e => { setForm(f => ({ ...f, name: e.target.value })); setDupWarning([]); setForceSave(false); }} onBlur={e => checkDuplicates(e.target.value)} style={inp} />\r\n            {dupWarning.length > 0 && (\r\n              <div style={{ marginTop: 8, background: forceSave ? 'rgba(245,158,11,0.08)' : 'rgba(239,68,68,0.08)', border: `1px solid ${forceSave ? 'rgba(245,158,11,0.4)' : 'rgba(239,68,68,0.4)'}`, borderRadius: 8, padding: '10px 12px' }}>\r\n                <p style={{ color: forceSave ? '#f59e0b' : '#ef4444', fontWeight: 700, fontSize: '0.82rem', marginBottom: 4 }}>\r\n                  {forceSave ? 'ΓÜá∩╕Å Yine de kaydetmek i├ºin tekrar \"Kaydet\" a t─▒klay─▒n' : '≡ƒö┤ Benzer tedarik├ºiler bulundu:'}\r\n                </p>\r\n                {dupWarning.map((d, i) => (\r\n                  <p key={i} style={{ color: '#94a3b8', fontSize: '0.8rem', margin: '2px 0' }}>\r\n                    ΓÇó {d.name} <span style={{ color: d.score >= 90 ? '#ef4444' : '#f59e0b', fontWeight: 700 }}>(%{d.score} benzerlik)</span>\r\n                  </p>\r\n                ))}\r\n              </div>\r\n            )}\r\n          </div>\r\n          <div><label style={lbl}>Kategori</label><input value={form.category || ''} onChange={e => setForm(f => ({ ...f, category: e.target.value }))} style={inp} /></div>\r\n          <div><label style={lbl}>Telefon</label><input value={form.phone || ''} onChange={e => setForm(f => ({ ...f, phone: e.target.value }))} style={inp} /></div>\r\n          <div><label style={lbl}>E-posta</label><input type=\"email\" value={form.email || ''} onChange={e => setForm(f => ({ ...f, email: e.target.value }))} style={inp} /></div>\r\n          <div><label style={lbl}>Yetkili</label><input value={form.contact || ''} onChange={e => setForm(f => ({ ...f, contact: e.target.value }))} style={inp} /></div>\r\n          <div style={{ gridColumn: '1/-1' }}><label style={lbl}>Adres</label><textarea value={form.address || ''} onChange={e => setForm(f => ({ ...f, address: e.target.value }))} style={{ ...inp, minHeight: 60 }} /></div>\r\n          <div style={{ gridColumn: '1/-1' }}><label style={lbl}>Not</label><textarea value={form.note || ''} onChange={e => setForm(f => ({ ...f, note: e.target.value }))} style={{ ...inp, minHeight: 60 }} /></div>\r\n        </div>\r\n        <div style={{ display: 'flex', gap: 10, marginTop: 20 }}>\r\n          <button onClick={saveSupplier} style={{ flex: 1, background: forceSave ? '#f59e0b' : '#10b981', border: 'none', borderRadius: 10, color: '#fff', padding: '11px 0', fontWeight: 700, cursor: 'pointer' }}>\r\n            {forceSave ? 'ΓÜá∩╕Å Yine de Kaydet' : '≡ƒÆ╛ Kaydet'}\r\n          </button>\r\n          <button onClick={() => setSupModal(false)} style={{ background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', padding: '11px 20px', cursor: 'pointer' }}>─░ptal</button>\r\n        </div>\r\n      </Modal>\r\n\r\n      <Modal open={orderModal} onClose={() => setOrderModal(false)} title=\"≡ƒôª Sipari┼ƒ Ver\" maxWidth={620}>\r\n        <div>\r\n          <label style={lbl}>Tedarik├ºi *</label>\r\n          <select value={orderSupplierId} onChange={e => setOrderSupplierId(e.target.value)} style={{ ...inp, marginBottom: 12 }}>\r\n            <option value=\"\">-- Tedarik├ºi Se├º --</option>\r\n            {db.suppliers.map(s => <option key={s.id} value={s.id}>{s.name}</option>)}\r\n          </select>\r\n          <label style={lbl}>├£r├╝n Ekle</label>\r\n          <div style={{ display: 'flex', gap: 8, marginBottom: 12 }}>\r\n            <select value={orderProductCat} onChange={e => setOrderProductCat(e.target.value)} style={{ ...inp, flex: '0 0 120px' }}>\r\n              <option value=\"\">T├╝m Kat.</option>\r\n              {[...new Set(db.products.filter(p => !p.deleted).map(p => p.category).filter(Boolean))].map(c => (\r\n                <option key={c} value={c}>{c}</option>\r\n              ))}\r\n            </select>\r\n            <select onChange={e => { if (e.target.value) { addOrderItem(e.target.value); e.target.value = ''; } }} style={{ ...inp, flex: 1 }}>\r\n              <option value=\"\">-- ├£r├╝n Se├º --</option>\r\n              {db.products.filter(p => !p.deleted && (!orderProductCat || p.category === orderProductCat)).map(p => <option key={p.id} value={p.id}>{p.name}</option>)}\r\n            </select>\r\n          </div>\r\n          {orderItems.map(item => (\r\n            <div key={item.productId} style={{ display: 'flex', gap: 8, alignItems: 'center', marginBottom: 8, background: '#0f172a', borderRadius: 8, padding: '8px 10px' }}>\r\n              <span style={{ flex: 1, color: '#f1f5f9', fontSize: '0.88rem' }}>{item.productName}</span>\r\n              <input type=\"number\" inputMode=\"decimal\" value={item.qty} min={1} onChange={e => { const qty = parseInt(e.target.value) || 1; setOrderItems(prev => prev.map(i => i.productId === item.productId ? { ...i, qty, lineTotal: qty * i.unitCost } : i)); }} style={{ width: 55, background: '#1e293b', border: '1px solid #334155', borderRadius: 6, color: '#f1f5f9', padding: '4px 6px', textAlign: 'center' }} />\r\n              <input type=\"number\" inputMode=\"decimal\" value={item.unitCost} step={0.01} onChange={e => { const cost = parseFloat(e.target.value) || 0; setOrderItems(prev => prev.map(i => i.productId === item.productId ? { ...i, unitCost: cost, lineTotal: i.qty * cost } : i)); }} style={{ width: 80, background: '#1e293b', border: '1px solid #334155', borderRadius: 6, color: '#f1f5f9', padding: '4px 6px' }} />\r\n              <button onClick={() => setOrderItems(prev => prev.filter(i => i.productId !== item.productId))} style={{ background: 'none', border: 'none', color: '#ef4444', cursor: 'pointer' }}>Γ£ò</button>\r\n            </div>\r\n          ))}\r\n          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, marginTop: 12 }}>\r\n            <div><label style={lbl}>Teslim Tarihi</label><input type=\"date\" value={deliveryDate} onChange={e => setDeliveryDate(e.target.value)} style={inp} /></div>\r\n            <div>\r\n              <label style={lbl}>Nakliye Maliyeti (Γé║)</label>\r\n              <input type=\"number\" inputMode=\"decimal\" value={nakliye || ''} min={0} step={0.01} placeholder=\"0,00\" onChange={e => setNakliye(parseFloat(e.target.value) || 0)} style={inp} />\r\n            </div>\r\n          </div>\r\n          <div style={{ marginTop: 12 }}><label style={lbl}>Not</label><textarea value={orderNote} onChange={e => setOrderNote(e.target.value)} style={{ ...inp, minHeight: 50 }} /></div>\r\n          {orderItems.length > 0 && (\r\n            <div style={{ background: '#0f172a', borderRadius: 8, padding: '12px 14px', marginTop: 12 }}>\r\n              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>\r\n                <span style={{ color: '#94a3b8' }}>├£r├╝n Toplam─▒</span>\r\n                <span style={{ color: '#f1f5f9', fontWeight: 700 }}>{formatMoney(orderItems.reduce((s, i) => s + i.lineTotal, 0))}</span>\r\n              </div>\r\n              {nakliye > 0 && (\r\n                <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>\r\n                  <span style={{ color: '#94a3b8', fontSize: '0.85rem' }}>+ Nakliye</span>\r\n                  <span style={{ color: '#f59e0b', fontWeight: 600, fontSize: '0.85rem' }}>{formatMoney(nakliye)}</span>\r\n                </div>\r\n              )}\r\n              <div style={{ display: 'flex', justifyContent: 'space-between', borderTop: '1px solid #1e3a5f', paddingTop: 8 }}>\r\n                <span style={{ color: '#94a3b8' }}>Genel Toplam</span>\r\n                <span style={{ color: '#10b981', fontWeight: 800, fontSize: '1.1rem' }}>{formatMoney(orderItems.reduce((s, i) => s + i.lineTotal, 0) + nakliye)}</span>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n        <div style={{ display: 'flex', gap: 10, marginTop: 20 }}>\r\n          <button onClick={saveOrder} style={{ flex: 1, background: '#ff5722', border: 'none', borderRadius: 10, color: '#fff', padding: '11px 0', fontWeight: 700, cursor: 'pointer' }}>≡ƒôª Sipari┼ƒ Ver</button>\r\n          <button onClick={() => setOrderModal(false)} style={{ background: '#273548', border: '1px solid #334155', borderRadius: 10, color: '#94a3b8', padding: '11px 20px', cursor: 'pointer' }}>─░ptal</button>\r\n        </div>\r\n      </Modal>\r\n    </div>\r\n  );\r\n}\r\n\r\nconst lbl: React.CSSProperties = { display: 'block', marginBottom: 6, color: '#94a3b8', fontSize: '0.85rem', fontWeight: 500 };\r\nconst inp: React.CSSProperties = { width: '100%', padding: '10px 14px', background: 'rgba(15,23,42,0.